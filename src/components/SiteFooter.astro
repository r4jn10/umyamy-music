---
// SiteFooter.astro
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<style>
  /* 日本語の不自然な改行を抑制（文節で折り返す） */
  .jp-text { word-break: auto-phrase; line-break: strict; }
  /* 波打ち際のディバイダー（砂色の背景 → 白いフッターへの繋ぎ） */
  .wave-divider { display: block; width: 100%; height: 56px; margin-bottom: -1px; }
</style>

<!-- 波のディバイダー（フッター＝波打ち際） -->
<div class="mt-20 w-full" aria-hidden="true">
  <svg class="wave-divider" viewBox="0 0 1440 56" preserveAspectRatio="none">
    <path fill="#ffeef0" opacity="0.6"
          d="M0,30 C180,52 360,10 540,26 C720,42 900,14 1080,24 C1260,34 1380,20 1440,26 L1440,56 L0,56 Z"/>
    <path fill="#eaf4fc" opacity="0.75"
          d="M0,38 C200,18 420,48 640,36 C860,24 1080,46 1260,38 C1350,34 1410,38 1440,40 L1440,56 L0,56 Z"/>
    <path fill="#ffffff"
          d="M0,46 C240,32 480,52 720,44 C960,36 1200,50 1440,42 L1440,56 L0,56 Z"/>
  </svg>
</div>

<footer class="bg-white w-full">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <div>
        <img src={`${base}/logo.svg`} alt="うみゃみーMusic" class="h-8 w-auto" />
        <p class="jp-text text-xs text-slate-400 mt-1.5 leading-relaxed max-w-sm">
          水面まどかさん・白砂あやねさんの歌枠・歌ってみたをまとめた非公式ファンサイト。動画・楽曲の権利はご本人および各権利者に帰属します。ANYCOLOR株式会社およびにじさんじ公式とは関係ありません。
        </p>
        <div class="flex flex-wrap gap-4 mt-4">
          <a href="https://www.youtube.com/@MinamoMadoka" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-madoka hover:underline">水面まどかさん ▸ YouTube</a>
          <a href="https://www.youtube.com/@ShirasaAyane" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-ayane hover:underline">白砂あやねさん ▸ YouTube</a>
        </div>
      </div>

      <div class="flex flex-col gap-2 md:items-end">
        <div class="flex flex-wrap gap-x-4 gap-y-2 md:justify-end">
          <button type="button" data-open="members" class="text-xs font-semibold text-slate-500 hover:text-ink transition">うみゃみーについて</button>
          <button type="button" data-open="about" class="text-xs font-semibold text-slate-500 hover:text-ink transition">このサイトについて</button>
          <a href="https://marshmallow-qa.com/u9dv88bf3mpjyaa" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-slate-500 hover:text-ink transition">お問い合わせ（マシュマロ）</a>
          <a href="https://x.com/teleprompter0" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-slate-500 hover:text-ink transition">お問い合わせ（X）</a>
          <button type="button" data-cookie-settings class="text-xs font-semibold text-slate-500 hover:text-ink transition">Cookie 設定</button>
        </div>
        <p class="text-[11px] text-slate-400 md:text-right mt-2">© 2026 navi</p>
      </div>
    </div>
  </div>
</footer>

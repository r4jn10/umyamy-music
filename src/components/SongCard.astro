---
// src/components/SongCard.astro
interface Props {
  song: {
    id: string;
    title: string;
    artist: string;
    performers: string[];
    unit?: string;
    category: string;
    streamType?: string;
    youtube: { videoId: string; timestampSec?: number; url: string; };
    streamDate: string;
    streamTitle?: string;
    tags?: string[];
    notes?: string;
  };
}

const { song } = Astro.props;

const CAT_LABEL: Record<string, string> = {
  uta_waku: '歌枠',
  cover: '歌ってみた',
  short: 'ショート',
};

// 水面まどかを先に並べる
const MEMBER_ORDER = ['水面まどか', '白砂あやね'];
const performers = [...song.performers].sort(
  (a, b) => MEMBER_ORDER.indexOf(a) - MEMBER_ORDER.indexOf(b)
);

const memberChip = (p: string) =>
  p === '水面まどか'
    ? 'text-[#ff8184] bg-[#ffeef0]'
    : 'text-[#54a2e5] bg-[#eaf4fc]';

const thumbUrl = `https://img.youtube.com/vi/${song.youtube.videoId}/mqdefault.jpg`;
const isDuet = performers.length > 1;
---

<div
  class="song-card-item card group cursor-pointer overflow-hidden"
  data-id={song.id}
>
  <div class="thumb-wrap">
    <img src={thumbUrl} alt={song.title} loading="lazy" decoding="async" />
    <div class="play-overlay">
      <div class="play-btn">
        <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      </div>
    </div>
    <span class="playing-badge ts-badge hidden">再生中</span>
  </div>

  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="font-bold text-slate-900 text-[15px] leading-snug flex-1">{song.title}</h3>
      <span class="shrink-0 text-[11px] px-2 py-0.5 rounded-full font-semibold text-slate-500 bg-slate-100 whitespace-nowrap">
        {CAT_LABEL[song.category] || song.category}
      </span>
    </div>

    <p class="text-xs text-slate-400 font-medium mb-3 truncate">{song.artist}</p>

    <div class="flex items-center justify-between gap-2">
      <div class="flex gap-1 flex-wrap">
        {isDuet && (
          <span class="text-[10px] px-2 py-0.5 rounded-full font-semibold text-white"
                style="background:linear-gradient(135deg,#ff8184,#54a2e5)">うみゃみー</span>
        )}
        {performers.map(p => (
          <span class={`text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChip(p)}`}>{p}</span>
        ))}
      </div>
      <span class="text-[11px] font-medium text-slate-400 whitespace-nowrap">{song.streamDate}</span>
    </div>

    {song.tags && song.tags.length > 0 && (
      <div class="flex gap-1 flex-wrap mt-2.5">
        {song.tags.slice(0, 3).map(t => (
          <span class="text-[10px] text-slate-400 bg-slate-50 border border-slate-100 px-2 py-0.5 rounded">#{t}</span>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .song-card-item:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(15,23,42,.08); border-color: #cbd5e1; }
  .song-card-item.is-playing { border-color: #ff8184; box-shadow: 0 0 0 2px #ff8184; }

  .thumb-wrap { position: relative; aspect-ratio: 16/9; background: #f1f5f9; overflow: hidden; }
  .thumb-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s ease; }
  .song-card-item:hover .thumb-wrap img { transform: scale(1.05); }

  .play-overlay {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: rgba(15,23,42,.25); opacity: 0; transition: opacity .2s ease;
  }
  .song-card-item:hover .play-overlay { opacity: 1; }
  .play-btn {
    width: 46px; height: 46px; border-radius: 9999px; display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,.18); border: 2px solid #fff; backdrop-filter: blur(2px);
  }

  .ts-badge {
    position: absolute; bottom: 8px; right: 8px;
    background: rgba(15,23,42,.78); color: #fff; font-size: .7rem; font-weight: 600;
    padding: 2px 7px; border-radius: 6px; font-variant-numeric: tabular-nums;
  }
  .playing-badge { background: #ff8184; left: 8px; right: auto; }
</style>

---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "うみゃみーMusic",
  description = "水面まどか・白砂あやねの歌枠・歌ってみたをまとめた非公式まとめサイトです。"
} = Astro.props;

// GitHub Pages で公開されたときに、base パスが自動で考慮されるようにします。
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="icon" href={`${base}/favicon.ico`} />
  <meta name="generator" content={Astro.generator} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen flex flex-col">

  <!-- ロード画面（読み込み完了でフェードアウト） -->
  <div id="siteLoader" class="site-loader" aria-hidden="true">
    <div class="loader-inner">
      <span class="font-display loader-word">うみゃみー<span class="loader-accent">Music</span></span>
      <span class="loader-bar"><span class="loader-bar-fill"></span></span>
    </div>
  </div>

  <style>
    .site-loader {
      position: fixed; inset: 0; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      background: #ffffff; transition: opacity .4s ease, visibility .4s ease;
    }
    .site-loader.is-hidden { opacity: 0; visibility: hidden; }
    .loader-inner { display: flex; flex-direction: column; align-items: center; gap: 16px; }
    .loader-word { font-size: 1.5rem; font-weight: 800; color: #0f172a; letter-spacing: -.01em; }
    .loader-accent { background: linear-gradient(90deg,#ff8184,#54a2e5); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .loader-bar { width: 160px; height: 4px; border-radius: 9999px; background: #eef2f7; overflow: hidden; }
    .loader-bar-fill { display: block; width: 40%; height: 100%; border-radius: 9999px; background: linear-gradient(90deg,#ff8184,#54a2e5); animation: loaderSlide 1s ease-in-out infinite; }
    @keyframes loaderSlide { 0% { transform: translateX(-120%); } 100% { transform: translateX(320%); } }
    @media (prefers-reduced-motion: reduce) { .loader-bar-fill { animation: none; width: 100%; } }
  </style>

  <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/85 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">
      <a href={`${base}/`} class="flex items-center gap-2.5 group">
        <svg class="w-8 h-8 shrink-0 transition group-hover:scale-105" viewBox="0 0 64 64" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="logoGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#ff8184"/><stop offset="1" stop-color="#54a2e5"/>
            </linearGradient>
          </defs>
          <rect width="64" height="64" rx="16" fill="url(#logoGrad)"/>
          <g fill="#fff">
            <ellipse cx="26" cy="43" rx="10" ry="8" transform="rotate(-16 26 43)"/>
            <rect x="34" y="18" width="3.6" height="25" rx="1.8"/>
            <path d="M37.6 18 C45.5 19 49.5 24 46.2 30.5 C47 25 43 21.8 37.6 22.8 Z"/>
          </g>
        </svg>
        <span class="flex items-baseline gap-2">
          <span class="font-display text-xl font-extrabold tracking-tight text-ink">
            うみゃみー<span class="bg-gradient-to-r from-[#ff8184] to-[#54a2e5] bg-clip-text text-transparent">Music</span>
          </span>
          <span class="hidden sm:inline text-[11px] font-medium text-slate-400">
            <span class="text-madoka">水面まどか</span> ・ <span class="text-ayane">白砂あやね</span>
          </span>
        </span>
      </a>

      <div class="flex items-center gap-1">
        <button id="historyBtn" type="button" aria-label="再生履歴"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 2m6-2a9 9 0 11-3.5-7.1M21 3v4h-4"/></svg>
          <span class="hidden sm:inline">履歴</span>
        </button>
        <button id="aboutBtn" type="button" aria-label="このサイトについて"
                class="ml-1 inline-flex items-center justify-center w-9 h-9 rounded-full text-slate-500 hover:text-ink hover:bg-slate-100 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
            <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 11v5"/><circle cx="12" cy="7.8" r=".6" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <slot />

  <!-- About modal -->
  <div id="aboutModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="aboutBackdrop" class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg card p-6 sm:p-7 max-h-[85vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="aboutTitle">
      <button id="aboutClose" type="button" aria-label="閉じる"
              class="absolute top-4 right-4 w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:text-ink hover:bg-slate-100 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <h2 id="aboutTitle" class="font-display text-lg font-extrabold text-ink">うみゃみーMusic について</h2>
      <p class="text-sm text-slate-600 mt-2 leading-relaxed">
        にじさんじ所属「うみゃみー」（<span class="font-semibold text-madoka">水面まどか</span>・<span class="font-semibold text-ayane">白砂あやね</span>）の歌枠・歌ってみたを、タイムスタンプ付きでまとめた有志による非公式サイトです。
      </p>

      <div class="mt-4 rounded-xl bg-slate-50 border border-slate-200 p-4 text-xs text-slate-500 leading-relaxed">
        本サイトは非公式です。ANYCOLOR株式会社およびにじさんじ公式とは一切関係ありません。掲載情報の正確性は保証しません。動画本体はホストせず、YouTube への埋め込み・リンクのみを掲載しています。問題がある場合はお問い合わせください。
      </div>

      <div class="mt-5">
        <p class="text-xs font-semibold text-slate-400 mb-2">公式チャンネル</p>
        <div class="flex flex-col sm:flex-row gap-2">
          <a href="https://www.youtube.com/@MinamoMadoka" target="_blank" rel="noopener noreferrer"
             class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white"
             style="background:#ff8184">水面まどか ▸ YouTube</a>
          <a href="https://www.youtube.com/@ShirasaAyane" target="_blank" rel="noopener noreferrer"
             class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white"
             style="background:#54a2e5">白砂あやね ▸ YouTube</a>
        </div>
      </div>

      <p class="mt-5 text-[11px] text-slate-400 text-center">© 2026 ファン有志 / 非公式</p>
    </div>
  </div>

  <script>
    // ロード画面: 読み込み完了でフェードアウト（保険で最大4秒）
    const loader = document.getElementById('siteLoader');
    const hideLoader = () => loader?.classList.add('is-hidden');
    if (document.readyState === 'complete') hideLoader();
    else window.addEventListener('load', hideLoader);
    setTimeout(hideLoader, 4000);

    const modal = document.getElementById('aboutModal');
    const open = () => modal?.classList.remove('hidden');
    const close = () => modal?.classList.add('hidden');
    document.getElementById('aboutBtn')?.addEventListener('click', open);
    document.getElementById('aboutClose')?.addEventListener('click', close);
    document.getElementById('aboutBackdrop')?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  </script>
</body>
</html>

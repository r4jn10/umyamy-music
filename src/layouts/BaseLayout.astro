---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "うみゃみーMusic",
  description = "水面まどかさん・白砂あやねさんの歌枠・歌ってみたをまとめた非公式まとめサイトです。"
} = Astro.props;

// GitHub Pages で公開されたときに、base パスが自動で考慮されるようにします。
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const siteOrigin = Astro.site ?? new URL("https://umyamy-music.com");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL(`${base}/og-image.png`, siteOrigin);

// 外部サービスのID（取得後にここへ設定。空のうちは読み込まれません）
const GA_ID = "G-RM01JXF3VN";  // Google アナリティクス4 測定ID
const GSC_VERIFY = "";   // Search Console 確認用メタ（DNS確認なら不要）

// サイトを検索結果から隠す（noindex）。告知直前に false に戻して再インデックス。
// robots.txt はクロール許可のまま（noindex を Googlebot に読ませるため）。
const NOINDEX = true;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="icon" href={`${base}/favicon.ico`} />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
  <link rel="manifest" href={`${base}/site.webmanifest`} />
  <meta name="theme-color" content="#ff8184" />
  <meta name="generator" content={Astro.generator} />

  <link rel="canonical" href={canonicalURL} />
  {NOINDEX && <meta name="robots" content="noindex, nofollow" />}
  {GSC_VERIFY && <meta name="google-site-verification" content={GSC_VERIFY} />}

  <!-- OGP / Twitter Card（SNS共有時の見え方） -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="うみゃみーMusic" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">

  {GA_ID && (
    <Fragment>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </Fragment>
  )}
</head>
<body class="min-h-screen flex flex-col">

  <!-- ロード画面（読み込み完了でフェードアウト） -->
  <div id="siteLoader" class="site-loader" aria-hidden="true">
    <div class="loader-inner">
      <div class="loader-lockup">
        <img src={`${base}/logo.svg`} alt="うみゃみーMusic" class="loader-logo" />
      </div>
      <span class="loader-bar"><span class="loader-bar-fill"></span></span>
    </div>
  </div>

  <style>
    .site-loader {
      position: fixed; inset: 0; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      background: #ffffff; transition: opacity .4s ease, visibility .4s ease;
    }
    .site-loader.is-hidden { opacity: 0; visibility: hidden; }
    .loader-inner { display: flex; flex-direction: column; align-items: center; gap: 18px; }
    .loader-lockup { display: flex; align-items: center; gap: 12px; }
    .loader-logo { height: 44px; width: auto; filter: drop-shadow(0 4px 14px rgba(255,129,132,.18)); }
    .loader-bar { width: 160px; height: 4px; border-radius: 9999px; background: #eef2f7; overflow: hidden; }
    .loader-bar-fill { display: block; width: 40%; height: 100%; border-radius: 9999px; background: linear-gradient(90deg,#ff8184,#54a2e5); animation: loaderSlide 1s ease-in-out infinite; }
    @keyframes loaderSlide { 0% { transform: translateX(-120%); } 100% { transform: translateX(320%); } }
    @media (prefers-reduced-motion: reduce) { .loader-bar-fill { animation: none; width: 100%; } }
    /* 日本語の不自然な改行を抑制（句読点・小書き仮名・閉じ括弧の行頭を避け、文節で折り返す） */
    .jp-text { word-break: auto-phrase; line-break: strict; }
  </style>

  <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/85 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">
      <a href={`${base}/`} class="flex items-center group">
        <img src={`${base}/logo.svg`} alt="うみゃみーMusic" class="h-8 w-auto transition group-hover:scale-[1.02]" />
      </a>

      <div class="flex items-center gap-1">
        <button id="historyBtn" type="button" aria-label="再生履歴"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
          <span class="hidden sm:inline">履歴</span>
        </button>
        <button type="button" data-open="members" aria-label="うみゃみーについて"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="hidden sm:inline">うみゃみーについて</span>
        </button>
        <button type="button" data-open="about" aria-label="このサイトについて"
                class="ml-1 inline-flex items-center justify-center w-9 h-9 rounded-full text-slate-500 hover:text-ink hover:bg-slate-100 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
            <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 11v5"/><circle cx="12" cy="7.8" r=".6" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <slot />

  <!-- うみゃみーについて（メンバー紹介）modal -->
  <div id="membersModal" class="modal-root hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" data-close></div>
    <div class="jp-text relative w-full max-w-lg card p-6 sm:p-7 max-h-[85vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="membersTitle">
      <button type="button" aria-label="閉じる" data-close
              class="absolute top-4 right-4 w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:text-ink hover:bg-slate-100 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <h2 id="membersTitle" class="font-display text-lg font-extrabold text-ink">うみゃみーについて</h2>
      <p class="text-sm text-slate-600 mt-2 leading-relaxed">
        「<span class="font-semibold text-ink">うみゃみー</span>」は、ANYCOLOR株式会社が運営するバーチャルライバーグループ「にじさんじ」より、2026年1月29日にデビューした、<span class="font-semibold text-madoka whitespace-nowrap">水面まどかさん</span>・<span class="font-semibold text-ayane whitespace-nowrap">白砂あやねさん</span>の女子高生の親友コンビによる同期ユニット。
      </p>

      <!-- 水面まどか -->
      <div class="mt-5 rounded-xl border border-slate-200 overflow-hidden">
        <div class="h-1.5" style="background:#ff8184"></div>
        <div class="p-4">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-bold text-ink">水面まどか <span class="text-xs font-medium text-slate-400">みなも まどか</span></h3>
            <div class="flex gap-2 shrink-0">
              <a href="https://www.youtube.com/@MinamoMadoka" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-madoka hover:underline">YouTube</a>
              <a href="https://x.com/Madoka_Minamo" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-madoka hover:underline">X</a>
            </div>
          </div>
          <blockquote class="mt-2 text-sm text-slate-600 leading-relaxed border-l-2 border-[#ff8184] pl-3">
            「流行りの服とメイクでキメてるけど、実は創作にかける情熱は誰にも負けないギャル。ファッションもメイクも、日常で目にするもの全部をイラストや表現のネタにしちゃう。いつか自分の作品をアニメにして、みんなに届けるのが夢。」
          </blockquote>
        </div>
      </div>

      <!-- 白砂あやね -->
      <div class="mt-4 rounded-xl border border-slate-200 overflow-hidden">
        <div class="h-1.5" style="background:#54a2e5"></div>
        <div class="p-4">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-bold text-ink">白砂あやね <span class="text-xs font-medium text-slate-400">しらさ あやね</span></h3>
            <div class="flex gap-2 shrink-0">
              <a href="https://www.youtube.com/@ShirasaAyane" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-ayane hover:underline">YouTube</a>
              <a href="https://x.com/shirasa_ayane" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-ayane hover:underline">X</a>
            </div>
          </div>
          <blockquote class="mt-2 text-sm text-slate-600 leading-relaxed border-l-2 border-[#54a2e5] pl-3">
            「いつも真面目で、授業も部活も完璧にこなす優等生。しかし実は、いつもノートの端には物語のワンシーンやキャラクターのスケッチが描かれている。いつか自分の声や描いた物語で、たくさんの人を楽しませたいと思っている。」
          </blockquote>
        </div>
      </div>

      <p class="mt-4 text-[11px] text-slate-400 leading-relaxed">
        プロフィール文は
        <a href="https://www.nijisanji.jp/news/1n2owk3cufgm" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-600">にじさんじ公式</a>
        より引用。各種情報の参照元：
        <a href="https://wikiwiki.jp/nijisanji/%E6%B0%B4%E9%9D%A2%E3%81%BE%E3%81%A9%E3%81%8B" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-600">にじさんじ非公式Wiki（水面まどか）</a>・<a href="https://wikiwiki.jp/nijisanji/%E7%99%BD%E7%A0%82%E3%81%82%E3%82%84%E3%81%AD" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-600">同（白砂あやね）</a>。
      </p>
    </div>
  </div>

  <!-- このサイトについて（ABOUT）modal -->
  <div id="aboutModal" class="modal-root hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" data-close></div>
    <div class="jp-text relative w-full max-w-lg card p-6 sm:p-7 max-h-[85vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="aboutTitle">
      <button type="button" aria-label="閉じる" data-close
              class="absolute top-4 right-4 w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:text-ink hover:bg-slate-100 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <h2 id="aboutTitle" class="font-display text-lg font-extrabold text-ink">このサイトについて</h2>
      <p class="text-sm text-slate-600 mt-2 leading-relaxed">
        「うみゃみーMusic」は、にじさんじ所属「うみゃみー」（<span class="font-semibold text-madoka whitespace-nowrap">水面まどかさん</span>・<span class="font-semibold text-ayane whitespace-nowrap">白砂あやねさん</span>）の応援を目的とした非公式ファンサイトです。
      </p>

      <div class="mt-4 rounded-xl bg-slate-50 border border-slate-200 p-4">
        <p class="text-xs font-semibold text-slate-400 mb-2">注意書き</p>
        <ul class="text-xs text-slate-500 leading-relaxed space-y-1.5 list-disc pl-4">
          <li>本サイトは非公式です。ANYCOLOR株式会社およびにじさんじ公式とは一切関係ありません。</li>
          <li>動画・楽曲などの権利は、ご本人および各権利者に帰属します。本サイトは動画をホストせず、YouTube 公式動画の埋め込み・リンクのみを掲載しています（再アップロード・転載はしていません）。</li>
          <li>非営利・個人運営であり、収益化は行っていません。</li>
          <li>掲載情報（曲名・タイムスタンプ等）は有志の手作業によるもので、正確性は保証できません。誤りのご報告は歓迎します。</li>
          <li>ご本人・関係者の方からのご要望があれば、速やかに修正・削除いたします。</li>
        </ul>
      </div>

      <div class="mt-4 rounded-xl bg-slate-50 border border-slate-200 p-4 text-xs text-slate-500 leading-relaxed">
        <p class="font-semibold text-slate-400 mb-1">情報の参照元</p>
        セットリスト等は、各動画の概要欄・固定コメント、および
        <a href="https://wikiwiki.jp/nijisanji/" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-600">にじさんじ非公式Wiki</a>
        を参照しています。リスナーの皆様、非公式Wiki様、いつもありがとうございます。
      </div>

      <div class="mt-4 rounded-xl bg-slate-50 border border-slate-200 p-4 text-xs text-slate-500 leading-relaxed">
        <p class="font-semibold text-slate-400 mb-1">アクセス解析について</p>
        本サイトでは品質改善のため Google アナリティクス（GA4）を利用し、Cookie によってアクセス状況を匿名で収集します。氏名など、あなたを直接特定する情報は取得しません。ブラウザの設定で Cookie を無効化することで収集を拒否できます。詳しくは
        <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-600">Google のポリシーとプライバシー</a>
        をご覧ください。
      </div>

      <div class="mt-4 rounded-xl border border-slate-200 p-4">
        <p class="text-xs font-semibold text-slate-400 mb-1">お問い合わせ</p>
        <p class="text-sm text-slate-600 leading-relaxed">
          ご指摘・削除依頼・お問い合わせは下記までご連絡ください。
        </p>
        <a href="https://x.com/teleprompter0" target="_blank" rel="noopener noreferrer"
           class="mt-2 inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-white bg-slate-900 hover:bg-slate-800 transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          @teleprompter0 ▸ X
        </a>
      </div>

      <div class="mt-4">
        <p class="text-xs font-semibold text-slate-400 mb-2">公式チャンネル</p>
        <div class="flex flex-col sm:flex-row gap-2">
          <a href="https://www.youtube.com/@MinamoMadoka" target="_blank" rel="noopener noreferrer"
             class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white"
             style="background:#ff8184">水面まどかさん ▸ YouTube</a>
          <a href="https://www.youtube.com/@ShirasaAyane" target="_blank" rel="noopener noreferrer"
             class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white"
             style="background:#54a2e5">白砂あやねさん ▸ YouTube</a>
        </div>
      </div>

      <p class="mt-5 text-[11px] text-slate-400 text-center">© 2026 navi</p>
    </div>
  </div>

  <script>
    // ロード画面: 読み込み完了でフェードアウト（保険で最大4秒）
    const loader = document.getElementById('siteLoader');
    const hideLoader = () => loader?.classList.add('is-hidden');
    if (document.readyState === 'complete') hideLoader();
    else window.addEventListener('load', hideLoader);
    setTimeout(hideLoader, 4000);

    // モーダル開閉（うみゃみーについて / このサイトについて）。
    // [data-open="about|members"] で開き、[data-close] と Esc で閉じる。
    const aboutModal = document.getElementById('aboutModal');
    const membersModal = document.getElementById('membersModal');
    const openModal = (el: HTMLElement | null) => el?.classList.remove('hidden');
    const closeAll = () => { aboutModal?.classList.add('hidden'); membersModal?.classList.add('hidden'); };
    document.querySelectorAll('[data-open]').forEach(btn =>
      btn.addEventListener('click', () => {
        const which = btn.getAttribute('data-open');
        openModal(which === 'members' ? membersModal : aboutModal);
      }));
    document.querySelectorAll('[data-close]').forEach(el =>
      el.addEventListener('click', () => el.closest('.modal-root')?.classList.add('hidden')));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });
  </script>
</body>
</html>

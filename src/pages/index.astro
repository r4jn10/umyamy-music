<script>
  import Fuse from 'fuse.js';

  let filterMember = 'all';
  let filterCategory = 'all';
  let searchText = '';
  let filterArtist: string | null = null;
  let filterFav = false;
  let viewMode: 'songs' | 'streams' | 'artists' = 'songs';

  // ===== お気に入り（localStorage 永続化） =====
  const FAV_KEY = 'umyamy:favorites';
  let favSet: Set<string> = new Set();
  try { favSet = new Set(JSON.parse(localStorage.getItem(FAV_KEY) || '[]')); } catch (_) {}
  function saveFav(): boolean {
    try { localStorage.setItem(FAV_KEY, JSON.stringify([...favSet])); return true; } catch (_) { return false; }
  }
  function toggleFav(id: string) {
    if (favSet.has(id)) favSet.delete(id); else favSet.add(id);
    saveFav();
    refreshFavUI();
    // 追加されたときは★をポップさせる（トグル時のみ。再描画では動かさない）
    if (favSet.has(id)) {
      const targets = [...document.querySelectorAll(`.card-fav[data-id="${CSS.escape(id)}"] svg`)];
      if (nowPlaying && nowPlaying.id === id) {
        const sf = document.querySelector('#sheetFav svg');
        if (sf) targets.push(sf);
      }
      targets.forEach(el => {
        el.classList.remove('fav-pop');
        void (el as SVGElement).getBoundingClientRect();
        el.classList.add('fav-pop');
        el.addEventListener('animationend', () => el.classList.remove('fav-pop'), { once: true });
      });
    }
    // お気に入り絞り込み中なら、外れた曲を一覧から消す
    if (filterFav) { shownCount = PAGE_SIZE; refresh(); }
  }
  // カード・シートの星の状態を現在の favSet に同期
  function refreshFavUI() {
    document.querySelectorAll('.card-fav').forEach(btn => {
      const on = favSet.has(btn.getAttribute('data-id') || '');
      btn.classList.toggle('is-fav', on);
      btn.setAttribute('aria-pressed', String(on));
    });
    const sf = document.getElementById('sheetFav');
    if (sf) {
      const on = !!nowPlaying && favSet.has(nowPlaying.id);
      sf.setAttribute('aria-pressed', String(on));
    }
  }

  // ===== お気に入りの書き出し／取り込み（端末間の移行・バックアップ用） =====
  // お気に入り絞り込み中（曲ビュー）のときだけツールバーを出す
  function updateFavToolbar() {
    document.getElementById('favToolbar')?.classList.toggle('hidden', !(filterFav && viewMode === 'songs'));
  }
  function setFavIoMsg(text: string, isErr = false) {
    const el = document.getElementById('favIoMsg');
    if (!el) return;
    el.textContent = text;
    el.classList.toggle('text-rose-500', isErr);
    el.classList.toggle('text-slate-400', !isErr);
  }
  function exportFavorites() {
    const ids = [...favSet];
    const payload = { app: 'umyamy-music', type: 'favorites', version: 1, exportedAt: new Date().toISOString(), ids };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const d = new Date();
    const ymd = `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
    const a = document.createElement('a');
    a.href = url; a.download = `umyamy-favorites-${ymd}.json`;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
    setFavIoMsg(ids.length ? `${ids.length}件を書き出しました` : 'お気に入りは空です');
  }
  // 取り込みは「既存に追加（マージ）」。現在の曲データに存在するIDのみ採用
  function importFavorites(file: File) {
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const data = JSON.parse(String(reader.result));
        const incoming = Array.isArray(data) ? data : (data && Array.isArray(data.ids) ? data.ids : null);
        if (!incoming) { setFavIoMsg('ファイル形式が正しくありません', true); return; }
        const known = new Set(songs.map((s: any) => s.id));
        const snapshot = new Set(favSet);
        let added = 0, skipped = 0;
        for (const id of incoming) {
          if (typeof id !== 'string' || !known.has(id)) { skipped++; continue; }
          if (favSet.has(id)) continue;
          favSet.add(id); added++;
        }
        if (!saveFav()) { favSet = snapshot; setFavIoMsg('保存に失敗しました。ブラウザの保存容量を確認してください', true); return; }
        refreshFavUI();
        shownCount = PAGE_SIZE;
        refresh();
        setFavIoMsg(`${added}件を追加${skipped ? `（対象外 ${skipped}件）` : ''}`);
      } catch (_) {
        setFavIoMsg('読み込みに失敗しました', true);
      }
    };
    reader.readAsText(file);
  }

  const songsDataEl = document.getElementById('songs-data');
  const songs = songsDataEl ? JSON.parse(songsDataEl.getAttribute('data-songs') || '[]') : [];

  // 表示順は JSON の並びに依存させず「配信日 → 同日内は配信（動画）ごと → タイムスタンプ」で揃える。
  // 同日に複数配信がある場合は曲が混ざらないよう、動画単位でまとめる（同日内の動画同士は JSON の登場順を維持）。
  {
    const videoOrder = new Map<string, number>();
    songs.forEach((s: any, i: number) => {
      const vid = s.youtube?.videoId || '';
      if (!videoOrder.has(vid)) videoOrder.set(vid, i);
    });
    songs.sort((a: any, b: any) =>
      (a.streamDate || '').localeCompare(b.streamDate || '') ||
      (videoOrder.get(a.youtube?.videoId || '') || 0) - (videoOrder.get(b.youtube?.videoId || '') || 0) ||
      (a.youtube?.timestampSec || 0) - (b.youtube?.timestampSec || 0));
  }

  // 新着順の並び（配信が新しい順、配信内はタイムスタンプ順のまま配信単位で逆順にする）
  const songsDesc = (() => {
    const videoRank = new Map<string, number>();
    songs.forEach((s: any) => {
      const vid = s.youtube?.videoId || '';
      if (!videoRank.has(vid)) videoRank.set(vid, videoRank.size);
    });
    return [...songs].sort((a: any, b: any) =>
      (videoRank.get(b.youtube?.videoId || '') || 0) - (videoRank.get(a.youtube?.videoId || '') || 0) ||
      (a.youtube?.timestampSec || 0) - (b.youtube?.timestampSec || 0));
  })();

  const fuse = new Fuse(songs, { keys: ['title', 'artist', 'tags'], threshold: 0.3 });

  // ===== プレイリスト（自作・並べ替え・共有） =====
  const PL_KEY = 'umyamy:playlists';
  let playlists: any[] = [];
  try { const v = JSON.parse(localStorage.getItem(PL_KEY) || '[]'); if (Array.isArray(v)) playlists = v; } catch (_) {}
  function savePlaylists(): boolean {
    try { localStorage.setItem(PL_KEY, JSON.stringify(playlists)); return true; } catch (_) { return false; }
  }
  const plUid = () => Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
  const plFind = (id: string | null) => playlists.find(p => p.id === id);
  const songById = (id: string) => songs.find((s: any) => s.id === id);
  const plResolveSongs = (pl: any) => pl.ids.map(songById).filter(Boolean);

  let plCurrentId: string | null = null;    // 詳細画面で開いているプレイリスト
  let plAddTargetId: string | null = null;  // 「プレイリストに追加」モーダルの対象曲
  let plShared: { name: string; ids: string[] } | null = null; // URLで受け取った共有プレイリスト

  function createPlaylist(name: string): any {
    const pl = { id: plUid(), name: (name || '').trim() || '新しいプレイリスト', ids: [] as string[], updatedAt: Date.now() };
    playlists.unshift(pl);
    savePlaylists();
    return pl;
  }

  // --- モーダル開閉（一覧 ⇄ 詳細） ---
  const show = (id: string) => document.getElementById(id)?.classList.remove('hidden');
  const hide = (id: string) => document.getElementById(id)?.classList.add('hidden');
  function openPlModal() { showPlList(); show('plModal'); }
  function closePlModal() { hide('plModal'); }
  function showPlList() {
    plCurrentId = null;
    document.getElementById('plListView')?.classList.remove('hidden');
    const d = document.getElementById('plDetailView');
    d?.classList.add('hidden'); d?.classList.remove('flex');
    const b = document.getElementById('plBack');
    b?.classList.add('hidden'); b?.classList.remove('inline-flex');
    renderPlList();
  }
  function showPlDetail(id: string) {
    plCurrentId = id;
    document.getElementById('plListView')?.classList.add('hidden');
    const d = document.getElementById('plDetailView');
    d?.classList.remove('hidden'); d?.classList.add('flex');
    const b = document.getElementById('plBack');
    b?.classList.remove('hidden'); b?.classList.add('inline-flex');
    setPlMsg('');
    renderPlDetail();
  }
  function setPlMsg(text: string, isErr = false) {
    const el = document.getElementById('plMsg');
    if (!el) return;
    el.textContent = text;
    (el as HTMLElement).style.color = isErr ? '#e11d48' : '';
  }

  // ===== プレイリストの書き出し／取り込み（端末間の移行・バックアップ用） =====
  function setPlIoMsg(text: string, isErr = false) {
    const el = document.getElementById('plIoMsg');
    if (!el) return;
    el.textContent = text;
    el.classList.toggle('text-rose-500', isErr);
    el.classList.toggle('text-slate-400', !isErr);
  }
  function exportPlaylists() {
    const payload = {
      app: 'umyamy-music', type: 'playlists', version: 1, exportedAt: new Date().toISOString(),
      playlists: playlists.map(pl => ({ name: pl.name, ids: pl.ids })),
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const d = new Date();
    const ymd = `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
    const a = document.createElement('a');
    a.href = url; a.download = `umyamy-playlists-${ymd}.json`;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
    setPlIoMsg(playlists.length ? `${playlists.length}件を書き出しました` : 'プレイリストは空です');
  }
  // 同名プレイリストがある場合は上書きせず「名前 (2)」のように連番を付けて別名にする
  function uniquePlName(name: string): string {
    const base = name || '取り込んだプレイリスト';
    const existing = new Set(playlists.map(p => p.name));
    if (!existing.has(base)) return base;
    let i = 2;
    while (existing.has(`${base} (${i})`)) i++;
    return `${base} (${i})`;
  }
  // 取り込みは「新規追加」（既存プレイリストは上書きしない）。曲IDは現行の songs.json に無くても保持する
  function importPlaylists(file: File) {
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const data = JSON.parse(String(reader.result));
        const incoming = Array.isArray(data) ? data : (data && Array.isArray(data.playlists) ? data.playlists : null);
        if (!incoming) { setPlIoMsg('ファイル形式が正しくありません', true); return; }
        const snapshot = [...playlists];
        let added = 0, skipped = 0;
        for (const item of incoming) {
          if (!item || typeof item !== 'object' || !Array.isArray(item.ids)) { skipped++; continue; }
          const ids = item.ids.filter((id: any) => typeof id === 'string');
          const name = uniquePlName(typeof item.name === 'string' ? item.name.trim().slice(0, 40) : '');
          playlists.push({ id: plUid(), name, ids, updatedAt: Date.now() });
          added++;
        }
        if (!savePlaylists()) { playlists = snapshot; setPlIoMsg('保存に失敗しました。ブラウザの保存容量を確認してください', true); return; }
        renderPlList();
        if (added) setPlIoMsg(`${added}件を取り込みました${skipped ? `（対象外 ${skipped}件）` : ''}`);
        else setPlIoMsg('取り込めるプレイリストがありませんでした', true);
      } catch (_) {
        setPlIoMsg('読み込みに失敗しました', true);
      }
    };
    reader.readAsText(file);
  }

  // --- 描画 ---
  function plRowThumb(pl: any): string {
    const first = plResolveSongs(pl)[0];
    return first
      ? `<img src="https://img.youtube.com/vi/${encodeURIComponent(first.youtube.videoId)}/default.jpg" alt="" loading="lazy" class="w-12 h-12 rounded-lg object-cover bg-slate-100 shrink-0">`
      : `<span class="w-12 h-12 rounded-lg shrink-0 inline-flex items-center justify-center text-white" style="background:linear-gradient(135deg,#ff8184,#54a2e5)">

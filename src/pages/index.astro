  // --- 再生 ---
  function playPlaylist(pl: any, startIdx = 0, doShuffle = false) {
    const list = plResolveSongs(pl);
    if (!list.length) { setPlMsg('再生できる曲がありません', true); return; }
    if (doShuffle) {
      for (let i = list.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [list[i], list[j]] = [list[j], list[i]];
      }
      startIdx = 0;
    }
    queue = list;
    qIndex = Math.max(0, Math.min(list.length - 1, startIdx));
    current(queue[qIndex]);
    closePlModal();
  }

  // --- 共有リンクの短縮エンコード（?p=） ---
  // idをそのまま並べると1曲19〜25文字になるため、id構造を利用して圧縮する。
  // トークン列: M|A|B = 旧形式id（メンバー＋日付）、V = videoId形式id。
  //   M|A|B + 日数3桁(base36, 2026-01-01起点) + 連番2桁(base36)…
  //   V + videoId(11文字固定) + 連番2桁(base36)…
  // 同じ日付メンバー／同じ動画が連続する間は連番(2文字)だけを並べる。
  // マーカーは大文字MABV・連番は小文字base36なので区切り文字は不要。
  const PL_EPOCH_UTC = Date.UTC(2026, 0, 1);
  const OLD_ID_RE = /^(\d{4})(\d{2})(\d{2})-(both|madoka|ayane)-(\d{3})$/;
  const VID_ID_RE = /^\d{8}-([\w-]{11})-(\d{3})$/;
  const MEMBER_MARK: Record<string, string> = { both: 'B', madoka: 'M', ayane: 'A' };
  const MARK_MEMBER: Record<string, string> = { B: 'both', M: 'madoka', A: 'ayane' };
  const b36 = (n: number, w: number) => n.toString(36).padStart(w, '0');

  // 全idを短縮コード化。1つでも未知の形式があれば null（旧形式 songs= にフォールバック）
  function encodeShareIds(ids: string[]): string | null {
    let out = '', prevKey = '';
    for (const id of ids) {
      const m = OLD_ID_RE.exec(id);
      if (m) {
        const days = Math.round((Date.UTC(+m[1], +m[2] - 1, +m[3]) - PL_EPOCH_UTC) / 86400000);
        const num = +m[5];
        if (days < 0 || days >= 36 ** 3 || num >= 36 ** 2) return null;
        const key = MEMBER_MARK[m[4]] + b36(days, 3);
        out += (key === prevKey ? '' : key) + b36(num, 2);
        prevKey = key;
        continue;
      }
      const v = VID_ID_RE.exec(id);
      if (v) {
        const num = +v[2];
        if (num >= 36 ** 2) return null;
        const key = 'V' + v[1];
        out += (key === prevKey ? '' : key) + b36(num, 2);
        prevKey = key;
        continue;
      }
      return null;
    }
    return out;
  }

  // 短縮コード → id配列。videoId形式は日付をidから復元できないため曲データから逆引きする
  function decodeShareIds(code: string): string[] {
    const ids: string[] = [];
    let i = 0, mode: string | null = null, days = 0, videoId = '';
    while (i < code.length && ids.length < 500) {
      const c = code[i];
      if (c === 'M' || c === 'A' || c === 'B') {
        days = parseInt(code.slice(i + 1, i + 4), 36);
        if (isNaN(days)) break;
        mode = c; i += 4;
      } else if (c === 'V') {
        videoId = code.slice(i + 1, i + 12);
        if (videoId.length < 11) break;
        mode = 'V'; i += 12;
      } else if (mode && /^[0-9a-z]{2}$/.test(code.slice(i, i + 2))) {
        const n3 = String(parseInt(code.slice(i, i + 2), 36)).padStart(3, '0');
        if (mode === 'V') {
          const song = songs.find((s: any) => s.id.endsWith(`-${videoId}-${n3}`));
          ids.push(song ? song.id : `unknown-${videoId}-${n3}`);
        } else {
          const d = new Date(PL_EPOCH_UTC + days * 86400000);
          const ymd = `${d.getUTCFullYear()}${String(d.getUTCMonth() + 1).padStart(2, '0')}${String(d.getUTCDate()).padStart(2, '0')}`;
          ids.push(`${ymd}-${MARK_MEMBER[mode]}-${n3}`);
        }
        i += 2;
      } else break; // 壊れたコード。読めたところまで使う
    }
    return ids;
  }

  // --- 共有（URLに短縮コードを載せる。受け取り側はデータに存在する曲だけ復元） ---
  function playlistShareUrl(name: string, ids: string[]): string {
    const valid = ids.filter(id => songById(id));
    const code = encodeShareIds(valid);
    const q = code !== null ? `p=${code}` : `songs=${valid.join('.')}`;
    return `${location.origin}${location.pathname}?pl=${encodeURIComponent(name)}&${q}`;
  }
  async function copyText(text: string): Promise<boolean> {
    try { await navigator.clipboard.writeText(text); return true; } catch (_) {}
    try {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      const ok = document.execCommand('copy');
      ta.remove();
      return ok;
    } catch (_) { return false; }
  }


  /* ミニバー操作行：主操作（前へ・再生・次へ）と補助操作（リピート・シャッフル・音量）の区切り */
  .ctl-divider { width: 1px; height: 22px; background: #e2e8f0; margin: 0 .25rem; flex: none; }
  /* 音量スライダーはミュートボタンのhover/フォーカス中だけ広がる */
  .vol-group .volume-slider { width: 0; opacity: 0; pointer-events: none; transition: width .2s ease, opacity .2s ease; }
  .vol-group:hover .volume-slider,
  .vol-group:focus-within .volume-slider { width: 5rem; opacity: 1; pointer-events: auto; margin-right: .25rem; }
  @media (prefers-reduced-motion: reduce) {

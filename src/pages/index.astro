  /* 「今日の一曲」バッジ（display は .hidden に勝たないよう :not(.hidden) のときだけ指定） */
  #qTodayBadge:not(.hidden) { display: inline-flex; align-items: center; }
  /* 選択肢の回答状態（ボタンは JS 描画のため :global） */

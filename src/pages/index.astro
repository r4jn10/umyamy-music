---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import songsData from '../../public/data/songs.json';

const { songs } = songsData;
const totalSongs = songs.length;
const utaWakuCount = songs.filter(s => s.category === 'uta_waku').length;
const coverCount = songs.filter(s => s.category === 'cover').length;
const shortCount = songs.filter(s => s.category === 'short').length;
const lastUpdated = songsData.updatedAt;
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-4 w-full">

    <!-- Stats -->
    <div class="py-6">
      <div class="flex flex-wrap items-center gap-x-4 sm:gap-x-8 gap-y-1 text-sm">
        <div class="flex items-baseline gap-1 sm:gap-1.5">
          <span class="font-display text-lg sm:text-2xl font-extrabold text-ink tabular-nums">{totalSongs}</span>
          <span class="text-slate-400 text-[11px] sm:text-xs font-medium">曲</span>
        </div>
        <div class="flex items-baseline gap-1 sm:gap-1.5">
          <span class="font-display text-sm sm:text-lg font-bold text-ayane tabular-nums">{utaWakuCount}</span>
          <span class="text-slate-400 text-[11px] sm:text-xs font-medium">歌枠</span>
        </div>
        <div class="flex items-baseline gap-1 sm:gap-1.5">
          <span class="font-display text-sm sm:text-lg font-bold text-madoka tabular-nums">{coverCount}</span>
          <span class="text-slate-400 text-[11px] sm:text-xs font-medium">歌ってみた</span>
        </div>
        {shortCount > 0 && (
          <div class="flex items-baseline gap-1 sm:gap-1.5">
            <span class="font-display text-sm sm:text-lg font-bold text-slate-600 tabular-nums">{shortCount}</span>
            <span class="text-slate-400 text-[11px] sm:text-xs font-medium">ショート</span>
          </div>
        )}
        <span class="hidden sm:inline ml-auto text-[11px] text-slate-400">最終更新 <span class="font-semibold text-slate-500">{lastUpdated}</span></span>
      </div>
      <div class="sm:hidden mt-1 text-right text-[10px] text-slate-400">最終更新 <span class="font-semibold text-slate-500">{lastUpdated}</span></div>
    </div>

    <main id="songs" class="pb-16">

      <!-- New videos slider -->
      <section id="newSection" class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="section-label font-display text-sm font-bold text-slate-500 tracking-wide">新着</h2>
          <div class="flex items-center gap-1">
            <button id="newPrev" type="button" aria-label="前へ"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 disabled:opacity-30 disabled:hover:bg-transparent transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="newNext" type="button" aria-label="次へ"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 disabled:opacity-30 disabled:hover:bg-transparent transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
        <div id="newSlider" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 -mx-1 px-1 new-slider"></div>
      </section>

      <!-- Search & Filter -->
      <div class="card p-5 mb-8" id="searchArea">
        <div class="flex items-center gap-1.5 mb-4">
          <button id="view-songs" class="chip" aria-pressed="true">🎵 曲</button>
          <button id="view-streams" class="chip" aria-pressed="false">📺 配信</button>
          <button id="view-artists" class="chip" aria-pressed="false">🎤 アーティスト</button>
          <select id="streamSort" class="hidden ml-auto text-xs border border-slate-200 rounded-lg px-2 py-1.5 bg-white text-slate-500">
            <option value="date_desc">新着順</option>
            <option value="date_asc">古い順</option>
          </select>
        </div>
        <div class="relative mb-4">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3m1.8-4.7a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" id="searchInput" placeholder="曲名・アーティスト・タグで検索"
                 class="w-full pl-10 pr-10 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:outline-none focus:border-slate-400 focus:bg-white transition">
          <button id="clearSearch" type="button" aria-label="クリア"
                  class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="flex flex-col gap-3">
          <div class="flex flex-col gap-1.5 sm:flex-row sm:flex-wrap sm:items-center sm:gap-2">
            <span class="text-[11px] text-slate-400 font-semibold sm:mr-1">メンバー</span>
            <div class="flex flex-wrap items-center gap-2">
              <button id="btn-m-all" class="chip" aria-pressed="true">ぜんぶ</button>
              <button id="btn-m-madoka" class="chip chip-madoka" aria-pressed="false"><span class="dot" style="background:#ff8184"></span>水面まどか<span class="fan-mark" aria-hidden="true">🪟</span></button>
              <button id="btn-m-ayane" class="chip chip-ayane" aria-pressed="false"><span class="dot" style="background:#54a2e5"></span>白砂あやね<span class="fan-mark" aria-hidden="true">🏖️</span></button>
              <button id="btn-m-duet" class="chip chip-duet" aria-pressed="false">うみゃみー<span class="fan-mark" aria-hidden="true">🫶</span></button>
            </div>
          </div>
          <div class="flex flex-col gap-1.5 sm:flex-row sm:flex-wrap sm:items-center sm:gap-2">
            <span class="text-[11px] text-slate-400 font-semibold sm:mr-1">カテゴリ</span>
            <div class="flex flex-wrap items-center gap-2">
              <button id="btn-c-all" class="chip" aria-pressed="true">ぜんぶ</button>
              <button id="btn-c-uta_waku" class="chip" aria-pressed="false">歌枠</button>
              <button id="btn-c-cover" class="chip" aria-pressed="false">歌ってみた</button>
              <button id="btn-c-short" class="chip" aria-pressed="false">ショート</button>
              <button id="btn-fav" class="chip chip-fav sm:ml-auto" aria-pressed="false" aria-label="お気に入りで絞り込み">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                お気に入り
              </button>
              <span id="resultCount" class="text-[11px] font-medium text-slate-400">{totalSongs} 曲</span>
            </div>
          </div>
        </div>
      </div>

      <!-- アクティブなアーティスト絞り込み -->
      <div id="artistFilterBar" class="hidden mb-4 flex items-center gap-2">
        <span class="text-xs text-slate-400 font-semibold">アーティスト</span>
        <button id="artistClear" type="button" class="chip" aria-pressed="true"><span id="artistFilterName"></span><span class="ml-1.5 text-slate-400">✕</span></button>
      </div>

      <!-- お気に入りの書き出し／取り込み（お気に入り絞り込み時のみ表示） -->
      <div id="favToolbar" class="hidden mb-4 flex flex-wrap items-center gap-2">
        <span class="text-xs text-slate-400 font-semibold">お気に入り</span>
        <button id="favExport" type="button" class="chip text-xs" aria-label="お気に入りをファイルに書き出し">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          書き出し
        </button>
        <button id="favImport" type="button" class="chip text-xs" aria-label="ファイルからお気に入りを取り込み">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          取り込み
        </button>
        <span id="favIoMsg" class="text-[11px] font-medium text-slate-400" role="status" aria-live="polite"></span>
        <input id="favFile" type="file" accept="application/json,.json" class="hidden">
      </div>

      <!-- Song Grid（カードは表示中のぶんだけ JS で描画＝Phase B 軽量化） -->
      <div id="songGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>

      <!-- さらに表示 -->
      <div id="moreWrap" class="hidden mt-8 text-center">
        <button id="loadMoreBtn" type="button"
                class="chip px-5 py-2 text-sm font-semibold">さらに表示<span id="moreCount" class="text-slate-400 font-normal ml-1.5"></span></button>
      </div>

      <!-- Empty state -->
      <div id="emptyState" class="hidden py-20 text-center">
        <p id="emptyMsg" class="font-semibold text-slate-500">「<span id="emptyQuery" class="text-madoka"></span>」に一致する曲がありません</p>
        <button id="resetSearchBtn" type="button" class="mt-4 chip text-xs">検索をリセット</button>
      </div>

      <!-- Stream Grid（配信ビュー） -->
      <div id="streamGrid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
      <div id="streamEmpty" class="hidden py-20 text-center">
        <p class="font-semibold text-slate-500">該当する配信がありません</p>
      </div>

      <!-- Artist Grid（アーティストビュー） -->
      <div id="artistGrid" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3"></div>
      <div id="artistEmpty" class="hidden py-20 text-center">
        <p class="font-semibold text-slate-500">該当するアーティストがいません</p>
      </div>

    </main>
  </div>

  <div id="songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>

  <!-- Bottom music player -->
  <div id="player" class="hidden">
    <!-- Expanded sheet -->
    <div id="playerSheet" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center">
      <div id="sheetBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
      <div class="relative w-full max-w-4xl bg-white rounded-t-2xl sm:rounded-2xl shadow-2xl border border-slate-200 max-h-[90vh] flex flex-col overflow-hidden">
        <div class="accent-bar h-1 w-full shrink-0"></div>
        <div class="flex items-center justify-between px-4 pt-3 pb-1">
          <span class="accent-text text-[11px] font-bold tracking-widest text-madoka">NOW PLAYING</span>
          <button id="collapseBtn" aria-label="閉じる" class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 p-4 pt-1 min-h-0 overflow-hidden">
          <div class="sm:w-3/5 shrink-0 flex flex-col">
            <div class="aspect-video bg-black rounded-xl overflow-hidden"><div id="ytFrame" class="w-full h-full"></div></div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <h3 id="sheetTitle" class="font-bold text-ink truncate">—</h3>
                <p id="sheetMeta" class="text-xs text-slate-400 truncate">—</p>
              </div>
              <div class="shrink-0 flex items-center gap-2">
                <button id="sheetAdd" type="button" aria-label="プレイリストに追加"
                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 12H3"/><path d="M16 6H3"/><path d="M16 18H3"/><path d="M18 9v6"/><path d="M21 12h-6"/></svg>
                </button>
                <button id="sheetFav" type="button" aria-label="お気に入り" aria-pressed="false"
                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </button>
                <button id="sheetShare" type="button" aria-label="Xで共有"
                        class="inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-slate-900 hover:bg-slate-800 px-3 py-2 rounded-lg transition">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  共有
                </button>
                <a id="sheetYoutube" href="#" target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-[#ff0000] px-3 py-2 rounded-lg">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
                  YouTube
                </a>
              </div>
            </div>
            <!-- Seek bar（曲内の再生位置） -->
            <div class="mt-3 flex items-center gap-2 text-[11px] text-slate-400 tabular-nums">
              <span class="seek-cur">0:00</span>
              <input type="range" min="0" max="1000" value="0" step="1" aria-label="再生位置" class="seek-range flex-1">
              <span class="seek-dur">0:00</span>
            </div>
            <!-- Sheet controls -->
            <div class="mt-3 flex items-center justify-center gap-1 text-slate-600">
              <button class="ctl-prev p-2 rounded-full hover:bg-slate-100" aria-label="前へ">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 4 9 12 19 20 19 4" fill="currentColor"/><line x1="5" x2="5" y1="5" y2="19"/></svg>
              </button>
              <button class="ctl-play play-btn-themed p-3 rounded-full bg-ink text-white hover:opacity-90" aria-label="再生/一時停止">
                <svg class="icon-play w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3" fill="currentColor"/></svg>
                <svg class="icon-pause w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/><rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/></svg>
              </button>
              <button class="ctl-next p-2 rounded-full hover:bg-slate-100" aria-label="次へ">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4" fill="currentColor"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
              </button>
              <button class="ctl-repeat relative p-2 rounded-full hover:bg-slate-100" aria-label="リピート切替">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>
                <span class="repeat-one hidden absolute -top-0.5 -right-0.5 text-[9px] font-bold bg-madoka text-white rounded-full w-3.5 h-3.5 flex items-center justify-center">1</span>
              </button>
              <button class="ctl-shuffle p-2 rounded-full hover:bg-slate-100" aria-label="シャッフル再生">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h4c2 0 4-1.2 6-6s4-6 6-6h4" /><path d="m18 2 4 4-4 4" /><path d="M2 6h4c2 0 4 1.2 6 6s4 6 6 6h4" /><path d="m18 14 4 4-4 4" /></svg>
              </button>
              <div class="flex items-center gap-1 ml-2">
                <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
                  <svg class="icon-vol w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                  <svg class="icon-vol-low w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                  <svg class="icon-mute w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="22" y1="9" x2="16" y2="15"/><line x1="16" y1="9" x2="22" y2="15"/></svg>
                </button>
                <input type="range" min="0" max="100" value="100" aria-label="音量" class="volume-slider w-20 accent-[#ff8184]">
              </div>
            </div>
          </div>
          <div class="sm:w-2/5 min-h-0 flex flex-col">
            <p class="mb-2 shrink-0 flex items-baseline gap-2">
              <span class="text-xs font-bold text-slate-400">再生キュー</span>
              <span id="queueMode" class="text-[11px] font-medium text-slate-400"></span>
            </p>
            <div id="upNext" class="flex-1 overflow-y-auto -mr-1 pr-1 space-y-1 min-h-[120px]"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mini bar -->
    <div class="fixed inset-x-0 bottom-0 z-40 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_20px_rgba(15,23,42,0.06)]">
      <div class="accent-bar h-1 w-full"></div>
      <button id="barHandle" aria-label="プレーヤーを開く" class="group w-full flex flex-col items-center pt-1.5 gap-0.5">
        <span class="block w-9 h-1 rounded-full bg-slate-300 group-hover:bg-slate-400 transition"></span>
        <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-slate-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" d="M5 15l7-7 7 7"/></svg>
      </button>
      <!-- Seek bar（折りたたみ時も表示） -->
      <div class="max-w-6xl mx-auto px-3 sm:px-4 flex items-center gap-2 text-[10px] text-slate-400 tabular-nums">
        <span class="seek-cur">0:00</span>
        <input type="range" min="0" max="1000" value="0" step="1" aria-label="再生位置" class="seek-range flex-1">
        <span class="seek-dur">0:00</span>
      </div>
      <div class="max-w-6xl mx-auto px-3 sm:px-4 pb-2 flex items-center gap-2 sm:gap-3">
        <button id="barExpand" class="flex items-center gap-3 min-w-0 flex-1 text-left" aria-label="プレーヤーを開く">
          <img id="barThumb" src="" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
          <div class="min-w-0">
            <p id="barTitle" class="text-sm font-semibold text-ink truncate">—</p>
            <p id="barMeta" class="text-xs text-slate-400 truncate">—</p>
          </div>
        </button>

        <!-- volume (md+) -->
        <div class="hidden md:flex items-center gap-1.5 shrink-0 text-slate-600">
          <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
            <svg class="icon-vol w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
            <svg class="icon-vol-low w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                  <svg class="icon-mute w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="22" y1="9" x2="16" y2="15"/><line x1="16" y1="9" x2="22" y2="15"/></svg>
          </button>

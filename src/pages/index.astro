            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
          </button>
          <button type="button" data-act="down" aria-label="下へ" ${i === list.length - 1 ? 'disabled' : ''} class="w-7 h-7 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-white disabled:opacity-25">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <button type="button" data-act="remove" aria-label="プレイリストから外す" class="w-7 h-7 inline-flex items-center justify-center rounded-full text-slate-400 hover:text-rose-500 hover:bg-white">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </span>
      </div>`).join('');
  }

  // --- 再生 ---
  function playPlaylist(pl: any, startIdx = 0, doShuffle = false) {
    const list = plResolveSongs(pl);
    if (!list.length) { setPlMsg('再生できる曲がありません', true); return; }
    if (doShuffle) {
      for (let i = list.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [list[i], list[j]] = [list[j], list[i]];
      }
      startIdx = 0;
    }
    queue = list;
    qIndex = Math.max(0, Math.min(list.length - 1, startIdx));
    current(queue[qIndex]);
    closePlModal();
  }

  // --- 共有リンクの短縮エンコード（?p=） ---
  // idをそのまま並べると1曲19〜25文字になるため、id構造を利用して圧縮する。
  // トークン列: M|A|B = 旧形式id（メンバー＋日付）、V = videoId形式id。
  //   M|A|B + 日数3桁(base36, 2026-01-01起点) + 連番2桁(base36)…
  //   V + videoId(11文字固定) + 連番2桁(base36)…
  // 同じ日付メンバー／同じ動画が連続する間は連番(2文字)だけを並べる。
  // マーカーは大文字MABV・連番は小文字base36なので区切り文字は不要。
  const PL_EPOCH_UTC = Date.UTC(2026, 0, 1);
  const OLD_ID_RE = /^(\d{4})(\d{2})(\d{2})-(both|madoka|ayane)-(\d{3})$/;
  const VID_ID_RE = /^\d{8}-([\w-]{11})-(\d{3})$/;
  const MEMBER_MARK: Record<string, string> = { both: 'B', madoka: 'M', ayane: 'A' };
  const MARK_MEMBER: Record<string, string> = { B: 'both', M: 'madoka', A: 'ayane' };
  const b36 = (n: number, w: number) => n.toString(36).padStart(w, '0');

  // 全idを短縮コード化。1つでも未知の形式があれば null（旧形式 songs= にフォールバック）
  function encodeShareIds(ids: string[]): string | null {
    let out = '', prevKey = '';
    for (const id of ids) {
      const m = OLD_ID_RE.exec(id);
      if (m) {
        const days = Math.round((Date.UTC(+m[1], +m[2] - 1, +m[3]) - PL_EPOCH_UTC) / 86400000);
        const num = +m[5];
        if (days < 0 || days >= 36 ** 3 || num >= 36 ** 2) return null;
        const key = MEMBER_MARK[m[4]] + b36(days, 3);
        out += (key === prevKey ? '' : key) + b36(num, 2);
        prevKey = key;
        continue;
      }
      const v = VID_ID_RE.exec(id);
      if (v) {
        const num = +v[2];
        if (num >= 36 ** 2) return null;
        const key = 'V' + v[1];
        out += (key === prevKey ? '' : key) + b36(num, 2);
        prevKey = key;
        continue;
      }
      return null;
    }
    return out;
  }

  // 短縮コード → id配列。videoId形式は日付をidから復元できないため曲データから逆引きする
  function decodeShareIds(code: string): string[] {
    const ids: string[] = [];
    let i = 0, mode: string | null = null, days = 0, videoId = '';
    while (i < code.length && ids.length < 500) {
      const c = code[i];
      if (c === 'M' || c === 'A' || c === 'B') {
        days = parseInt(code.slice(i + 1, i + 4), 36);
        if (isNaN(days)) break;
        mode = c; i += 4;
      } else if (c === 'V') {
        videoId = code.slice(i + 1, i + 12);
        if (videoId.length < 11) break;
        mode = 'V'; i += 12;
      } else if (mode && /^[0-9a-z]{2}$/.test(code.slice(i, i + 2))) {
        const n3 = String(parseInt(code.slice(i, i + 2), 36)).padStart(3, '0');
        if (mode === 'V') {
          const song = songs.find((s: any) => s.id.endsWith(`-${videoId}-${n3}`));
          ids.push(song ? song.id : `unknown-${videoId}-${n3}`);
        } else {
          const d = new Date(PL_EPOCH_UTC + days * 86400000);
          const ymd = `${d.getUTCFullYear()}${String(d.getUTCMonth() + 1).padStart(2, '0')}${String(d.getUTCDate()).padStart(2, '0')}`;
          ids.push(`${ymd}-${MARK_MEMBER[mode]}-${n3}`);
        }
        i += 2;
      } else break; // 壊れたコード。読めたところまで使う
    }
    return ids;
  }

  // --- 共有（URLに短縮コードを載せる。受け取り側はデータに存在する曲だけ復元） ---
  function playlistShareUrl(name: string, ids: string[]): string {
    const valid = ids.filter(id => songById(id));
    const code = encodeShareIds(valid);
    const q = code !== null ? `p=${code}` : `songs=${valid.join('.')}`;
    return `${location.origin}${location.pathname}?pl=${encodeURIComponent(name)}&${q}`;
  }
  async function copyText(text: string): Promise<boolean> {
    try { await navigator.clipboard.writeText(text); return true; } catch (_) {}
    try {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      const ok = document.execCommand('copy');
      ta.remove();
      return ok;
    } catch (_) { return false; }
  }

  // --- 「プレイリストに追加」モーダル ---
  function openPlAdd(songId: string) {
    const s = songById(songId);
    if (!s) return;
    plAddTargetId = songId;
    const label = document.getElementById('plAddSong');
    if (label) label.textContent = `${s.title}${s.artist ? ' / ' + s.artist : ''}`;
    renderPlAddList();
    show('plAddModal');
  }
  function renderPlAddList() {
    const el = document.getElementById('plAddList');
    if (!el) return;
    if (!playlists.length) {
      el.innerHTML = `<p class="text-sm text-slate-400 py-6 text-center leading-relaxed">プレイリストはまだありません。<br>下の入力欄から作成できます。</p>`;
      return;
    }
    el.innerHTML = playlists.map(pl => {
      const on = !!plAddTargetId && pl.ids.includes(plAddTargetId);
      return `
        <button type="button" data-pl-id="${escHtml(pl.id)}" aria-pressed="${on}"
                class="w-full flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 text-left">
          <span class="w-6 h-6 shrink-0 inline-flex items-center justify-center rounded-full ${on ? 'text-white' : 'text-slate-400 border border-slate-200'}"
                ${on ? 'style="background:linear-gradient(135deg,#ff8184,#54a2e5)"' : ''}>
            ${on
              ? '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
              : '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>'}
          </span>
          <span class="min-w-0 flex-1">
            <span class="block text-sm font-semibold text-ink truncate">${escHtml(pl.name)}</span>
            <span class="block text-xs text-slate-400">${plResolveSongs(pl).length}曲</span>
          </span>
        </button>`;
    }).join('');
  }
  function togglePlAdd(plId: string) {
    const pl = plFind(plId);
    if (!pl || !plAddTargetId) return;
    const i = pl.ids.indexOf(plAddTargetId);
    if (i >= 0) pl.ids.splice(i, 1); else pl.ids.push(plAddTargetId);
    pl.updatedAt = Date.now();
    savePlaylists();
    renderPlAddList();
  }

  // --- URLで共有されたプレイリストの受け取り（?pl=名前&p=短縮コード。旧 &songs=id.id… も互換） ---
  function checkSharedPlaylist() {
    const params = new URLSearchParams(location.search);
    const shortRaw = params.get('p');
    const legacyRaw = params.get('songs');
    if (!shortRaw && !legacyRaw) return;
    const name = (params.get('pl') || '共有プレイリスト').slice(0, 40);
    const ids = shortRaw
      ? decodeShareIds(shortRaw)
      : (legacyRaw || '').split('.').filter(Boolean).slice(0, 500);
    const found = ids.map(songById).filter(Boolean);
    if (!found.length) return;
    plShared = { name, ids: found.map((s: any) => s.id) };
    const info = document.getElementById('plSharedInfo');
    if (info) {
      const missing = ids.length - found.length;
      info.textContent = `「${name}」（${found.length}曲${missing ? `・${missing}曲は見つかりませんでした` : ''}）`;
    }
    const el = document.getElementById('plSharedSongs');
    if (el) el.innerHTML = found.map((s: any, i: number) => `
      <button type="button" data-idx="${i}" class="pl-shared-row w-full flex items-center gap-2.5 p-1.5 rounded-lg hover:bg-slate-100 text-left">
        <span class="text-[11px] text-slate-400 w-5 text-right tabular-nums shrink-0">${i + 1}</span>
        <img src="https://img.youtube.com/vi/${encodeURIComponent(s.youtube.videoId)}/default.jpg" alt="" loading="lazy" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
        <span class="min-w-0">
          <span class="block text-xs font-semibold text-ink truncate">${escHtml(s.title)}</span>
          <span class="block text-[11px] text-slate-400 truncate">${escHtml(s.artist || '')}</span>
        </span>
      </button>`).join('');
    show('plSharedModal');
  }
  function playShared(startIdx = 0) {
    if (!plShared) return;
    const list = plShared.ids.map(songById).filter(Boolean);
    if (!list.length) return;
    queue = list;
    qIndex = Math.max(0, Math.min(list.length - 1, startIdx));
    current(queue[qIndex]);
    hide('plSharedModal');
  }

  // ===== Media Session API（ロック画面・メディアキー・イヤホン操作に対応） =====
  function updateMediaMetadata(song: any) {
    if (!('mediaSession' in navigator) || typeof (window as any).MediaMetadata === 'undefined') return;
    const vid = song.youtube.videoId;
    const performers = orderPerformers(song.performers || []).join('・');
    try {
      (navigator as any).mediaSession.metadata = new (window as any).MediaMetadata({
        title: song.title,
        artist: song.artist ? `${song.artist}${performers ? '（うた：' + performers + '）' : ''}` : performers,
        album: 'うみゃみーMusic',
        artwork: [
          { src: `https://img.youtube.com/vi/${vid}/mqdefault.jpg`, sizes: '320x180', type: 'image/jpeg' },
          { src: `https://img.youtube.com/vi/${vid}/hqdefault.jpg`, sizes: '480x360', type: 'image/jpeg' },
        ],
      });
    } catch (_) {}
  }
  function setupMediaSession() {
    if (!('mediaSession' in navigator)) return;
    const ms = (navigator as any).mediaSession;
    const set = (action: string, fn: any) => { try { ms.setActionHandler(action, fn); } catch (_) {} };
    set('play', () => ytPlayer?.playVideo?.());
    set('pause', () => ytPlayer?.pauseVideo?.());
    set('previoustrack', prev);
    set('nexttrack', next);
    // 曲＝動画内の区間なので、シークは区間開始秒を基準に変換
    set('seekto', (d: any) => {
      if (d && typeof d.seekTime === 'number' && ytPlayer?.seekTo) ytPlayer.seekTo(segStart + d.seekTime, true);
    });
  }

  const CAT_LABEL: Record<string, string> = { uta_waku: '歌枠', cover: '歌ってみた', short: 'ショート' };
  const MEMBER_ORDER = ['水面まどか', '白砂あやね'];

  function orderPerformers(performers: string[]) {
    return [...performers].sort((a, b) => MEMBER_ORDER.indexOf(a) - MEMBER_ORDER.indexOf(b));
  }
  function memberChipClass(p: string) {
    return p === '水面まどか' ? 'text-[#ff8184] bg-[#ffeef0]' : 'text-[#54a2e5] bg-[#eaf4fc]';
  }

  // 曲カードのHTML（SongCard.astro と同等。表示中ぶんだけ JS で描画＝Phase B 軽量化）
  function cardHtml(song: any): string {
    const performers = orderPerformers(song.performers || []);
    const isDuet = performers.length > 1;
    const thumb = `https://img.youtube.com/vi/${encodeURIComponent(song.youtube.videoId)}/mqdefault.jpg`;
    const cat = CAT_LABEL[song.category] || song.category;
    const duetBadge = isDuet
      ? `<span class="text-[10px] px-2 py-0.5 rounded-full font-semibold text-white" style="background:linear-gradient(135deg,#ff8184,#54a2e5)">うみゃみー</span>`
      : '';
    const chips = performers.map((p: string) =>
      `<span class="text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChipClass(p)}">${escHtml(p)}</span>`).join('');
    const tags = (song.tags && song.tags.length)
      ? `<div class="flex gap-1 flex-wrap mt-2.5">${song.tags.slice(0, 3).map((t: string) =>
          `<span class="tag-chip">#${escHtml(t)}</span>`).join('')}</div>`
      : '';
    return `
      <div class="song-card-item card group cursor-pointer overflow-hidden" data-id="${escHtml(song.id)}">
        <div class="thumb-wrap">
          <img src="${thumb}" alt="${escHtml(song.title)}" loading="lazy" decoding="async" />
          <div class="play-overlay"><div class="play-btn">
            <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div></div>
          <span class="playing-badge ts-badge hidden"><span class="eq" aria-hidden="true"><i></i><i></i><i></i></span>再生中</span>
          <button type="button" class="card-fav" data-id="${escHtml(song.id)}" aria-label="お気に入り" aria-pressed="false">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </button>
          <button type="button" class="card-share" data-id="${escHtml(song.id)}" aria-label="Xで共有">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button type="button" class="card-add" data-id="${escHtml(song.id)}" aria-label="プレイリストに追加">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 12H3"/><path d="M16 6H3"/><path d="M16 18H3"/><path d="M18 9v6"/><path d="M21 12h-6"/></svg>
          </button>
        </div>
        <div class="p-4">
          <div class="flex items-start justify-between gap-2 mb-1">
            <h3 class="font-bold text-slate-900 text-[15px] leading-snug flex-1">${escHtml(song.title)}</h3>
            <span class="shrink-0 text-[11px] px-2 py-0.5 rounded-full font-semibold text-slate-500 bg-slate-100 whitespace-nowrap">${escHtml(cat)}</span>
          </div>
          <p class="text-xs text-slate-400 font-medium mb-3 truncate">${escHtml(song.artist || '')}</p>
          <div class="flex items-center justify-between gap-2">
            <div class="flex gap-1 flex-wrap">${duetBadge}${chips}</div>
            <span class="text-[11px] font-medium text-slate-400 whitespace-nowrap">${escHtml(song.streamDate || '')}</span>
          </div>
          ${tags}
        </div>
      </div>`;
  }

  // メンバー・カテゴリだけで絞った曲（アーティスト一覧の集計と曲一覧の土台に共用）
  function memberCategoryFiltered() {
    let f = songs;
    // メンバー単体ボタンは「ソロ曲のみ」を表示（2人歌唱は「うみゃみー」で絞り込む）
    if (filterMember === 'ayane') f = f.filter((s: any) => s.performers.length === 1 && s.performers[0] === '白砂あやね');
    else if (filterMember === 'madoka') f = f.filter((s: any) => s.performers.length === 1 && s.performers[0] === '水面まどか');
    else if (filterMember === 'duet') f = f.filter((s: any) => s.performers.length > 1);
    if (filterCategory !== 'all') f = f.filter((s: any) => s.category === filterCategory);
    if (filterFav) f = f.filter((s: any) => favSet.has(s.id));
    return f;
  }

  function getFiltered() {
    let f = memberCategoryFiltered();
    if (filterArtist) f = f.filter((s: any) => (s.artist || '').trim() === filterArtist);
    if (searchText) {
      const m = new Set(fuse.search(searchText).map(r => (r.item as any).id));
      f = f.filter((s: any) => m.has(s.id));
    }
    return f;
  }

  // 一覧の段階表示（多すぎてページ下部に行けない問題への対策）
  const PAGE_SIZE = 24;
  let shownCount = PAGE_SIZE;

  // 現在の絞り込み結果のうち先頭 shownCount 件だけ表示し、残りは「さらに表示」に隠す
  function applyDisplay() {
    const filtered = getFiltered();
    const grid = document.getElementById('songGrid');
    if (grid) grid.innerHTML = filtered.slice(0, shownCount).map(cardHtml).join('');
    // 再描画後に「再生中」「お気に入り」の状態を復元
    markPlayingCard(nowPlaying ? nowPlaying.id : null);
    refreshFavUI();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${filtered.length} 曲`;

    const remaining = filtered.length - shownCount;
    const moreWrap = document.getElementById('moreWrap');
    const moreCount = document.getElementById('moreCount');
    moreWrap?.classList.toggle('hidden', remaining <= 0);
    if (moreCount) moreCount.textContent = remaining > 0 ? `（残り${remaining}曲）` : '';

    const emptyState = document.getElementById('emptyState');
    const emptyQuery = document.getElementById('emptyQuery');
    const emptyMsg = document.getElementById('emptyMsg');
    if (filtered.length === 0) {
      emptyState?.classList.remove('hidden');
      // お気に入り絞り込みで空（かつ未検索）のときは専用メッセージ
      if (filterFav && !searchText && favSet.size === 0) {
        if (emptyMsg) emptyMsg.innerHTML = 'お気に入りがまだありません。曲カードの<span class="text-madoka">★</span>でお気に入りに追加できます。';
      } else if (emptyMsg) {
        emptyMsg.innerHTML = '「<span id="emptyQuery" class="text-madoka"></span>」に一致する曲がありません';
        const q = document.getElementById('emptyQuery');
        if (q) q.textContent = searchText || (filterFav ? 'お気に入り' : '');
      }
    } else emptyState?.classList.add('hidden');
  }

  // 絞り込み・検索が変わったときの入口（表示件数をリセットして先頭から）
  function filterSongs() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    searchText = searchInput ? searchInput.value.trim().toLowerCase() : '';
    document.getElementById('clearSearch')?.classList.toggle('hidden', !searchText);
    shownCount = PAGE_SIZE;
    refresh();
  }

  // 現在のビューに応じて一覧を再描画
  function refresh() {
    if (viewMode === 'streams') renderStreams();
    else if (viewMode === 'artists') renderArtists();
    else applyDisplay();
    updateFavToolbar();
  }

  // ビュー切替（曲 / 配信 / アーティスト）
  function setView(mode: 'songs' | 'streams' | 'artists') {
    viewMode = mode;
    shownCount = PAGE_SIZE;
    const isSongs = mode === 'songs', isStreams = mode === 'streams', isArtists = mode === 'artists';
    document.getElementById('view-songs')?.setAttribute('aria-pressed', String(isSongs));
    document.getElementById('view-streams')?.setAttribute('aria-pressed', String(isStreams));
    document.getElementById('view-artists')?.setAttribute('aria-pressed', String(isArtists));
    document.getElementById('songGrid')?.classList.toggle('hidden', !isSongs);
    document.getElementById('streamGrid')?.classList.toggle('hidden', !isStreams);
    document.getElementById('artistGrid')?.classList.toggle('hidden', !isArtists);
    document.getElementById('streamSort')?.classList.toggle('hidden', !isStreams);
    if (!isSongs) {
      document.getElementById('moreWrap')?.classList.add('hidden');
      document.getElementById('emptyState')?.classList.add('hidden');
    }
    if (!isStreams) document.getElementById('streamEmpty')?.classList.add('hidden');
    if (!isArtists) document.getElementById('artistEmpty')?.classList.add('hidden');
    updateArtistChip();
    const si = document.getElementById('searchInput') as HTMLInputElement | null;
    if (si) si.placeholder = isStreams ? '配信タイトル・日付・曲名で検索'
      : isArtists ? 'アーティスト名で検索'
      : '曲名・アーティスト・タグで検索';
    refresh();
  }

  // アクティブなアーティスト絞り込みチップの表示更新（曲ビューでのみ表示）
  function updateArtistChip() {
    const bar = document.getElementById('artistFilterBar');
    const nameEl = document.getElementById('artistFilterName');
    const show = viewMode === 'songs' && !!filterArtist;
    bar?.classList.toggle('hidden', !show);
    if (show && nameEl) nameEl.textContent = filterArtist;
  }

  function loadMore() {
    shownCount += PAGE_SIZE;
    applyDisplay();
  }

  function clearSearch() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    filterSongs();
  }

  // ===== 下部音楽プレーヤー（YouTube IFrame API） =====
  type RepeatMode = 'all' | 'one' | 'off';
  let ytPlayer: any = null, pending: any = null;
  let queue: any[] = [], qIndex = -1, isPlaying = false, nowPlaying: any = null;
  let repeatMode: RepeatMode = 'off';   // 既定=1巡で停止。オフ → 連続再生 → 1曲リピート で巡回
  let lastVolume = 100, isMuted = false;
  // 曲は「動画内の [開始秒, 終了秒) 区間」。終了秒は同一動画の次曲の開始秒（最後の曲は動画終端=ENDEDに委譲）
  let segStart = 0, segEnd = Infinity, segHandled = false, currentVideoId: string | null = null, watchTimer: any = null;
  let isSeeking = false; // シークバーをドラッグ中はバー位置を上書きしない

  const apiTag = document.createElement('script');
  apiTag.src = 'https://www.youtube.com/iframe_api';
  document.head.appendChild(apiTag);
  (window as any).onYouTubeIframeAPIReady = () => {
    ytPlayer = new (window as any).YT.Player('ytFrame', {
      playerVars: { rel: 0, playsinline: 1, autoplay: 1 },
      events: {
        onReady: () => {
          applyVolume();
          if (pending) { loadVideo(pending); pending = null; }
        },
        onStateChange: (e: any) => {
          isPlaying = (e.data === 1);
          updatePlayIcon();
          if ('mediaSession' in navigator) {
            try { (navigator as any).mediaSession.playbackState = isPlaying ? 'playing' : 'paused'; } catch (_) {}
          }
          // 動画自体の終端（＝最後の曲の区間終わり）。区間監視が拾えない最終曲のみここで処理
          if (e.data === 0 && !segHandled) { segHandled = true; handleEnded(); }
        },
      },
    });
  };

  // 同一動画で「この曲の開始秒より後にある最も近い曲の開始秒」＝この曲の終了秒。無ければ動画終端(Infinity)
  function computeSegmentEnd(song: any): number {
    if (song.youtube.endSec != null) return song.youtube.endSec; // 明示の終了秒（動画長）
    const vid = song.youtube.videoId;
    const start = song.youtube.timestampSec || 0;
    const laterStarts = songs
      .filter((s: any) => s.youtube.videoId === vid)
      .map((s: any) => s.youtube.timestampSec || 0)
      .filter((t: number) => t > start)
      .sort((a: number, b: number) => a - b);
    return laterStarts.length ? laterStarts[0] : Infinity;
  }

  function loadVideo(song: any) {
    const start = song.youtube.timestampSec || 0;
    segStart = start;
    segEnd = computeSegmentEnd(song);
    segHandled = false;
    if (ytPlayer && ytPlayer.loadVideoById) {
      if (currentVideoId === song.youtube.videoId && ytPlayer.seekTo) {
        // 同じ動画内の移動は再読込せず seek（瞬時）
        ytPlayer.seekTo(start, true);
        ytPlayer.playVideo?.();
      } else {
        ytPlayer.loadVideoById({ videoId: song.youtube.videoId, startSeconds: start });
        currentVideoId = song.youtube.videoId;
      }
      startWatch();
    } else {
      pending = song;
    }
  }

  // mm:ss 形式（曲の経過/尺の表示用）
  function fmtClock(sec: number): string {
    if (!isFinite(sec) || sec < 0) sec = 0;
    const m = Math.floor(sec / 60), s = Math.floor(sec % 60);
    return `${m}:${String(s).padStart(2, '0')}`;
  }

  // 実効の終了秒（最後の曲は動画長を使う）
  function effectiveEnd(): number {
    if (segEnd !== Infinity) return segEnd;
    const d = ytPlayer && ytPlayer.getDuration ? ytPlayer.getDuration() : 0;
    return d > 0 ? d : segStart; // 動画長が未取得なら尺0扱い
  }

  // シークバー・時間表示を更新（ミニバー／展開シートの両方）
  function updateSeek(t: number) {
    const end = effectiveEnd();
    const dur = Math.max(0, end - segStart);
    const cur = Math.max(0, Math.min(dur, t - segStart));
    document.querySelectorAll('.seek-cur').forEach(el => (el.textContent = fmtClock(cur)));
    document.querySelectorAll('.seek-dur').forEach(el => (el.textContent = fmtClock(dur)));
    if (!isSeeking && dur > 0) {
      const v = String(Math.round((cur / dur) * 1000));
      document.querySelectorAll('.seek-range').forEach(el => ((el as HTMLInputElement).value = v));
    }
    // ロック画面などのシークバーにも曲内の位置を反映
    if (dur > 0 && 'mediaSession' in navigator && (navigator as any).mediaSession.setPositionState) {
      try { (navigator as any).mediaSession.setPositionState({ duration: dur, position: cur, playbackRate: 1 }); } catch (_) {}
    }
  }

  // 曲内の指定位置へシーク（ratio: 0〜1）
  function seekToRatio(ratio: number) {
    if (!ytPlayer || !ytPlayer.seekTo) return;
    const dur = Math.max(0, effectiveEnd() - segStart);
    ytPlayer.seekTo(segStart + ratio * dur, true);
  }

  // 再生位置を監視: シークバー更新 ＋ 曲の終了秒に達したら handleEnded（区間境界での次へ/リピート）
  function startWatch() {
    if (watchTimer) return;
    watchTimer = setInterval(() => {
      if (!ytPlayer || !ytPlayer.getCurrentTime) return;
      const t = ytPlayer.getCurrentTime();
      updateSeek(t);
      if (!segHandled && segEnd !== Infinity && t >= segEnd - 0.25) { segHandled = true; handleEnded(); }
    }, 250);
  }
  function stopWatch() { if (watchTimer) { clearInterval(watchTimer); watchTimer = null; } }

  function saveHistory(song: any) {
    try {
      const k = 'umyamy:history';
      const arr = JSON.parse(localStorage.getItem(k) || '[]');
      if (arr[0] && arr[0].id === song.id) return;
      arr.unshift({ id: song.id, title: song.title, artist: song.artist, videoId: song.youtube.videoId, at: Date.now() });
      localStorage.setItem(k, JSON.stringify(arr.slice(0, 50)));
    } catch (_) {}
  }

  function markPlayingCard(id: string | null) {
    // 再生中カードの枠色は歌唱者で変える（プレーヤーのテーマ色と一致）
    const accent = nowPlaying ? accentFor(nowPlaying).accent : null;
    document.querySelectorAll('.song-card-item').forEach(card => {
      const on = card.getAttribute('data-id') === id;
      card.classList.toggle('is-playing', on);
      if (on && accent) (card as HTMLElement).style.setProperty('--card-accent', accent);
      else (card as HTMLElement).style.removeProperty('--card-accent');
      const pb = card.querySelector('.playing-badge');
      const ts = card.querySelector('.ts-badge:not(.playing-badge)');
      if (pb) pb.classList.toggle('hidden', !on);
      if (ts) ts.classList.toggle('hidden', on);
    });
  }

  function updateBar(song: any) {
    const yurl = song.youtube.url || `https://www.youtube.com/watch?v=${song.youtube.videoId}`;
    const set = (id: string, fn: (el: any) => void) => { const el = document.getElementById(id); if (el) fn(el); };
    set('barThumb', el => el.src = `https://img.youtube.com/vi/${song.youtube.videoId}/default.jpg`);
    set('barTitle', el => el.textContent = song.title);
    set('barMeta', el => el.textContent = song.artist);
    set('sheetTitle', el => el.textContent = song.title);
    set('sheetMeta', el => el.textContent = `${song.artist}${song.streamTitle ? ' — ' + song.streamTitle : ''}`);
    set('barYoutube', el => el.href = yurl);
    set('sheetYoutube', el => el.href = yurl);
  }

  function updatePlayIcon() {
    document.querySelectorAll('.icon-play').forEach(el => el.classList.toggle('hidden', isPlaying));
    document.querySelectorAll('.icon-pause').forEach(el => el.classList.toggle('hidden', !isPlaying));
  }

  // ----- テーマ色（歌唱者で変化） -----
  // まどかソロ=コーラル / あやねソロ=ブルー / うみゃみー=中間色＋2色グラデ
  function accentFor(song: any): { accent: string; grad: string } {
    const p: string[] = song.performers || [];
    const hasM = p.includes('水面まどか'), hasA = p.includes('白砂あやね');
    if (hasM && hasA) return { accent: '#b86fb0', grad: 'linear-gradient(90deg,#ff8184,#54a2e5)' };
    if (hasA) return { accent: '#54a2e5', grad: 'linear-gradient(90deg,#54a2e5,#88c4f1)' };
    return { accent: '#ff8184', grad: 'linear-gradient(90deg,#ff8184,#ffb0b2)' };
  }
  function applyTheme(song: any) {
    const { accent, grad } = accentFor(song);
    const root = document.getElementById('player');
    if (root) {
      root.style.setProperty('--accent', accent);
      root.style.setProperty('--accent-grad', grad);
    }
    document.querySelectorAll('.play-btn-themed').forEach(b => (b as HTMLElement).style.background = grad);
  }

  // ----- 再生キュー表示（前の曲 / 再生中 / 次の曲） -----
  const QUEUE_PREV_MAX = 8, QUEUE_NEXT_MAX = 40;  // パネルに出す前後の上限（DOMを軽く保つ）
  function queueRowHtml(s: any, idx: number, dim: boolean) {
    const thumb = `https://img.youtube.com/vi/${encodeURIComponent(s.youtube.videoId)}/default.jpg`;
    return `
      <button type="button" data-qindex="${idx}" class="upnext-item w-full flex items-center gap-2.5 p-1.5 rounded-lg hover:bg-slate-100 text-left${dim ? ' opacity-60' : ''}">
        <img src="${thumb}" alt="" loading="lazy" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold text-ink truncate">${escHtml(s.title)}</p>
          <p class="text-[11px] text-slate-400 truncate">${escHtml(s.artist || '')}</p>
        </div>
      </button>`;
  }
  const queueHint = (txt: string) => `<p class="text-[11px] text-slate-400 px-1.5 py-1.5 text-center">${txt}</p>`;
  function renderUpNext() {
    const el = document.getElementById('upNext');
    if (!el) return;
    if (!queue.length || qIndex < 0) {
      el.innerHTML = '<p class="text-xs text-slate-400 py-4 text-center">再生キューは空です</p>';
      return;
    }
    const parts: string[] = [];
    // 前の曲（直近 QUEUE_PREV_MAX 件。さらに前は件数だけ示す）
    if (qIndex > 0) {
      const prevStart = Math.max(0, qIndex - QUEUE_PREV_MAX);
      parts.push(`<p class="text-[11px] font-semibold text-slate-400 px-1.5 pt-1">前の曲${prevStart > 0 ? `（ほか ${prevStart} 曲）` : ''}</p>`);
      for (let i = prevStart; i < qIndex; i++) parts.push(queueRowHtml(queue[i], i, true));
    }
    // 再生中（ハイライト）
    const cur = queue[qIndex];
    parts.push(`
      <div data-current class="flex items-center gap-2.5 p-1.5 my-1 rounded-lg bg-slate-50 border border-slate-200">
        <img src="https://img.youtube.com/vi/${encodeURIComponent(cur.youtube.videoId)}/default.jpg" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-bold accent-text">▶ 再生中</p>
          <p class="text-xs font-semibold text-ink truncate">${escHtml(cur.title)}</p>
        </div>
      </div>`);
    // 次の曲（末尾まで。多い場合は QUEUE_NEXT_MAX で打ち切り、残数を表示）
    const after = queue.length - 1 - qIndex;
    if (after > 0) {
      parts.push('<p class="text-[11px] font-semibold text-slate-400 px-1.5 pt-1">次の曲</p>');
      const nextEnd = Math.min(queue.length, qIndex + 1 + QUEUE_NEXT_MAX);
      for (let i = qIndex + 1; i < nextEnd; i++) parts.push(queueRowHtml(queue[i], i, false));
      const rest = queue.length - nextEnd;
      if (rest > 0) parts.push(queueHint(`…ほか ${rest} 曲`));
      if (repeatMode === 'all') parts.push(queueHint('↻ 最後まで再生したら先頭へ戻ります'));
    } else {
      // 末尾＝キューの終わり。リピート設定ごとに次の動きを示す
      parts.push(queueHint(
        repeatMode === 'all' ? '↻ 末尾です（先頭へ戻って繰り返し）'
        : repeatMode === 'one' ? '🔂 この曲を繰り返します'
        : 'キューの最後です'));
    }
    el.innerHTML = parts.join('');
    // 現在曲をパネル中央へスクロール（ページ全体は動かさない）
    const curEl = el.querySelector('[data-current]') as HTMLElement | null;
    if (curEl) {
      const cRect = el.getBoundingClientRect(), curRect = curEl.getBoundingClientRect();
      el.scrollTop += (curRect.top - cRect.top) - el.clientHeight / 2 + curRect.height / 2;
    }
  }

  // ----- 音量 -----
  function applyVolume() {
    if (!ytPlayer || !ytPlayer.setVolume) return;
    if (isMuted || lastVolume === 0) ytPlayer.mute?.();
    else { ytPlayer.unMute?.(); ytPlayer.setVolume(lastVolume); }
  }
  function updateVolumeUI() {
    const off = isMuted || lastVolume === 0;
    const low = !off && lastVolume <= 50;   // 小音量（1〜50）
    const high = !off && lastVolume > 50;   // 大音量（51〜100）
    document.querySelectorAll('.volume-slider').forEach(s => (s as HTMLInputElement).value = String(isMuted ? 0 : lastVolume));
    document.querySelectorAll('.icon-vol').forEach(el => el.classList.toggle('hidden', !high));
    document.querySelectorAll('.icon-vol-low').forEach(el => el.classList.toggle('hidden', !low));
    document.querySelectorAll('.icon-mute').forEach(el => el.classList.toggle('hidden', !off));
  }
  function setVolume(v: number) {
    lastVolume = Math.max(0, Math.min(100, v));
    isMuted = lastVolume === 0;
    applyVolume();
    updateVolumeUI();
  }
  function toggleMute() {
    isMuted = !isMuted;
    if (!isMuted && lastVolume === 0) lastVolume = 50;
    applyVolume();
    updateVolumeUI();
  }

  // ----- リピート（オフ=1巡で停止 → 連続=末尾で先頭へ → 1曲=現在曲を繰り返し） -----
  const REPEAT_CYCLE: RepeatMode[] = ['off', 'all', 'one'];
  const REPEAT_LABEL: Record<RepeatMode, string> = { off: '1巡で停止', all: '連続リピート', one: '1曲リピート' };
  function cycleRepeat() {
    repeatMode = REPEAT_CYCLE[(REPEAT_CYCLE.indexOf(repeatMode) + 1) % REPEAT_CYCLE.length];
    updateRepeatUI();
    renderUpNext();
  }
  function updateRepeatUI() {
    document.querySelectorAll('.ctl-repeat').forEach(btn => {
      btn.classList.toggle('repeat-active', repeatMode !== 'off');
      btn.setAttribute('aria-label', 'リピート: ' + REPEAT_LABEL[repeatMode]);
      btn.setAttribute('title', 'リピート: ' + REPEAT_LABEL[repeatMode]);
    });
    document.querySelectorAll('.repeat-one').forEach(el => el.classList.toggle('hidden', repeatMode !== 'one'));
    const qm = document.getElementById('queueMode');
    if (qm) qm.textContent = '· ' + REPEAT_LABEL[repeatMode];
  }

  function handleEnded() {
    if (repeatMode === 'one') { playIndex(qIndex); return; }
    if (qIndex >= queue.length - 1) {
      if (repeatMode === 'all') playIndex(0);
      return; // off → 末尾で停止
    }
    playIndex(qIndex + 1);
  }

  function current(song: any) {
    if (!song) return;
    nowPlaying = song;
    loadVideo(song);
    updateBar(song);
    applyTheme(song);
    updateMediaMetadata(song);
    saveHistory(song);
    markPlayingCard(song.id);
    refreshFavUI();
    renderUpNext();
    document.getElementById('player')?.classList.remove('hidden');
    document.body.style.paddingBottom = '5.75rem';
  }

  // ----- Xで共有（曲名・アーティスト・歌唱者を本文に、URLは該当のYouTube動画） -----
  function shareSong(song: any) {
    if (!song) return;
    const performers = orderPerformers(song.performers || []).join('・');
    const lines = ['#NowPlaying', `${song.title}${song.artist ? ' / ' + song.artist : ''}`];
    if (performers) lines.push(`うた：${performers}`);
    const text = lines.join('\n');
    const sec = song.youtube?.timestampSec || 0;
    const ytUrl = song.youtube?.url
      || `https://www.youtube.com/watch?v=${song.youtube?.videoId}${sec ? '&t=' + sec : ''}`;
    const intent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`
      + `&url=${encodeURIComponent(ytUrl)}`;
    window.open(intent, '_blank', 'noopener,noreferrer');
  }

  function playSong(song: any) {
    queue = getFiltered();
    if (queue.length === 0 || !queue.find((s: any) => s.id === song.id)) queue = songs;
    qIndex = queue.findIndex((s: any) => s.id === song.id);
    current(song);
  }
  // キュー外へはみ出さないようクランプ（端での循環は呼び出し側が明示的に行う）
  function playIndex(i: number) {
    if (queue.length === 0) return;
    qIndex = Math.max(0, Math.min(queue.length - 1, i));
    current(queue[qIndex]);
  }
  // 手動「次」：末尾では連続(all)のときだけ先頭へ。オフ/1曲は末尾で停止（何もしない）。
  function next() {
    if (!queue.length) return;
    if (qIndex < queue.length - 1) playIndex(qIndex + 1);
    else if (repeatMode === 'all') playIndex(0);
  }
  // 手動「前」：先頭では連続(all)のときだけ末尾へ。オフ/1曲は先頭で停止。
  function prev() {
    if (!queue.length) return;
    if (qIndex > 0) playIndex(qIndex - 1);
    else if (repeatMode === 'all') playIndex(queue.length - 1);
  }
  function shufflePlay() {
    // キューをリセットしてシャッフル（絞り込み中の曲を対象）。リピート設定は変更しない。
    const base = getFiltered();
    const pool = (base.length ? base : songs).slice();
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }
    if (pool.length === 0) return;
    queue = pool;
    qIndex = 0;
    current(queue[0]);
  }
  function togglePlay() {
    if (!ytPlayer) return;
    if (isPlaying) ytPlayer.pauseVideo(); else ytPlayer.playVideo();
  }

  // ----- 再生履歴 -----
  function openHistory() {
    const list = document.getElementById('historyList');
    if (list) {
      let arr: any[] = [];
      try { arr = JSON.parse(localStorage.getItem('umyamy:history') || '[]'); } catch (_) {}
      if (arr.length === 0) {
        list.innerHTML = '<p class="text-sm text-slate-400 py-10 text-center">まだ再生履歴はありません</p>';
      } else {
        list.innerHTML = arr.map((h: any) => {
          const thumb = `https://img.youtube.com/vi/${encodeURIComponent(h.videoId)}/default.jpg`;
          return `
            <button type="button" data-hist-id="${escHtml(h.id)}" class="history-item w-full flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 text-left">
              <img src="${thumb}" alt="" class="w-12 h-12 rounded object-cover bg-slate-100 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-ink truncate">${escHtml(h.title || '')}</p>
                <p class="text-xs text-slate-400 truncate">${escHtml(h.artist || '')}</p>
              </div>
            </button>`;
        }).join('');
      }
    }
    document.getElementById('historyModal')?.classList.remove('hidden');
  }
  function closeHistory() { document.getElementById('historyModal')?.classList.add('hidden'); }
  function playById(id: string) {
    const song = songs.find((s: any) => s.id === id);
    if (song) playSong(song);
  }

  function closePlayer() {
    stopWatch();
    currentVideoId = null;
    segEnd = Infinity;
    if (ytPlayer && ytPlayer.stopVideo) ytPlayer.stopVideo();
    document.getElementById('player')?.classList.add('hidden');
    document.getElementById('playerSheet')?.classList.add('hidden');
    document.body.style.paddingBottom = '';
    markPlayingCard(null);
  }

  // ----- 新着スライダー（配信＝動画単位でまとめて新しい順） -----
  function buildStreams() {
    const map = new Map<string, any>();
    for (const s of songs) {
      const vid = s.youtube.videoId;
      let g = map.get(vid);
      if (!g) {
        g = { videoId: vid, title: s.streamTitle || s.title, date: s.streamDate || '',
              category: s.category, streamType: s.streamType || '', performers: new Set<string>(), songs: [], views: 0 };
        map.set(vid, g);
      }
      (s.performers || []).forEach((p: string) => g.performers.add(p));
      g.views = Math.max(g.views, s.youtube?.viewCount || 0);
      g.songs.push(s);
    }
    return [...map.values()]
      .map(g => ({ ...g, performers: orderPerformers([...g.performers]) }))
      .sort((a, b) => b.date.localeCompare(a.date));
  }

  // 配信カードの中身（新着スライダー／配信ビューで共用）
  function streamCardInner(g: any) {
    const performerBadges = g.performers.map((p: string) =>
      `<span class="text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChipClass(p)}">${escHtml(p)}</span>`).join('');
    const thumbUrl = `https://img.youtube.com/vi/${encodeURIComponent(g.videoId)}/mqdefault.jpg`;
    const catLabel = CAT_LABEL[g.category] || g.category;
    // ソロ/コラボ歌枠バッジは歌枠のみ（歌ってみた/ショートでは出さない）
    const typeLabel = g.category !== 'uta_waku' ? '' : (g.streamType === 'solo' ? 'ソロ歌枠' : g.streamType === 'collab' ? 'コラボ歌枠' : '');
    const typeBadge = typeLabel
      ? `<span class="absolute top-2 left-2 text-[11px] font-semibold text-white bg-slate-900/70 px-1.5 py-0.5 rounded">${typeLabel}</span>`
      : '';
    return `
      <div class="relative aspect-video bg-slate-100 overflow-hidden">
        <img src="${thumbUrl}" alt="" onerror="this.style.opacity='0.3'" class="w-full h-full object-cover block">
        ${typeBadge}
        <span class="absolute bottom-2 left-2 text-[11px] font-semibold text-white bg-slate-900/80 px-1.5 py-0.5 rounded">${escHtml(catLabel)}</span>
        <span class="absolute bottom-2 right-2 text-[11px] font-semibold text-white bg-slate-900/80 px-1.5 py-0.5 rounded">${g.songs.length}曲</span>
      </div>
      <div class="p-3">
        <p class="text-sm font-semibold text-ink leading-snug clamp-2 min-h-[2.5em]">${escHtml(g.title || '')}</p>
        <div class="flex flex-wrap items-center gap-1.5 mt-2">
          ${performerBadges}
          <span class="text-[11px] text-slate-400 ml-auto">${escHtml(g.date || '')}</span>
        </div>
      </div>`;
  }

  // 新着は直近 NEW_LIMIT 件だけ（全件は「配信」ビューで見られる）
  const NEW_LIMIT = 12;
  function renderNewSlider() {
    const slider = document.getElementById('newSlider');
    if (!slider) return;
    slider.innerHTML = buildStreams().slice(0, NEW_LIMIT).map(g =>
      `<button type="button" data-video-id="${escHtml(g.videoId)}"
               class="new-card snap-start shrink-0 w-64 card overflow-hidden text-left hover:shadow-md transition">${streamCardInner(g)}</button>`
    ).join('');
    updateSliderArrows();
  }

  // 配信ビュー: 絞り込み済みの配信一覧
  function getFilteredStreams() {
    let list = buildStreams();
    if (filterMember === 'ayane') list = list.filter((g: any) => g.performers.includes('白砂あやね'));
    else if (filterMember === 'madoka') list = list.filter((g: any) => g.performers.includes('水面まどか'));
    else if (filterMember === 'duet') list = list.filter((g: any) => g.performers.length > 1);
    if (filterCategory !== 'all') list = list.filter((g: any) => g.category === filterCategory);
    if (filterFav) list = list.filter((g: any) => g.songs.some((s: any) => favSet.has(s.id)));
    if (searchText) {
      list = list.filter((g: any) => {
        const hay = [g.title, g.date, g.performers.join(' '),
          g.songs.map((s: any) => `${s.title} ${s.artist || ''}`).join(' ')].join(' ').toLowerCase();
        return hay.includes(searchText);
      });
    }
    const sortVal = (document.getElementById('streamSort') as HTMLSelectElement)?.value || 'date_desc';
    if (sortVal === 'date_asc') list.sort((a: any, b: any) => a.date.localeCompare(b.date));
    else if (sortVal === 'views') list.sort((a: any, b: any) => (b.views || 0) - (a.views || 0));
    else list.sort((a: any, b: any) => b.date.localeCompare(a.date));
    return list;
  }

  function renderStreams() {
    const grid = document.getElementById('streamGrid');
    if (!grid) return;
    const list = getFilteredStreams();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${list.length} 配信`;
    grid.innerHTML = list.map((g: any) =>
      `<button type="button" data-video-id="${escHtml(g.videoId)}"
               class="stream-card card overflow-hidden text-left hover:shadow-md transition">${streamCardInner(g)}</button>`
    ).join('');
    document.getElementById('streamEmpty')?.classList.toggle('hidden', list.length !== 0);
  }

  function playStream(videoId: string) {
    const list = songs.filter((s: any) => s.youtube.videoId === videoId);
    if (list.length === 0) return;
    queue = list;
    qIndex = 0;
    current(queue[0]);
  }

  // ----- アーティストビュー -----
  function escHtml(s: string) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // メンバー/カテゴリ絞り込みを反映しつつ、アーティスト名で集計（曲数が多い順）
  function buildArtists() {
    const base = memberCategoryFiltered();
    const map = new Map<string, number>();
    for (const s of base) {
      const a = (s.artist || '').trim();
      if (!a) continue; // アーティスト不明はリストから除外
      map.set(a, (map.get(a) || 0) + 1);
    }
    let list = [...map.entries()].map(([name, count]) => ({ name, count }));
    if (searchText) list = list.filter(g => g.name.toLowerCase().includes(searchText));
    list.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'ja'));
    return list;
  }

  function renderArtists() {
    const grid = document.getElementById('artistGrid');
    if (!grid) return;
    const list = buildArtists();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${list.length} 組`;
    grid.innerHTML = list.map(g => `
      <button type="button" data-artist="${escHtml(g.name)}"
              class="artist-card card p-3 text-left hover:shadow-md transition">
        <p class="text-sm font-semibold text-ink truncate">${escHtml(g.name)}</p>
        <p class="text-[11px] text-slate-400 mt-0.5 tabular-nums">${g.count}曲</p>
      </button>`).join('');
    document.getElementById('artistEmpty')?.classList.toggle('hidden', list.length !== 0);
  }

  function updateSliderArrows() {
    // ループするので矢印は常に有効。スクロールできない（全件が画面内）ときだけ隠す。
    const slider = document.getElementById('newSlider');
    const prev = document.getElementById('newPrev') as HTMLButtonElement | null;
    const next = document.getElementById('newNext') as HTMLButtonElement | null;
    if (!slider || !prev || !next) return;
    const scrollable = slider.scrollWidth - slider.clientWidth > 1;
    prev.disabled = false;
    next.disabled = false;
    prev.classList.toggle('hidden', !scrollable);
    next.classList.toggle('hidden', !scrollable);
  }

  function setPressed(ids: string[], activeId: string) {
    ids.forEach(id => document.getElementById(id)?.setAttribute('aria-pressed', String(id === activeId)));
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (songs.length > 0) renderNewSlider();

    // 初期表示も段階表示にする（先頭 PAGE_SIZE 件のみ）
    applyDisplay();
    document.getElementById('loadMoreBtn')?.addEventListener('click', loadMore);

    // 新着スライダー操作
    const slider = document.getElementById('newSlider');
    // 端まで来たら反対側へループ（末尾で「次」→先頭、先頭で「前」→末尾）
    const scrollByCard = (dir: number) => {
      if (!slider) return;
      const max = slider.scrollWidth - slider.clientWidth;
      const step = slider.clientWidth * 0.8;
      let target = slider.scrollLeft + dir * step;
      if (dir > 0 && slider.scrollLeft >= max - 1) target = 0;
      else if (dir < 0 && slider.scrollLeft <= 1) target = max;
      slider.scrollTo({ left: target, behavior: 'smooth' });
    };
    document.getElementById('newPrev')?.addEventListener('click', () => scrollByCard(-1));
    document.getElementById('newNext')?.addEventListener('click', () => scrollByCard(1));
    slider?.addEventListener('scroll', updateSliderArrows, { passive: true });
    window.addEventListener('resize', updateSliderArrows);
    slider?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.new-card');
      const vid = btn?.getAttribute('data-video-id');
      if (vid) playStream(vid);
    });

    document.getElementById('searchInput')?.addEventListener('input', filterSongs);
    document.getElementById('clearSearch')?.addEventListener('click', clearSearch);
    document.getElementById('resetSearchBtn')?.addEventListener('click', clearSearch);
    document.getElementById('closePlayerBtn')?.addEventListener('click', closePlayer);

    // 共有コントロール（下部バー＋展開シート）
    const on = (sel: string, fn: () => void) =>
      document.querySelectorAll(sel).forEach(el => el.addEventListener('click', fn));
    on('.ctl-play', togglePlay);
    on('.ctl-prev', prev);
    on('.ctl-next', next);
    on('.ctl-shuffle', shufflePlay);
    on('.ctl-repeat', cycleRepeat);
    on('.ctl-mute', toggleMute);
    document.querySelectorAll('.volume-slider').forEach(el =>
      el.addEventListener('input', (e) => setVolume(Number((e.target as HTMLInputElement).value))));

    // 曲内シークバー（ミニバー＋展開シート共通）: ドラッグ中はバー位置を固定し、確定時にシーク
    document.querySelectorAll('.seek-range').forEach(el => {
      const bar = el as HTMLInputElement;
      bar.addEventListener('input', () => {
        isSeeking = true;
        const ratio = Number(bar.value) / 1000;
        const dur = Math.max(0, effectiveEnd() - segStart);
        // 全シークバー・経過表示を同期（プレビュー）
        document.querySelectorAll('.seek-range').forEach(o => ((o as HTMLInputElement).value = bar.value));
        document.querySelectorAll('.seek-cur').forEach(o => (o.textContent = fmtClock(ratio * dur)));
      });
      bar.addEventListener('change', () => { seekToRatio(Number(bar.value) / 1000); isSeeking = false; });
    });

    const openSheet = () => { document.getElementById('playerSheet')?.classList.remove('hidden'); renderUpNext(); };
    const closeSheet = () => document.getElementById('playerSheet')?.classList.add('hidden');
    document.getElementById('barExpand')?.addEventListener('click', openSheet);
    document.getElementById('barHandle')?.addEventListener('click', openSheet);
    document.getElementById('collapseBtn')?.addEventListener('click', closeSheet);
    document.getElementById('sheetBackdrop')?.addEventListener('click', closeSheet);

    updateRepeatUI();
    updateVolumeUI();

    // 次の曲リスト → クリックでジャンプ
    document.getElementById('upNext')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.upnext-item');
      const idx = btn?.getAttribute('data-qindex');
      if (idx !== null && idx !== undefined) playIndex(Number(idx));
    });

    // 再生履歴
    document.getElementById('historyBtn')?.addEventListener('click', openHistory);
    document.getElementById('historyClose')?.addEventListener('click', closeHistory);
    document.getElementById('historyBackdrop')?.addEventListener('click', closeHistory);
    document.getElementById('historyList')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.history-item');
      const id = btn?.getAttribute('data-hist-id');
      if (id) { closeHistory(); playById(id); }
    });

    // ===== プレイリスト =====
    setupMediaSession();
    document.getElementById('playlistBtn')?.addEventListener('click', openPlModal);
    document.getElementById('plClose')?.addEventListener('click', closePlModal);
    document.getElementById('plBackdrop')?.addEventListener('click', closePlModal);
    document.getElementById('plBack')?.addEventListener('click', showPlList);

    // 一覧画面: 作成・詳細へ
    const createFromInput = () => {
      const input = document.getElementById('plNewName') as HTMLInputElement | null;
      const name = input?.value.trim();
      if (!name) { input?.focus(); return; }
      const pl = createPlaylist(name);
      if (input) input.value = '';
      showPlDetail(pl.id);
    };
    document.getElementById('plCreate')?.addEventListener('click', createFromInput);
    document.getElementById('plNewName')?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') createFromInput();
    });
    document.getElementById('plList')?.addEventListener('click', (e) => {
      const row = (e.target as HTMLElement).closest('.pl-row');
      const id = row?.getAttribute('data-pl-id');
      if (id) showPlDetail(id);
    });

    // 一覧画面: プレイリストの書き出し／取り込み
    document.getElementById('plExport')?.addEventListener('click', exportPlaylists);
    document.getElementById('plImport')?.addEventListener('click', () => document.getElementById('plFile')?.click());
    document.getElementById('plFile')?.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const file = input.files?.[0];
      if (file) importPlaylists(file);
      input.value = ''; // 同じファイルを連続で選び直せるようにリセット
    });

    // 詳細画面: 名前変更・再生・共有・削除・曲操作
    document.getElementById('plRename')?.addEventListener('change', (e) => {
      const pl = plFind(plCurrentId);
      if (!pl) return;
      const input = e.target as HTMLInputElement;
      const v = input.value.trim();
      if (v) { pl.name = v.slice(0, 40); pl.updatedAt = Date.now(); savePlaylists(); }
      else input.value = pl.name;
    });
    document.getElementById('plPlay')?.addEventListener('click', () => {
      const pl = plFind(plCurrentId); if (pl) playPlaylist(pl);
    });
    document.getElementById('plShuffle')?.addEventListener('click', () => {
      const pl = plFind(plCurrentId); if (pl) playPlaylist(pl, 0, true);
    });
    document.getElementById('plCopyLink')?.addEventListener('click', async () => {
      const pl = plFind(plCurrentId); if (!pl) return;
      if (!pl.ids.length) { setPlMsg('曲が無いため共有できません', true); return; }
      const ok = await copyText(playlistShareUrl(pl.name, pl.ids));
      setPlMsg(ok ? '共有リンクをコピーしました' : 'コピーに失敗しました', !ok);
    });
    document.getElementById('plShareX')?.addEventListener('click', () => {
      const pl = plFind(plCurrentId); if (!pl) return;
      if (!pl.ids.length) { setPlMsg('曲が無いため共有できません', true); return; }
      const text = `うみゃみーMusic プレイリスト「${pl.name}」（${pl.ids.length}曲）`;
      const intent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`
        + `&url=${encodeURIComponent(playlistShareUrl(pl.name, pl.ids))}`;
      window.open(intent, '_blank', 'noopener,noreferrer');
    });
    document.getElementById('plDelete')?.addEventListener('click', () => {
      const pl = plFind(plCurrentId); if (!pl) return;
      if (!window.confirm(`プレイリスト「${pl.name}」を削除しますか？`)) return;
      playlists = playlists.filter(p => p.id !== pl.id);
      savePlaylists();
      showPlList();
    });
    document.getElementById('plSongs')?.addEventListener('click', (e) => {
      const pl = plFind(plCurrentId); if (!pl) return;
      const actBtn = (e.target as HTMLElement).closest('[data-act]');
      const row = (e.target as HTMLElement).closest('.pl-song');
      if (!actBtn || !row) return;
      const idx = Number(row.getAttribute('data-idx'));
      const act = actBtn.getAttribute('data-act');
      if (act === 'play') { playPlaylist(pl, idx); return; }
      if (act === 'up' && idx > 0) {
        [pl.ids[idx - 1], pl.ids[idx]] = [pl.ids[idx], pl.ids[idx - 1]];
      } else if (act === 'down' && idx < pl.ids.length - 1) {
        [pl.ids[idx + 1], pl.ids[idx]] = [pl.ids[idx], pl.ids[idx + 1]];
      } else if (act === 'remove') {
        pl.ids.splice(idx, 1);
      } else return;
      pl.updatedAt = Date.now();
      savePlaylists();
      renderPlDetail();
    });

    // 「プレイリストに追加」モーダル
    document.getElementById('plAddClose')?.addEventListener('click', () => hide('plAddModal'));
    document.getElementById('plAddBackdrop')?.addEventListener('click', () => hide('plAddModal'));
    document.getElementById('plAddList')?.addEventListener('click', (e) => {
      const row = (e.target as HTMLElement).closest('[data-pl-id]');
      const id = row?.getAttribute('data-pl-id');
      if (id) togglePlAdd(id);
    });
    const addCreate = () => {
      const input = document.getElementById('plAddNewName') as HTMLInputElement | null;
      const name = input?.value.trim();
      if (!name) { input?.focus(); return; }
      const pl = createPlaylist(name);
      if (plAddTargetId) { pl.ids.push(plAddTargetId); savePlaylists(); }
      if (input) input.value = '';
      renderPlAddList();
    };
    document.getElementById('plAddCreate')?.addEventListener('click', addCreate);
    document.getElementById('plAddNewName')?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') addCreate();
    });
    document.getElementById('sheetAdd')?.addEventListener('click', () => {
      if (nowPlaying) openPlAdd(nowPlaying.id);
    });

    // 共有されたプレイリストの受け取り
    document.getElementById('plSharedClose')?.addEventListener('click', () => hide('plSharedModal'));
    document.getElementById('plSharedBackdrop')?.addEventListener('click', () => hide('plSharedModal'));
    document.getElementById('plSharedPlay')?.addEventListener('click', () => playShared(0));
    document.getElementById('plSharedSongs')?.addEventListener('click', (e) => {
      const row = (e.target as HTMLElement).closest('.pl-shared-row');
      if (row) playShared(Number(row.getAttribute('data-idx') || 0));
    });
    document.getElementById('plSharedSave')?.addEventListener('click', () => {
      if (!plShared) return;
      const pl = createPlaylist(plShared.name);
      pl.ids = [...plShared.ids];
      savePlaylists();
      const msg = document.getElementById('plSharedMsg');
      if (msg) msg.textContent = `「${pl.name}」として保存しました`;
    });
    checkSharedPlaylist();

    // Esc でプレイリスト系モーダルを閉じる
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closePlModal(); hide('plAddModal'); hide('plSharedModal'); }
    });

    const memberIds = ['btn-m-all', 'btn-m-madoka', 'btn-m-ayane', 'btn-m-duet'];
    const memberVal: Record<string, string> = { 'btn-m-all': 'all', 'btn-m-madoka': 'madoka', 'btn-m-ayane': 'ayane', 'btn-m-duet': 'duet' };
    memberIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterMember = memberVal[id]; setPressed(memberIds, id); filterSongs();
    }));

    const catIds = ['btn-c-all', 'btn-c-uta_waku', 'btn-c-cover', 'btn-c-short'];
    const catVal: Record<string, string> = { 'btn-c-all': 'all', 'btn-c-uta_waku': 'uta_waku', 'btn-c-cover': 'cover', 'btn-c-short': 'short' };
    catIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterCategory = catVal[id]; setPressed(catIds, id); filterSongs();
    }));

    // お気に入りで絞り込み（トグル）
    document.getElementById('btn-fav')?.addEventListener('click', () => {
      filterFav = !filterFav;
      document.getElementById('btn-fav')?.setAttribute('aria-pressed', String(filterFav));
      filterSongs();
    });
    // 展開シートの★（再生中の曲をお気に入り切替）
    document.getElementById('sheetFav')?.addEventListener('click', () => {
      if (nowPlaying) toggleFav(nowPlaying.id);
    });
    // お気に入りの書き出し／取り込み
    document.getElementById('favExport')?.addEventListener('click', exportFavorites);
    document.getElementById('favImport')?.addEventListener('click', () => document.getElementById('favFile')?.click());
    document.getElementById('favFile')?.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const file = input.files?.[0];
      if (file) importFavorites(file);
      input.value = ''; // 同じファイルを連続で選び直せるようにリセット
    });
    // 永続化された状態をカードに反映
    refreshFavUI();

    document.getElementById('songGrid')?.addEventListener('click', (e) => {
      // ★ボタンが押されたら再生せずお気に入り切替
      const fav = (e.target as HTMLElement).closest('.card-fav');
      if (fav) { const fid = fav.getAttribute('data-id'); if (fid) toggleFav(fid); return; }
      // ＋ボタンが押されたら再生せず「プレイリストに追加」
      const add = (e.target as HTMLElement).closest('.card-add');
      if (add) { const aid = add.getAttribute('data-id'); if (aid) openPlAdd(aid); return; }
      // 共有ボタンが押されたら再生せず共有
      const share = (e.target as HTMLElement).closest('.card-share');
      if (share) {
        const sid = share.getAttribute('data-id');
        const ss = sid ? songs.find((s: any) => s.id === sid) : null;
        if (ss) shareSong(ss);
        return;
      }
      const card = (e.target as HTMLElement).closest('.song-card-item');
      const id = card?.getAttribute('data-id');
      const song = id ? songs.find((s: any) => s.id === id) : null;
      if (song) playSong(song);
    });

    // プレーヤー（展開シート）の共有ボタン
    document.getElementById('sheetShare')?.addEventListener('click', () => shareSong(nowPlaying));

    // ビュー切替（曲 / 配信 / アーティスト）。タブを直接押したらアーティスト絞り込みは解除
    document.getElementById('view-songs')?.addEventListener('click', () => { filterArtist = null; setView('songs'); });
    document.getElementById('view-streams')?.addEventListener('click', () => { filterArtist = null; setView('streams'); });
    document.getElementById('view-artists')?.addEventListener('click', () => { filterArtist = null; setView('artists'); });
    document.getElementById('streamSort')?.addEventListener('change', renderStreams);

    // 配信カードをクリック → その配信まるごと再生キューへ
    document.getElementById('streamGrid')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.stream-card');
      const vid = btn?.getAttribute('data-video-id');
      if (vid) playStream(vid);
    });

    // アーティストをクリック → そのアーティストの曲に絞り込み（曲ビューへ）
    document.getElementById('artistGrid')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.artist-card');
      const a = btn?.getAttribute('data-artist');
      if (a) { filterArtist = a; setView('songs'); }
    });
    // アーティスト絞り込みの解除
    document.getElementById('artistClear')?.addEventListener('click', () => {
      filterArtist = null; updateArtistChip(); shownCount = PAGE_SIZE; applyDisplay();
    });
  });
</script>

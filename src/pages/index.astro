---
import BaseLayout from '../layouts/BaseLayout.astro';
import SongCard from '../components/SongCard.astro';
import SiteFooter from '../components/SiteFooter.astro';
import songsData from '../../public/data/songs.json';

// Build-time calculation of statistics
const { songs } = songsData;
const totalSongs = songs.length;
const utaWakuCount = songs.filter(s => s.category === 'uta_waku').length;
const coverCount = songs.filter(s => s.category === 'cover').length;
const unitCount = songs.filter(s => s.category === 'unit_cover').length;
const lastUpdated = songsData.updatedAt;
---

<BaseLayout title="うみゃみーMusic（非公式ファンサイト）">
  <!-- Stats bar -->
  <div class="max-w-6xl mx-auto px-4 -mt-4 z-10 relative">
    <div class="bg-white/80 backdrop-blur-md border-2 border-sky-100 rounded-3xl p-4 shadow-cute flex flex-wrap items-center justify-around gap-4 text-center">
      <div class="flex-1 min-w-[80px]">
        <div class="text-2xl font-black text-sky-500 font-mono">{totalSongs}</div>
        <div class="text-slate-500 text-xs font-bold mt-0.5">🍭 総曲数</div>
      </div>
      <div class="w-px h-8 bg-sky-100 hidden sm:block"></div>
      <div class="flex-1 min-w-[80px]">
        <div class="text-2xl font-black text-sky-400 font-mono">{utaWakuCount}</div>
        <div class="text-slate-500 text-xs font-bold mt-0.5">🎤 歌枠</div>
      </div>
      <div class="w-px h-8 bg-sky-100 hidden sm:block"></div>
      <div class="flex-1 min-w-[80px]">
        <div class="text-2xl font-black text-purple-400 font-mono">{coverCount}</div>
        <div class="text-slate-500 text-xs font-bold mt-0.5">🎵 歌ってみた</div>
      </div>
      <div class="w-px h-8 bg-sky-100 hidden sm:block"></div>
      <div class="flex-1 min-w-[80px]">
        <div class="text-2xl font-black text-emerald-400 font-mono">{unitCount}</div>
        <div class="text-slate-500 text-xs font-bold mt-0.5">💫 Unit</div>
      </div>
      <div class="w-full sm:w-auto text-right text-slate-400 text-[11px] border-t sm:border-t-0 pt-2 sm:pt-0 sm:pl-4">
        <div>最終更新 🎀 <span class="font-bold text-slate-600">{lastUpdated}</span></div>
      </div>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 py-8 flex-1 w-full" id="songs">

    <!-- Featured / Random pick -->
    <section id="featuredSection" class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-extrabold text-slate-800 flex items-center gap-1.5">
          <span class="text-2xl">🎲</span> 今日のピックアップ！
        </h2>
        <button id="shuffleBtn"
                class="flex items-center gap-1.5 text-xs font-bold text-white bg-gradient-to-r from-sky-400 to-purple-400 px-4 py-2 rounded-full shadow-cute hover:shadow-cute-hover active:scale-95 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                  d="M4 4h5l2 3m9 13h-5l-2-3m7-13l-3 3m3-3v3m0 0h-3M4 20l3-3m-3 3v-3m0 0h3"/>
          </svg>
          別の曲をえらぶ
        </button>
      </div>
      <div id="featuredCard"
           class="featured-card rounded-3xl shadow-cute border overflow-hidden cursor-pointer hover:shadow-cute-hover transition-all duration-300">
        <!-- filled by renderFeatured() on client side -->
      </div>
    </section>

    <!-- Inline Player -->
    <div id="playerSection" class="hidden mb-8">
      <div class="bg-white/95 backdrop-blur-md rounded-3xl shadow-cute border-2 border-purple-100 overflow-hidden">
        <!-- Player header -->
        <div class="flex items-center justify-between p-5 pb-3 border-b border-purple-50 bg-purple-50/30">
          <div class="flex items-center gap-3 min-w-0">
            <span class="inline-flex w-3 h-3 rounded-full bg-rose-400 animate-ping"></span>
            <div class="min-w-0">
              <span class="text-[10px] text-rose-500 font-extrabold uppercase tracking-widest bg-rose-50 px-2 py-0.5 rounded-full border border-rose-100">Now Singing 🫧</span>
              <h2 id="playerTitle" class="font-extrabold text-slate-800 text-lg leading-snug truncate mt-1">—</h2>
              <p id="playerMeta" class="text-xs text-slate-400 truncate mt-0.5">—</p>
            </div>
          </div>
          <button id="closePlayerBtn"
            class="flex-shrink-0 text-slate-400 hover:text-slate-700 hover:bg-slate-100 p-2 rounded-2xl transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <!-- Video -->
        <div class="p-4 bg-purple-50/10">
          <div class="player-wrap shadow-inner">
            <iframe id="ytPlayer" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
        <!-- Player footer -->
        <div class="px-5 py-3 bg-purple-50/30 border-t border-purple-50 flex items-center justify-between text-xs text-slate-500">
          <span id="playerDate" class="font-bold bg-white px-3 py-1 rounded-full border border-purple-100">—</span>
          <span id="playerTags" class="flex gap-1.5 flex-wrap"></span>
        </div>
      </div>
    </div>

    <!-- Search & Filter -->
    <div class="bg-white/80 backdrop-blur-md rounded-3xl shadow-cute border-2 border-sky-50 p-6 mb-8" id="searchArea">
      <!-- Search input -->
      <div class="relative mb-5">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-xl pointer-events-none">🔍</span>
        <input type="text" id="searchInput"
               placeholder="曲名・アーティスト・ハッシュタグで検索するよ..."
               class="w-full pl-12 pr-12 py-3.5 border-2 border-sky-100 bg-sky-50/10 rounded-2xl text-sm focus:outline-none focus:border-sky-300 focus:bg-white transition-all font-medium">
        <button id="clearSearch"
                class="hidden absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 bg-slate-100 hover:bg-slate-200 p-1.5 rounded-full transition">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Filter buttons -->
      <div class="flex flex-col gap-4">
        <!-- Members Filter -->
        <div class="flex flex-wrap gap-2 items-center text-sm">
          <span class="text-xs text-slate-400 font-bold tracking-wider mr-2">🩵 メンバー:</span>
          <button id="btn-m-all"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-200 bg-sky-400 text-white font-bold shadow-md shadow-sky-100">
            ふたりとも！
          </button>
          <button id="btn-m-ayane"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600 hover:text-sky-500 hover:border-sky-300">
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-sky-400 mr-1.5"></span>白砂あやね
          </button>
          <button id="btn-m-madoka"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600 hover:text-purple-500 hover:border-purple-300">
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-purple-400 mr-1.5"></span>水面まどか
          </button>
        </div>

        <hr class="border-sky-50/50">

        <!-- Categories Filter -->
        <div class="flex flex-wrap gap-2 items-center text-sm">
          <span class="text-xs text-slate-400 font-bold tracking-wider mr-2">🎵 カテゴリ:</span>
          <button id="btn-c-all"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-200 bg-sky-400 text-white font-bold shadow-md shadow-sky-100">
            ぜんぶ
          </button>
          <button id="btn-c-uta_waku"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600">
            🎤 歌枠
          </button>
          <button id="btn-c-cover"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600">
            🎬 歌ってみた
          </button>
          <button id="btn-c-unit_cover"
                  class="filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600">
            💫 ユニット曲
          </button>

          <!-- Result Count badge -->
          <span id="resultCount" class="ml-auto text-xs font-bold text-sky-600 bg-sky-50 px-3 py-1.5 rounded-full border border-sky-100">
            みつかった曲: {totalSongs} 曲
          </span>
        </div>
      </div>
    </div>

    <!-- Song Grid -->
    <div id="songGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {songs.map(song => (
        <SongCard song={song} />
      ))}
    </div>

    <!-- Empty state -->
    <div id="emptyState" class="hidden py-20 text-center bg-white/50 backdrop-blur-md rounded-3xl border-2 border-dashed border-sky-200">
      <div class="text-6xl mb-4 animate-bounce">💦</div>
      <p class="font-extrabold text-slate-600 text-lg">「<span id="emptyQuery" class="text-rose-400"></span>」に合う曲が見つからなかったよ</p>
      <p class="text-slate-400 text-xs mt-1">ちがうワードで検索してみてね！</p>
      <button id="resetSearchBtn" class="mt-4 px-5 py-2 font-bold text-white bg-sky-400 hover:bg-sky-500 rounded-full shadow transition">検索をリセットする</button>
    </div>

  </main>

  <!-- Pass data to client-side script -->
  <div id="songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>

  <SiteFooter />
</BaseLayout>

<style>
  .featured-card {
    background: linear-gradient(135deg, #bae6fd 0%, #f3e8ff 100%);
    border: 3px solid #e0f2fe;
    position: relative;
  }
  
  @keyframes featured-pop {
    0%   { opacity: 0; transform: scale(0.96); }
    100% { opacity: 1; transform: scale(1); }
  }
  
  :global(.featured-anim) {
    animation: featured-pop 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .player-wrap { 
    aspect-ratio: 16/9; 
    background: #faf5ff; 
    border-radius: 1.5rem; 
    overflow: hidden; 
    border: 4px solid #f3e8ff; 
  }
  .player-wrap iframe { 
    width: 100%; 
    height: 100%; 
    border: none; 
    display: block; 
  }
</style>

<script>
  import Fuse from 'fuse.js';

  // State
  let filterMember = 'all';
  let filterCategory = 'all';
  let searchText = '';
  let playingId: string | null = null;
  let featuredId: string | null = null;

  // Retrieve songs data
  const songsDataEl = document.getElementById('songs-data');
  const songs = songsDataEl ? JSON.parse(songsDataEl.getAttribute('data-songs') || '[]') : [];

  // Initialize Fuse.js
  const fuseOptions = {
    keys: ['title', 'artist', 'tags'],
    threshold: 0.3
  };
  const fuse = new Fuse(songs, fuseOptions);

  const CAT_LABEL: Record<string, string> = { 
    uta_waku: '🎤 歌枠', 
    cover: '🎬 歌ってみた', 
    unit_cover: '💫 ユニット曲', 
    short: '📱 ショート' 
  };

  // Helper functions
  function getBorderClass(performers: string[]) {
    if (performers.length > 1) return 'member-both-border';
    if (performers.includes('白砂あやね')) return 'member-ayane-border';
    if (performers.includes('水面まどか')) return 'member-madoka-border';
    return '';
  }

  function fmtTs(sec?: number) {
    if (!sec && sec !== 0) return null;
    if (sec === 0) return null;
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = sec % 60;
    return h > 0
      ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
      : `${m}:${String(s).padStart(2,'0')}`;
  }

  function filterSongs() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    searchText = searchInput ? searchInput.value.trim().toLowerCase() : '';
    
    const clearSearchBtn = document.getElementById('clearSearch');
    if (clearSearchBtn) {
      clearSearchBtn.classList.toggle('hidden', !searchText);
    }

    let filtered = songs;

    if (filterMember === 'ayane') {
      filtered = filtered.filter((s: any) => s.performers.includes('白砂あやね'));
    } else if (filterMember === 'madoka') {
      filtered = filtered.filter((s: any) => s.performers.includes('水面まどか'));
    }

    if (filterCategory !== 'all') {
      filtered = filtered.filter((s: any) => s.category === filterCategory);
    }

    if (searchText) {
      const searchResults = fuse.search(searchText);
      const matchedIds = new Set(searchResults.map(r => r.item.id));
      filtered = filtered.filter((s: any) => matchedIds.has(s.id));
    }

    const matchedIds = new Set(filtered.map((s: any) => s.id));

    // Update song card visibility in DOM
    const cards = document.querySelectorAll('.song-card-item');
    cards.forEach(card => {
      const id = card.getAttribute('data-id');
      const isMatch = matchedIds.has(id);
      card.classList.toggle('hidden', !isMatch);
    });

    const countEl = document.getElementById('resultCount');
    if (countEl) {
      countEl.textContent = `みつかった曲: ${filtered.length} 曲`;
    }

    const emptyState = document.getElementById('emptyState');
    const emptyQuery = document.getElementById('emptyQuery');
    if (filtered.length === 0) {
      if (emptyState) emptyState.classList.remove('hidden');
      if (emptyQuery) emptyQuery.textContent = searchText;
    } else {
      if (emptyState) emptyState.classList.add('hidden');
    }
  }

  function clearSearch() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    filterSongs();
  }

  function playVideo(song: any) {
    playingId = song.id;
    filterSongs(); // refresh search state to update cards

    // Update is-playing classes on all cards
    const cards = document.querySelectorAll('.song-card-item');
    cards.forEach(card => {
      const id = card.getAttribute('data-id');
      const isPlaying = id === playingId;
      card.classList.toggle('is-playing', isPlaying);
      
      const playingBadge = card.querySelector('.playing-badge');
      const standardTs = card.querySelector('.ts-badge:not(.playing-badge)');
      if (playingBadge && standardTs) {
        playingBadge.classList.toggle('hidden', !isPlaying);
        standardTs.classList.toggle('hidden', isPlaying);
      }
    });

    // Update Player UI
    const section = document.getElementById('playerSection');
    const iframe = document.getElementById('ytPlayer') as HTMLIFrameElement;
    const title = document.getElementById('playerTitle');
    const meta = document.getElementById('playerMeta');
    const date = document.getElementById('playerDate');
    const tagsEl = document.getElementById('playerTags');

    if (title) title.textContent = song.title;
    if (meta) meta.textContent = `${song.artist}${song.streamTitle ? ' — ' + song.streamTitle : ''}`;
    if (date) date.textContent = `配信日: ${song.streamDate}`;

    if (tagsEl) {
      const tags = (song.tags || []).map((t: string) =>
        `<span class="bg-white border border-purple-100 text-purple-500 px-3 py-1 rounded-full text-xs font-bold shadow-sm">#${t}</span>`
      ).join('');
      tagsEl.innerHTML = tags;
    }

    if (iframe) {
      const start = song.youtube.timestampSec || 0;
      const src = `https://www.youtube.com/embed/${song.youtube.videoId}?start=${start}&autoplay=1&rel=0&enablejsapi=1`;
      iframe.src = src;
    }

    if (section) section.classList.remove('hidden');

    // Scroll to player
    const target = document.getElementById('searchArea');
    if (target) {
      const yOffset = -120;
      const y = target.getBoundingClientRect().top + window.pageYOffset + yOffset;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  }

  function closePlayer() {
    const iframe = document.getElementById('ytPlayer') as HTMLIFrameElement;
    if (iframe) iframe.src = '';
    
    const section = document.getElementById('playerSection');
    if (section) section.classList.add('hidden');
    
    playingId = null;
    filterSongs();
  }

  function pickRandomSong(excludeId: string | null) {
    const pool = songs.length > 1 ? songs.filter((s: any) => s.id !== excludeId) : songs;
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function renderFeatured(song: any, animate: boolean) {
    featuredId = song.id;
    const ts = fmtTs(song.youtube.timestampSec);
    
    const performerBadges = song.performers.map((p: string) => {
      const isAyane = p === '白砂あやね';
      return `<span class="tag text-xs px-3 py-1 rounded-full font-bold ${isAyane ? 'bg-sky-100 text-sky-700' : 'bg-purple-100 text-purple-700'}">${p}</span>`;
    }).join('');

    const card = document.getElementById('featuredCard');
    if (card) {
      card.onclick = () => playVideo(song);
      const catLabel = CAT_LABEL[song.category] || song.category;
      const thumbUrl = `https://img.youtube.com/vi/${song.youtube.videoId}/mqdefault.jpg`;
      
      card.innerHTML = `
        <div class="flex flex-col md:flex-row p-6 items-center gap-6">
          <div class="featured-thumb w-full md:w-2/5 flex-shrink-0 relative overflow-hidden rounded-2xl border-4 border-white shadow-md">
            <img src="${thumbUrl}" alt="${song.title}" onerror="this.style.opacity='0.3'" class="w-full h-full object-cover block">
            <div class="play-overlay absolute inset-0 flex items-center justify-center bg-sky-300/15 backdrop-blur-[1px] transition-all">
              <div class="play-btn bg-[#ff9ebb] border-3 border-white rounded-full w-12 h-12 flex items-center justify-center shadow-md">
                <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            ${ts ? `<span class="ts-badge absolute bottom-2 right-2 bg-white/90 border border-sky-200 text-sky-700 font-bold text-xs px-2 py-0.5 rounded-full">${ts}</span>` : ''}
          </div>
          <div class="flex flex-col justify-center min-w-0 flex-1 text-center md:text-left">
            <span class="inline-flex items-center gap-1 text-[11px] font-bold text-sky-600 bg-white border border-sky-200 px-3 py-1 rounded-full self-center md:self-start mb-2.5">
              ${catLabel}
            </span>
            <h3 class="text-xl sm:text-2xl font-black text-slate-800 leading-snug">${song.title}</h3>
            <p class="text-slate-400 font-bold text-sm mt-1">原曲: ${song.artist}</p>
            <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mt-4">
              ${performerBadges}
              <span class="text-xs font-bold text-slate-400 ml-2">📅 ${song.streamDate}</span>
            </div>
          </div>
        </div>
      `;

      if (animate) {
        card.classList.remove('featured-anim');
        void card.offsetWidth; // trigger reflow
        card.classList.add('featured-anim');
      }
    }
  }

  function shuffleFeatured() {
    renderFeatured(pickRandomSong(featuredId), true);
  }

  // Setup Event Listeners
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initial Pickup Render
    if (songs.length > 0) {
      renderFeatured(pickRandomSong(null), false);
    }

    // 2. Search Box Input
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', filterSongs);
    }

    // 3. Clear Search Button
    const clearSearchBtn = document.getElementById('clearSearch');
    if (clearSearchBtn) {
      clearSearchBtn.addEventListener('click', clearSearch);
    }

    // 4. Reset Search Button (Empty State)
    const resetSearchBtn = document.getElementById('resetSearchBtn');
    if (resetSearchBtn) {
      resetSearchBtn.addEventListener('click', clearSearch);
    }

    // 5. Shuffle Button
    const shuffleBtn = document.getElementById('shuffleBtn');
    if (shuffleBtn) {
      shuffleBtn.addEventListener('click', shuffleFeatured);
    }

    // 6. Close Player Button
    const closePlayerBtn = document.getElementById('closePlayerBtn');
    if (closePlayerBtn) {
      closePlayerBtn.addEventListener('click', closePlayer);
    }

    // 7. Member Filter Buttons
    const btnMAll = document.getElementById('btn-m-all');
    const btnMAyane = document.getElementById('btn-m-ayane');
    const btnMMadoka = document.getElementById('btn-m-madoka');

    function updateMemberFilter(val: string) {
      filterMember = val;
      
      // Reset all classes
      [btnMAll, btnMAyane, btnMMadoka].forEach(btn => {
        if (btn) btn.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600 hover:text-sky-500 hover:border-sky-300";
      });

      if (val === 'all' && btnMAll) {
        btnMAll.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-200 bg-sky-400 text-white font-bold shadow-md shadow-sky-100";
      } else if (val === 'ayane' && btnMAyane) {
        btnMAyane.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-300 bg-sky-400 text-white font-bold shadow-md shadow-sky-100";
      } else if (val === 'madoka' && btnMMadoka) {
        btnMMadoka.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-purple-300 bg-purple-400 text-white font-bold shadow-md shadow-purple-100 madoka-active";
      }
      
      filterSongs();
    }

    if (btnMAll) btnMAll.addEventListener('click', () => updateMemberFilter('all'));
    if (btnMAyane) btnMAyane.addEventListener('click', () => updateMemberFilter('ayane'));
    if (btnMMadoka) btnMMadoka.addEventListener('click', () => updateMemberFilter('madoka'));

    // 8. Category Filter Buttons
    const btnCAll = document.getElementById('btn-c-all');
    const btnCUtaWaku = document.getElementById('btn-c-uta_waku');
    const btnCCover = document.getElementById('btn-c-cover');
    const btnCUnitCover = document.getElementById('btn-c-unit_cover');

    function updateCategoryFilter(val: string) {
      filterCategory = val;

      [btnCAll, btnCUtaWaku, btnCCover, btnCUnitCover].forEach(btn => {
        if (btn) btn.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-100 bg-white font-bold text-slate-600 hover:text-sky-500 hover:border-sky-300";
      });

      const btn = document.getElementById(`btn-c-${val}`);
      if (btn) {
        btn.className = "filter-btn text-xs px-4 py-2 rounded-full border-2 border-sky-200 bg-sky-400 text-white font-bold shadow-md shadow-sky-100";
      }

      filterSongs();
    }

    if (btnCAll) btnCAll.addEventListener('click', () => updateCategoryFilter('all'));
    if (btnCUtaWaku) btnCUtaWaku.addEventListener('click', () => updateCategoryFilter('uta_waku'));
    if (btnCCover) btnCCover.addEventListener('click', () => updateCategoryFilter('cover'));
    if (btnCUnitCover) btnCUnitCover.addEventListener('click', () => updateCategoryFilter('unit_cover'));

    // 9. Card click event delegation
    const grid = document.getElementById('songGrid');
    if (grid) {
      grid.addEventListener('click', (e) => {
        const card = (e.target as HTMLElement).closest('.song-card-item');
        if (card) {
          const songJson = card.getAttribute('data-song');
          if (songJson) {
            playVideo(JSON.parse(songJson));
          }
        }
      });
    }
  });
</script>

  :global(.card-share:hover) { background: rgba(15,23,42,.85); transform: scale(1.08); }
  :global(.card-add) { position: absolute; top: 52px; right: 6px; z-index: 10; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; background: rgba(15,23,42,.55); color: #fff; transition: background .2s, transform .2s; }
  :global(.card-add:hover) { background: rgba(15,23,42,.85); transform: scale(1.08); }
  :global(.card-fav) { position: absolute; top: 6px; left: 6px; z-index: 10; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; background: rgba(15,23,42,.55); color: #fff; transition: background .2s, transform .2s, color .2s; }
  :global(.card-fav:hover) { background: rgba(15,23,42,.85); transform: scale(1.08); }
  :global(.card-fav.is-fav) { color: #fbbf24; }
  :global(.card-fav.is-fav svg) { fill: #fbbf24; }

  /* お気に入り（絞り込みチップ／シート星）のアクティブ表示 */
  #btn-fav[aria-pressed="true"] { color: #b45309; border-color: #fbbf24; background: #fffbeb; }
  #btn-fav[aria-pressed="true"] svg { fill: #fbbf24; }

          <span id="plIoMsg" class="text-[11px] font-medium text-slate-400" role="status" aria-live="polite"></span>
          <input id="plFile" type="file" accept="application/json,.json" class="hidden">
        </div>
        <div id="plList" class="overflow-y-auto p-2"></div>
      </div>

      <!-- 詳細画面 -->
      <div id="plDetailView" class="hidden flex-col min-h-0">
        <div class="p-3 border-b border-slate-100 space-y-2 shrink-0">
          <input id="plRename" type="text" maxlength="40" aria-label="プレイリスト名"
                 class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm font-semibold bg-white focus:outline-none focus:border-slate-400 transition">
          <div class="flex flex-wrap items-center gap-1.5">
            <button id="plPlay" type="button" class="chip text-xs">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>再生
            </button>
            <button id="plShuffle" type="button" class="chip text-xs">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h4c2 0 4-1.2 6-6s4-6 6-6h4"/><path d="m18 2 4 4-4 4"/><path d="M2 6h4c2 0 4 1.2 6 6s4 6 6 6h4"/><path d="m18 14 4 4-4 4"/></svg>シャッフル
            </button>
            <button id="plCopyLink" type="button" class="chip text-xs">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>リンクをコピー
            </button>
            <button id="plShareX" type="button" class="chip text-xs">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>共有
            </button>
            <button id="plDelete" type="button" class="chip text-xs ml-auto" style="color:#e11d48">削除</button>
          </div>
          <p id="plMsg" class="text-[11px] text-slate-400 min-h-[1.1em]" role="status" aria-live="polite"></p>
        </div>
        <div id="plSongs" class="overflow-y-auto p-2"></div>
      </div>
    </div>

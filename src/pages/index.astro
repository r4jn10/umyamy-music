---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import songsData from '../../public/data/songs.json';

const { songs } = songsData;
const totalSongs = songs.length;
const utaWakuCount = songs.filter(s => s.category === 'uta_waku').length;
const coverCount = songs.filter(s => s.category === 'cover').length;
const shortCount = songs.filter(s => s.category === 'short').length;
const lastUpdated = songsData.updatedAt;
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-4 w-full">

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-x-8 gap-y-2 py-6 text-sm">
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-2xl font-extrabold text-ink tabular-nums">{totalSongs}</span>
        <span class="text-slate-400 text-xs font-medium">曲</span>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-lg font-bold text-ayane tabular-nums">{utaWakuCount}</span>
        <span class="text-slate-400 text-xs font-medium">歌枠</span>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-lg font-bold text-madoka tabular-nums">{coverCount}</span>
        <span class="text-slate-400 text-xs font-medium">歌ってみた</span>
      </div>
      {shortCount > 0 && (
        <div class="flex items-baseline gap-1.5">
          <span class="font-display text-lg font-bold text-slate-600 tabular-nums">{shortCount}</span>
          <span class="text-slate-400 text-xs font-medium">ショート</span>
        </div>
      )}
      <span class="ml-auto text-[11px] text-slate-400">最終更新 <span class="font-semibold text-slate-500">{lastUpdated}</span></span>
    </div>

    <main id="songs" class="pb-16">

      <!-- New videos slider -->
      <section id="newSection" class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-display text-sm font-bold text-slate-500 tracking-wide">新着</h2>
          <div class="flex items-center gap-1">
            <button id="newPrev" type="button" aria-label="前へ"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 disabled:opacity-30 disabled:hover:bg-transparent transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="newNext" type="button" aria-label="次へ"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 disabled:opacity-30 disabled:hover:bg-transparent transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
        <div id="newSlider" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 -mx-1 px-1 new-slider"></div>
      </section>

      <!-- Search & Filter -->
      <div class="card p-5 mb-8" id="searchArea">
        <div class="flex items-center gap-1.5 mb-4">
          <button id="view-songs" class="chip" aria-pressed="true">🎵 曲</button>
          <button id="view-streams" class="chip" aria-pressed="false">📺 配信</button>
          <button id="view-artists" class="chip" aria-pressed="false">🎤 アーティスト</button>
          <select id="streamSort" class="hidden ml-auto text-xs border border-slate-200 rounded-lg px-2 py-1.5 bg-white text-slate-500">
            <option value="date_desc">新着順</option>
            <option value="date_asc">古い順</option>
          </select>
        </div>
        <div class="relative mb-4">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3m1.8-4.7a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" id="searchInput" placeholder="曲名・アーティスト・タグで検索"
                 class="w-full pl-10 pr-10 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:outline-none focus:border-slate-400 focus:bg-white transition">
          <button id="clearSearch" type="button" aria-label="クリア"
                  class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="flex flex-col gap-3">
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-[11px] text-slate-400 font-semibold mr-1">メンバー</span>
            <button id="btn-m-all" class="chip" aria-pressed="true">ぜんぶ</button>
            <button id="btn-m-madoka" class="chip chip-madoka" aria-pressed="false"><span class="dot" style="background:#ff8184"></span>水面まどか</button>
            <button id="btn-m-ayane" class="chip chip-ayane" aria-pressed="false"><span class="dot" style="background:#54a2e5"></span>白砂あやね</button>
            <button id="btn-m-duet" class="chip chip-duet" aria-pressed="false">うみゃみー</button>
          </div>
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-[11px] text-slate-400 font-semibold mr-1">カテゴリ</span>
            <button id="btn-c-all" class="chip" aria-pressed="true">ぜんぶ</button>
            <button id="btn-c-uta_waku" class="chip" aria-pressed="false">歌枠</button>
            <button id="btn-c-cover" class="chip" aria-pressed="false">歌ってみた</button>
            <button id="btn-c-short" class="chip" aria-pressed="false">ショート</button>
            <button id="btn-fav" class="chip chip-fav ml-auto" aria-pressed="false" aria-label="お気に入りで絞り込み">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              お気に入り
            </button>
            <span id="resultCount" class="text-[11px] font-medium text-slate-400">{totalSongs} 曲</span>
          </div>
        </div>
      </div>

      <!-- アクティブなアーティスト絞り込み -->
      <div id="artistFilterBar" class="hidden mb-4 flex items-center gap-2">
        <span class="text-xs text-slate-400 font-semibold">アーティスト</span>
        <button id="artistClear" type="button" class="chip" aria-pressed="true"><span id="artistFilterName"></span><span class="ml-1.5 text-slate-400">✕</span></button>
      </div>

      <!-- Song Grid（カードは表示中のぶんだけ JS で描画＝Phase B 軽量化） -->
      <div id="songGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>

      <!-- さらに表示 -->
      <div id="moreWrap" class="hidden mt-8 text-center">
        <button id="loadMoreBtn" type="button"
                class="chip px-5 py-2 text-sm font-semibold">さらに表示<span id="moreCount" class="text-slate-400 font-normal ml-1.5"></span></button>
      </div>

      <!-- Empty state -->
      <div id="emptyState" class="hidden py-20 text-center">
        <p id="emptyMsg" class="font-semibold text-slate-500">「<span id="emptyQuery" class="text-madoka"></span>」に一致する曲がありません</p>
        <button id="resetSearchBtn" type="button" class="mt-4 chip text-xs">検索をリセット</button>
      </div>

      <!-- Stream Grid（配信ビュー） -->
      <div id="streamGrid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
      <div id="streamEmpty" class="hidden py-20 text-center">
        <p class="font-semibold text-slate-500">該当する配信がありません</p>
      </div>

      <!-- Artist Grid（アーティストビュー） -->
      <div id="artistGrid" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3"></div>
      <div id="artistEmpty" class="hidden py-20 text-center">
        <p class="font-semibold text-slate-500">該当するアーティストがいません</p>
      </div>

    </main>
  </div>

  <div id="songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>

  <!-- Bottom music player -->
  <div id="player" class="hidden">
    <!-- Expanded sheet -->
    <div id="playerSheet" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center">
      <div id="sheetBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
      <div class="relative w-full max-w-4xl bg-white rounded-t-2xl sm:rounded-2xl shadow-2xl border border-slate-200 max-h-[90vh] flex flex-col overflow-hidden">
        <div class="accent-bar h-1 w-full shrink-0"></div>
        <div class="flex items-center justify-between px-4 pt-3 pb-1">
          <span class="accent-text text-[11px] font-bold tracking-widest text-madoka">NOW PLAYING</span>
          <button id="collapseBtn" aria-label="閉じる" class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 p-4 pt-1 min-h-0 overflow-hidden">
          <div class="sm:w-3/5 shrink-0 flex flex-col">
            <div class="aspect-video bg-black rounded-xl overflow-hidden"><div id="ytFrame" class="w-full h-full"></div></div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <h3 id="sheetTitle" class="font-bold text-ink truncate">—</h3>
                <p id="sheetMeta" class="text-xs text-slate-400 truncate">—</p>
              </div>
              <div class="shrink-0 flex items-center gap-2">
                <button id="sheetFav" type="button" aria-label="お気に入り" aria-pressed="false"
                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </button>
                <button id="sheetShare" type="button" aria-label="Xで共有"
                        class="inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-slate-900 hover:bg-slate-800 px-3 py-2 rounded-lg transition">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  共有
                </button>
                <a id="sheetYoutube" href="#" target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-[#ff0000] px-3 py-2 rounded-lg">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
                  YouTube
                </a>
              </div>
            </div>
            <!-- Seek bar（曲内の再生位置） -->
            <div class="mt-3 flex items-center gap-2 text-[11px] text-slate-400 tabular-nums">
              <span class="seek-cur">0:00</span>
              <input type="range" min="0" max="1000" value="0" step="1" aria-label="再生位置" class="seek-range flex-1">
              <span class="seek-dur">0:00</span>
            </div>
            <!-- Sheet controls -->
            <div class="mt-3 flex items-center justify-center gap-1 text-slate-600">
              <button class="ctl-prev p-2 rounded-full hover:bg-slate-100" aria-label="前へ">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 4 9 12 19 20 19 4" fill="currentColor"/><line x1="5" x2="5" y1="5" y2="19"/></svg>
              </button>
              <button class="ctl-play play-btn-themed p-3 rounded-full bg-ink text-white hover:opacity-90" aria-label="再生/一時停止">
                <svg class="icon-play w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3" fill="currentColor"/></svg>
                <svg class="icon-pause w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/><rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/></svg>
              </button>
              <button class="ctl-next p-2 rounded-full hover:bg-slate-100" aria-label="次へ">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4" fill="currentColor"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
              </button>
              <button class="ctl-repeat relative p-2 rounded-full hover:bg-slate-100" aria-label="リピート切替">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>
                <span class="repeat-one hidden absolute -top-0.5 -right-0.5 text-[9px] font-bold bg-madoka text-white rounded-full w-3.5 h-3.5 flex items-center justify-center">1</span>
              </button>
              <button class="ctl-shuffle p-2 rounded-full hover:bg-slate-100" aria-label="シャッフル再生">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h4c2 0 4-1.2 6-6s4-6 6-6h4" /><path d="m18 2 4 4-4 4" /><path d="M2 6h4c2 0 4 1.2 6 6s4 6 6 6h4" /><path d="m18 14 4 4-4 4" /></svg>
              </button>
              <div class="flex items-center gap-1 ml-2">
                <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
                  <svg class="icon-vol w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                  <svg class="icon-vol-low w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                  <svg class="icon-mute w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="22" y1="9" x2="16" y2="15"/><line x1="16" y1="9" x2="22" y2="15"/></svg>
                </button>
                <input type="range" min="0" max="100" value="100" aria-label="音量" class="volume-slider w-20 accent-[#ff8184]">
              </div>
            </div>
          </div>
          <div class="sm:w-2/5 min-h-0 flex flex-col">
            <p class="text-xs font-bold text-slate-400 mb-2 shrink-0">次の曲</p>
            <div id="upNext" class="flex-1 overflow-y-auto -mr-1 pr-1 space-y-1 min-h-[120px]"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mini bar -->
    <div class="fixed inset-x-0 bottom-0 z-40 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_20px_rgba(15,23,42,0.06)]">
      <div class="accent-bar h-1 w-full"></div>
      <button id="barHandle" aria-label="プレーヤーを開く" class="group w-full flex flex-col items-center pt-1.5 gap-0.5">
        <span class="block w-9 h-1 rounded-full bg-slate-300 group-hover:bg-slate-400 transition"></span>
        <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-slate-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" d="M5 15l7-7 7 7"/></svg>
      </button>
      <!-- Seek bar（折りたたみ時も表示） -->
      <div class="max-w-6xl mx-auto px-3 sm:px-4 flex items-center gap-2 text-[10px] text-slate-400 tabular-nums">
        <span class="seek-cur">0:00</span>
        <input type="range" min="0" max="1000" value="0" step="1" aria-label="再生位置" class="seek-range flex-1">
        <span class="seek-dur">0:00</span>
      </div>
      <div class="max-w-6xl mx-auto px-3 sm:px-4 pb-2 flex items-center gap-2 sm:gap-3">
        <button id="barExpand" class="flex items-center gap-3 min-w-0 flex-1 text-left" aria-label="プレーヤーを開く">
          <img id="barThumb" src="" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
          <div class="min-w-0">
            <p id="barTitle" class="text-sm font-semibold text-ink truncate">—</p>
            <p id="barMeta" class="text-xs text-slate-400 truncate">—</p>
          </div>
        </button>

        <!-- volume (md+) -->
        <div class="hidden md:flex items-center gap-1.5 shrink-0 text-slate-600">
          <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
            <svg class="icon-vol w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
            <svg class="icon-vol-low w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                  <svg class="icon-mute w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="22" y1="9" x2="16" y2="15"/><line x1="16" y1="9" x2="22" y2="15"/></svg>
          </button>
          <input type="range" min="0" max="100" value="100" aria-label="音量" class="volume-slider w-20 accent-[#ff8184]">
        </div>

        <div class="flex items-center gap-0 sm:gap-1 shrink-0 text-slate-600">
          <button class="ctl-prev p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="前へ">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 4 9 12 19 20 19 4" fill="currentColor"/><line x1="5" x2="5" y1="5" y2="19"/></svg>
          </button>
          <button class="ctl-play play-btn-themed p-2 sm:p-2.5 rounded-full bg-ink text-white hover:opacity-90" aria-label="再生/一時停止">
            <svg class="icon-play w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3" fill="currentColor"/></svg>
            <svg class="icon-pause w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/><rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/></svg>
          </button>
          <button class="ctl-next p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="次へ">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4" fill="currentColor"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
          </button>
          <button class="ctl-repeat relative p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="リピート切替">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>
            <span class="repeat-one hidden absolute -top-0.5 -right-0.5 text-[9px] font-bold bg-madoka text-white rounded-full w-3.5 h-3.5 flex items-center justify-center">1</span>
          </button>
          <button class="ctl-shuffle p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="シャッフル再生">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h4c2 0 4-1.2 6-6s4-6 6-6h4" /><path d="m18 2 4 4-4 4" /><path d="M2 6h4c2 0 4 1.2 6 6s4 6 6 6h4" /><path d="m18 14 4 4-4 4" /></svg>
          </button>
          <a id="barYoutube" href="#" target="_blank" rel="noopener noreferrer" aria-label="YouTubeで開く" class="p-2 rounded-full hover:bg-slate-100 hidden lg:inline-flex text-[#ff0000]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <button id="closePlayerBtn" aria-label="閉じる" class="p-1.5 sm:p-2 rounded-full hover:bg-slate-100 text-slate-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- History modal（#player の外。再生前でも開けるように） -->
  <div id="historyModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="historyBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl border border-slate-200 max-h-[80vh] flex flex-col">
      <div class="flex items-center justify-between p-4 border-b border-slate-100">
        <h3 class="font-bold text-ink">再生履歴</h3>
        <button id="historyClose" aria-label="閉じる" class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="historyList" class="overflow-y-auto p-2"></div>
    </div>
  </div>

  <SiteFooter />
</BaseLayout>

<style>
  .player-wrap { aspect-ratio: 16/9; background: #0f172a; }
  .player-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
  /* 新着スライダー */
  :global(.new-slider) { scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent; }
  :global(.new-slider::-webkit-scrollbar) { height: 6px; }
  :global(.new-slider::-webkit-scrollbar-thumb) { background: #cbd5e1; border-radius: 9999px; }
  :global(.new-slider::-webkit-scrollbar-track) { background: transparent; }
  :global(.clamp-2) { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  /* プレーヤーのテーマ色（歌唱者で変化） */
  #player { --accent: #ff8184; --accent-grad: linear-gradient(90deg,#ff8184,#54a2e5); }
  :global(.accent-bar) { background: var(--accent-grad); }
  :global(.accent-text) { color: var(--accent); }
  :global(.volume-slider) { accent-color: var(--accent); }
  :global(.seek-range) { accent-color: var(--accent); cursor: pointer; }
  :global(.repeat-one) { background: var(--accent) !important; }
  :global(.repeat-active) { color: var(--accent); }

  /* 曲カード（JS描画になったため SongCard.astro のscopedからglobalへ移設） */
  :global(.song-card-item:hover) { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(15,23,42,.08); border-color: #cbd5e1; }
  :global(.song-card-item.is-playing) { border-color: #ff8184; box-shadow: 0 0 0 2px #ff8184; }
  :global(.thumb-wrap) { position: relative; aspect-ratio: 16/9; background: #f1f5f9; overflow: hidden; }
  :global(.thumb-wrap img) { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s ease; }
  :global(.song-card-item:hover .thumb-wrap img) { transform: scale(1.05); }
  :global(.play-overlay) { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(15,23,42,.25); opacity: 0; transition: opacity .2s ease; }
  :global(.song-card-item:hover .play-overlay) { opacity: 1; }
  :global(.play-btn) { width: 46px; height: 46px; border-radius: 9999px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.18); border: 2px solid #fff; backdrop-filter: blur(2px); }
  :global(.ts-badge) { position: absolute; bottom: 8px; right: 8px; background: rgba(15,23,42,.78); color: #fff; font-size: .7rem; font-weight: 600; padding: 2px 7px; border-radius: 6px; font-variant-numeric: tabular-nums; }
  :global(.playing-badge) { background: #ff8184; left: 8px; right: auto; }
  :global(.card-share) { position: absolute; top: 8px; right: 8px; z-index: 10; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; background: rgba(15,23,42,.55); color: #fff; transition: background .2s, transform .2s; }
  :global(.card-share:hover) { background: rgba(15,23,42,.85); transform: scale(1.08); }
  :global(.card-fav) { position: absolute; top: 8px; left: 8px; z-index: 10; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; background: rgba(15,23,42,.55); color: #fff; transition: background .2s, transform .2s, color .2s; }
  :global(.card-fav:hover) { background: rgba(15,23,42,.85); transform: scale(1.08); }
  :global(.card-fav.is-fav) { color: #fbbf24; }
  :global(.card-fav.is-fav svg) { fill: #fbbf24; }

  /* お気に入り（絞り込みチップ／シート星）のアクティブ表示 */
  #btn-fav[aria-pressed="true"] { color: #b45309; border-color: #fbbf24; background: #fffbeb; }
  #btn-fav[aria-pressed="true"] svg { fill: #fbbf24; }
  #sheetFav[aria-pressed="true"] { color: #f59e0b; border-color: #fcd34d; background: #fffbeb; }
  #sheetFav[aria-pressed="true"] svg { fill: #fbbf24; }
</style>

<script>
  import Fuse from 'fuse.js';

  let filterMember = 'all';
  let filterCategory = 'all';
  let searchText = '';
  let filterArtist: string | null = null;
  let filterFav = false;
  let viewMode: 'songs' | 'streams' | 'artists' = 'songs';

  // ===== お気に入り（localStorage 永続化） =====
  const FAV_KEY = 'umyamy:favorites';
  let favSet: Set<string> = new Set();
  try { favSet = new Set(JSON.parse(localStorage.getItem(FAV_KEY) || '[]')); } catch (_) {}
  function saveFav() {
    try { localStorage.setItem(FAV_KEY, JSON.stringify([...favSet])); } catch (_) {}
  }
  function toggleFav(id: string) {
    if (favSet.has(id)) favSet.delete(id); else favSet.add(id);
    saveFav();
    refreshFavUI();
    // お気に入り絞り込み中なら、外れた曲を一覧から消す
    if (filterFav) { shownCount = PAGE_SIZE; refresh(); }
  }
  // カード・シートの星の状態を現在の favSet に同期
  function refreshFavUI() {
    document.querySelectorAll('.card-fav').forEach(btn => {
      const on = favSet.has(btn.getAttribute('data-id') || '');
      btn.classList.toggle('is-fav', on);
      btn.setAttribute('aria-pressed', String(on));
    });
    const sf = document.getElementById('sheetFav');
    if (sf) {
      const on = !!nowPlaying && favSet.has(nowPlaying.id);
      sf.setAttribute('aria-pressed', String(on));
    }
  }

  const songsDataEl = document.getElementById('songs-data');
  const songs = songsDataEl ? JSON.parse(songsDataEl.getAttribute('data-songs') || '[]') : [];

  const fuse = new Fuse(songs, { keys: ['title', 'artist', 'tags'], threshold: 0.3 });

  const CAT_LABEL: Record<string, string> = { uta_waku: '歌枠', cover: '歌ってみた', short: 'ショート' };
  const MEMBER_ORDER = ['水面まどか', '白砂あやね'];

  function orderPerformers(performers: string[]) {
    return [...performers].sort((a, b) => MEMBER_ORDER.indexOf(a) - MEMBER_ORDER.indexOf(b));
  }
  function memberChipClass(p: string) {
    return p === '水面まどか' ? 'text-[#ff8184] bg-[#ffeef0]' : 'text-[#54a2e5] bg-[#eaf4fc]';
  }

  // 曲カードのHTML（SongCard.astro と同等。表示中ぶんだけ JS で描画＝Phase B 軽量化）
  function cardHtml(song: any): string {
    const performers = orderPerformers(song.performers || []);
    const isDuet = performers.length > 1;
    const thumb = `https://img.youtube.com/vi/${song.youtube.videoId}/mqdefault.jpg`;
    const cat = CAT_LABEL[song.category] || song.category;
    const duetBadge = isDuet
      ? `<span class="text-[10px] px-2 py-0.5 rounded-full font-semibold text-white" style="background:linear-gradient(135deg,#ff8184,#54a2e5)">うみゃみー</span>`
      : '';
    const chips = performers.map((p: string) =>
      `<span class="text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChipClass(p)}">${escHtml(p)}</span>`).join('');
    const tags = (song.tags && song.tags.length)
      ? `<div class="flex gap-1 flex-wrap mt-2.5">${song.tags.slice(0, 3).map((t: string) =>
          `<span class="text-[10px] text-slate-400 bg-slate-50 border border-slate-100 px-2 py-0.5 rounded">#${escHtml(t)}</span>`).join('')}</div>`
      : '';
    return `
      <div class="song-card-item card group cursor-pointer overflow-hidden" data-id="${escHtml(song.id)}">
        <div class="thumb-wrap">
          <img src="${thumb}" alt="${escHtml(song.title)}" loading="lazy" decoding="async" />
          <div class="play-overlay"><div class="play-btn">
            <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div></div>
          <span class="playing-badge ts-badge hidden">再生中</span>
          <button type="button" class="card-fav" data-id="${escHtml(song.id)}" aria-label="お気に入り" aria-pressed="false">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </button>
          <button type="button" class="card-share" data-id="${escHtml(song.id)}" aria-label="Xで共有">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
        </div>
        <div class="p-4">
          <div class="flex items-start justify-between gap-2 mb-1">
            <h3 class="font-bold text-slate-900 text-[15px] leading-snug flex-1">${escHtml(song.title)}</h3>
            <span class="shrink-0 text-[11px] px-2 py-0.5 rounded-full font-semibold text-slate-500 bg-slate-100 whitespace-nowrap">${escHtml(cat)}</span>
          </div>
          <p class="text-xs text-slate-400 font-medium mb-3 truncate">${escHtml(song.artist || '')}</p>
          <div class="flex items-center justify-between gap-2">
            <div class="flex gap-1 flex-wrap">${duetBadge}${chips}</div>
            <span class="text-[11px] font-medium text-slate-400 whitespace-nowrap">${escHtml(song.streamDate || '')}</span>
          </div>
          ${tags}
        </div>
      </div>`;
  }

  // メンバー・カテゴリだけで絞った曲（アーティスト一覧の集計と曲一覧の土台に共用）
  function memberCategoryFiltered() {
    let f = songs;
    if (filterMember === 'ayane') f = f.filter((s: any) => s.performers.includes('白砂あやね'));
    else if (filterMember === 'madoka') f = f.filter((s: any) => s.performers.includes('水面まどか'));
    else if (filterMember === 'duet') f = f.filter((s: any) => s.performers.length > 1);
    if (filterCategory !== 'all') f = f.filter((s: any) => s.category === filterCategory);
    if (filterFav) f = f.filter((s: any) => favSet.has(s.id));
    return f;
  }

  function getFiltered() {
    let f = memberCategoryFiltered();
    if (filterArtist) f = f.filter((s: any) => (s.artist || '').trim() === filterArtist);
    if (searchText) {
      const m = new Set(fuse.search(searchText).map(r => (r.item as any).id));
      f = f.filter((s: any) => m.has(s.id));
    }
    return f;
  }

  // 一覧の段階表示（多すぎてページ下部に行けない問題への対策）
  const PAGE_SIZE = 24;
  let shownCount = PAGE_SIZE;

  // 現在の絞り込み結果のうち先頭 shownCount 件だけ表示し、残りは「さらに表示」に隠す
  function applyDisplay() {
    const filtered = getFiltered();
    const grid = document.getElementById('songGrid');
    if (grid) grid.innerHTML = filtered.slice(0, shownCount).map(cardHtml).join('');
    // 再描画後に「再生中」「お気に入り」の状態を復元
    markPlayingCard(nowPlaying ? nowPlaying.id : null);
    refreshFavUI();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${filtered.length} 曲`;

    const remaining = filtered.length - shownCount;
    const moreWrap = document.getElementById('moreWrap');
    const moreCount = document.getElementById('moreCount');
    moreWrap?.classList.toggle('hidden', remaining <= 0);
    if (moreCount) moreCount.textContent = remaining > 0 ? `（残り${remaining}曲）` : '';

    const emptyState = document.getElementById('emptyState');
    const emptyQuery = document.getElementById('emptyQuery');
    const emptyMsg = document.getElementById('emptyMsg');
    if (filtered.length === 0) {
      emptyState?.classList.remove('hidden');
      // お気に入り絞り込みで空（かつ未検索）のときは専用メッセージ
      if (filterFav && !searchText && favSet.size === 0) {
        if (emptyMsg) emptyMsg.innerHTML = 'お気に入りがまだありません。曲カードの<span class="text-madoka">★</span>でお気に入りに追加できます。';
      } else if (emptyMsg) {
        emptyMsg.innerHTML = '「<span id="emptyQuery" class="text-madoka"></span>」に一致する曲がありません';
        const q = document.getElementById('emptyQuery');
        if (q) q.textContent = searchText || (filterFav ? 'お気に入り' : '');
      }
    } else emptyState?.classList.add('hidden');
  }

  // 絞り込み・検索が変わったときの入口（表示件数をリセットして先頭から）
  function filterSongs() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    searchText = searchInput ? searchInput.value.trim().toLowerCase() : '';
    document.getElementById('clearSearch')?.classList.toggle('hidden', !searchText);
    shownCount = PAGE_SIZE;
    refresh();
  }

  // 現在のビューに応じて一覧を再描画
  function refresh() {
    if (viewMode === 'streams') renderStreams();
    else if (viewMode === 'artists') renderArtists();
    else applyDisplay();
  }

  // ビュー切替（曲 / 配信 / アーティスト）
  function setView(mode: 'songs' | 'streams' | 'artists') {
    viewMode = mode;
    shownCount = PAGE_SIZE;
    const isSongs = mode === 'songs', isStreams = mode === 'streams', isArtists = mode === 'artists';
    document.getElementById('view-songs')?.setAttribute('aria-pressed', String(isSongs));
    document.getElementById('view-streams')?.setAttribute('aria-pressed', String(isStreams));
    document.getElementById('view-artists')?.setAttribute('aria-pressed', String(isArtists));
    document.getElementById('songGrid')?.classList.toggle('hidden', !isSongs);
    document.getElementById('streamGrid')?.classList.toggle('hidden', !isStreams);
    document.getElementById('artistGrid')?.classList.toggle('hidden', !isArtists);
    document.getElementById('streamSort')?.classList.toggle('hidden', !isStreams);
    if (!isSongs) {
      document.getElementById('moreWrap')?.classList.add('hidden');
      document.getElementById('emptyState')?.classList.add('hidden');
    }
    if (!isStreams) document.getElementById('streamEmpty')?.classList.add('hidden');
    if (!isArtists) document.getElementById('artistEmpty')?.classList.add('hidden');
    updateArtistChip();
    const si = document.getElementById('searchInput') as HTMLInputElement | null;
    if (si) si.placeholder = isStreams ? '配信タイトル・日付・曲名で検索'
      : isArtists ? 'アーティスト名で検索'
      : '曲名・アーティスト・タグで検索';
    refresh();
  }

  // アクティブなアーティスト絞り込みチップの表示更新（曲ビューでのみ表示）
  function updateArtistChip() {
    const bar = document.getElementById('artistFilterBar');
    const nameEl = document.getElementById('artistFilterName');
    const show = viewMode === 'songs' && !!filterArtist;
    bar?.classList.toggle('hidden', !show);
    if (show && nameEl) nameEl.textContent = filterArtist;
  }

  function loadMore() {
    shownCount += PAGE_SIZE;
    applyDisplay();
  }

  function clearSearch() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    filterSongs();
  }

  // ===== 下部音楽プレーヤー（YouTube IFrame API） =====
  type RepeatMode = 'all' | 'one' | 'off';
  let ytPlayer: any = null, pending: any = null;
  let queue: any[] = [], qIndex = -1, isPlaying = false, nowPlaying: any = null;
  let repeatMode: RepeatMode = 'all';   // 連続再生 → 1曲リピート → オフ
  let lastVolume = 100, isMuted = false;
  // 曲は「動画内の [開始秒, 終了秒) 区間」。終了秒は同一動画の次曲の開始秒（最後の曲は動画終端=ENDEDに委譲）
  let segStart = 0, segEnd = Infinity, segHandled = false, currentVideoId: string | null = null, watchTimer: any = null;
  let isSeeking = false; // シークバーをドラッグ中はバー位置を上書きしない

  const apiTag = document.createElement('script');
  apiTag.src = 'https://www.youtube.com/iframe_api';
  document.head.appendChild(apiTag);
  (window as any).onYouTubeIframeAPIReady = () => {
    ytPlayer = new (window as any).YT.Player('ytFrame', {
      playerVars: { rel: 0, playsinline: 1, autoplay: 1 },
      events: {
        onReady: () => {
          applyVolume();
          if (pending) { loadVideo(pending); pending = null; }
        },
        onStateChange: (e: any) => {
          isPlaying = (e.data === 1);
          updatePlayIcon();
          // 動画自体の終端（＝最後の曲の区間終わり）。区間監視が拾えない最終曲のみここで処理
          if (e.data === 0 && !segHandled) { segHandled = true; handleEnded(); }
        },
      },
    });
  };

  // 同一動画で「この曲の開始秒より後にある最も近い曲の開始秒」＝この曲の終了秒。無ければ動画終端(Infinity)
  function computeSegmentEnd(song: any): number {
    if (song.youtube.endSec != null) return song.youtube.endSec; // 明示の終了秒（動画長）
    const vid = song.youtube.videoId;
    const start = song.youtube.timestampSec || 0;
    const laterStarts = songs
      .filter((s: any) => s.youtube.videoId === vid)
      .map((s: any) => s.youtube.timestampSec || 0)
      .filter((t: number) => t > start)
      .sort((a: number, b: number) => a - b);
    return laterStarts.length ? laterStarts[0] : Infinity;
  }

  function loadVideo(song: any) {
    const start = song.youtube.timestampSec || 0;
    segStart = start;
    segEnd = computeSegmentEnd(song);
    segHandled = false;
    if (ytPlayer && ytPlayer.loadVideoById) {
      if (currentVideoId === song.youtube.videoId && ytPlayer.seekTo) {
        // 同じ動画内の移動は再読込せず seek（瞬時）
        ytPlayer.seekTo(start, true);
        ytPlayer.playVideo?.();
      } else {
        ytPlayer.loadVideoById({ videoId: song.youtube.videoId, startSeconds: start });
        currentVideoId = song.youtube.videoId;
      }
      startWatch();
    } else {
      pending = song;
    }
  }

  // mm:ss 形式（曲の経過/尺の表示用）
  function fmtClock(sec: number): string {
    if (!isFinite(sec) || sec < 0) sec = 0;
    const m = Math.floor(sec / 60), s = Math.floor(sec % 60);
    return `${m}:${String(s).padStart(2, '0')}`;
  }

  // 実効の終了秒（最後の曲は動画長を使う）
  function effectiveEnd(): number {
    if (segEnd !== Infinity) return segEnd;
    const d = ytPlayer && ytPlayer.getDuration ? ytPlayer.getDuration() : 0;
    return d > 0 ? d : segStart; // 動画長が未取得なら尺0扱い
  }

  // シークバー・時間表示を更新（ミニバー／展開シートの両方）
  function updateSeek(t: number) {
    const end = effectiveEnd();
    const dur = Math.max(0, end - segStart);
    const cur = Math.max(0, Math.min(dur, t - segStart));
    document.querySelectorAll('.seek-cur').forEach(el => (el.textContent = fmtClock(cur)));
    document.querySelectorAll('.seek-dur').forEach(el => (el.textContent = fmtClock(dur)));
    if (!isSeeking && dur > 0) {
      const v = String(Math.round((cur / dur) * 1000));
      document.querySelectorAll('.seek-range').forEach(el => ((el as HTMLInputElement).value = v));
    }
  }

  // 曲内の指定位置へシーク（ratio: 0〜1）
  function seekToRatio(ratio: number) {
    if (!ytPlayer || !ytPlayer.seekTo) return;
    const dur = Math.max(0, effectiveEnd() - segStart);
    ytPlayer.seekTo(segStart + ratio * dur, true);
  }

  // 再生位置を監視: シークバー更新 ＋ 曲の終了秒に達したら handleEnded（区間境界での次へ/リピート）
  function startWatch() {
    if (watchTimer) return;
    watchTimer = setInterval(() => {
      if (!ytPlayer || !ytPlayer.getCurrentTime) return;
      const t = ytPlayer.getCurrentTime();
      updateSeek(t);
      if (!segHandled && segEnd !== Infinity && t >= segEnd - 0.25) { segHandled = true; handleEnded(); }
    }, 250);
  }
  function stopWatch() { if (watchTimer) { clearInterval(watchTimer); watchTimer = null; } }

  function saveHistory(song: any) {
    try {
      const k = 'umyamy:history';
      const arr = JSON.parse(localStorage.getItem(k) || '[]');
      if (arr[0] && arr[0].id === song.id) return;
      arr.unshift({ id: song.id, title: song.title, artist: song.artist, videoId: song.youtube.videoId, at: Date.now() });
      localStorage.setItem(k, JSON.stringify(arr.slice(0, 50)));
    } catch (_) {}
  }

  function markPlayingCard(id: string | null) {
    document.querySelectorAll('.song-card-item').forEach(card => {
      const on = card.getAttribute('data-id') === id;
      card.classList.toggle('is-playing', on);
      const pb = card.querySelector('.playing-badge');
      const ts = card.querySelector('.ts-badge:not(.playing-badge)');
      if (pb) pb.classList.toggle('hidden', !on);
      if (ts) ts.classList.toggle('hidden', on);
    });
  }

  function updateBar(song: any) {
    const yurl = song.youtube.url || `https://www.youtube.com/watch?v=${song.youtube.videoId}`;
    const set = (id: string, fn: (el: any) => void) => { const el = document.getElementById(id); if (el) fn(el); };
    set('barThumb', el => el.src = `https://img.youtube.com/vi/${song.youtube.videoId}/default.jpg`);
    set('barTitle', el => el.textContent = song.title);
    set('barMeta', el => el.textContent = song.artist);
    set('sheetTitle', el => el.textContent = song.title);
    set('sheetMeta', el => el.textContent = `${song.artist}${song.streamTitle ? ' — ' + song.streamTitle : ''}`);
    set('barYoutube', el => el.href = yurl);
    set('sheetYoutube', el => el.href = yurl);
  }

  function updatePlayIcon() {
    document.querySelectorAll('.icon-play').forEach(el => el.classList.toggle('hidden', isPlaying));
    document.querySelectorAll('.icon-pause').forEach(el => el.classList.toggle('hidden', !isPlaying));
  }

  // ----- テーマ色（歌唱者で変化） -----
  function applyTheme(song: any) {
    const p: string[] = song.performers || [];
    const hasM = p.includes('水面まどか'), hasA = p.includes('白砂あやね');
    let accent: string, grad: string;
    if (hasM && hasA) { accent = '#b86fb0'; grad = 'linear-gradient(90deg,#ff8184,#54a2e5)'; }
    else if (hasA) { accent = '#54a2e5'; grad = 'linear-gradient(90deg,#54a2e5,#88c4f1)'; }
    else { accent = '#ff8184'; grad = 'linear-gradient(90deg,#ff8184,#ffb0b2)'; }
    const root = document.getElementById('player');
    if (root) {
      root.style.setProperty('--accent', accent);
      root.style.setProperty('--accent-grad', grad);
    }
    document.querySelectorAll('.play-btn-themed').forEach(b => (b as HTMLElement).style.background = grad);
  }

  // ----- 次の曲リスト（YouTube Music風・キューを巡回して表示） -----
  function renderUpNext() {
    const el = document.getElementById('upNext');
    if (!el) return;
    if (queue.length <= 1 || qIndex < 0) {
      el.innerHTML = '<p class="text-xs text-slate-400 py-4 text-center">次の曲はありません</p>';
      return;
    }
    // 現在の曲の次から、キューを一周ぶん並べる（末尾付近で再生開始しても十分な数が出る）
    const items: { song: any; idx: number }[] = [];
    for (let k = 1; k < queue.length; k++) {
      const idx = (qIndex + k) % queue.length;
      items.push({ song: queue[idx], idx });
    }
    el.innerHTML = items.map(({ song: s, idx }) => {
      const thumb = `https://img.youtube.com/vi/${s.youtube.videoId}/default.jpg`;
      return `
        <button type="button" data-qindex="${idx}" class="upnext-item w-full flex items-center gap-2.5 p-1.5 rounded-lg hover:bg-slate-100 text-left">
          <img src="${thumb}" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-ink truncate">${s.title}</p>
            <p class="text-[11px] text-slate-400 truncate">${s.artist}</p>
          </div>
        </button>`;
    }).join('');
  }

  // ----- 音量 -----
  function applyVolume() {
    if (!ytPlayer || !ytPlayer.setVolume) return;
    if (isMuted || lastVolume === 0) ytPlayer.mute?.();
    else { ytPlayer.unMute?.(); ytPlayer.setVolume(lastVolume); }
  }
  function updateVolumeUI() {
    const off = isMuted || lastVolume === 0;
    const low = !off && lastVolume <= 50;   // 小音量（1〜50）
    const high = !off && lastVolume > 50;   // 大音量（51〜100）
    document.querySelectorAll('.volume-slider').forEach(s => (s as HTMLInputElement).value = String(isMuted ? 0 : lastVolume));
    document.querySelectorAll('.icon-vol').forEach(el => el.classList.toggle('hidden', !high));
    document.querySelectorAll('.icon-vol-low').forEach(el => el.classList.toggle('hidden', !low));
    document.querySelectorAll('.icon-mute').forEach(el => el.classList.toggle('hidden', !off));
  }
  function setVolume(v: number) {
    lastVolume = Math.max(0, Math.min(100, v));
    isMuted = lastVolume === 0;
    applyVolume();
    updateVolumeUI();
  }
  function toggleMute() {
    isMuted = !isMuted;
    if (!isMuted && lastVolume === 0) lastVolume = 50;
    applyVolume();
    updateVolumeUI();
  }

  // ----- リピート -----
  const REPEAT_CYCLE: RepeatMode[] = ['all', 'one', 'off'];
  function cycleRepeat() {
    repeatMode = REPEAT_CYCLE[(REPEAT_CYCLE.indexOf(repeatMode) + 1) % REPEAT_CYCLE.length];
    updateRepeatUI();
    renderUpNext();
  }
  function updateRepeatUI() {
    document.querySelectorAll('.ctl-repeat').forEach(btn => {
      btn.classList.toggle('repeat-active', repeatMode !== 'off');
      btn.setAttribute('aria-label',
        repeatMode === 'all' ? 'リピート: 連続再生' : repeatMode === 'one' ? 'リピート: 1曲' : 'リピート: オフ');
    });
    document.querySelectorAll('.repeat-one').forEach(el => el.classList.toggle('hidden', repeatMode !== 'one'));
  }

  function handleEnded() {
    if (repeatMode === 'one') { playIndex(qIndex); return; }
    if (qIndex >= queue.length - 1) {
      if (repeatMode === 'all') playIndex(0);
      return; // off → 末尾で停止
    }
    playIndex(qIndex + 1);
  }

  function current(song: any) {
    if (!song) return;
    nowPlaying = song;
    loadVideo(song);
    updateBar(song);
    applyTheme(song);
    saveHistory(song);
    markPlayingCard(song.id);
    refreshFavUI();
    renderUpNext();
    document.getElementById('player')?.classList.remove('hidden');
    document.body.style.paddingBottom = '5.75rem';
  }

  // ----- Xで共有（曲名・アーティスト・歌唱者を本文に、URLは該当のYouTube動画） -----
  function shareSong(song: any) {
    if (!song) return;
    const performers = orderPerformers(song.performers || []).join('・');
    const lines = ['#NowPlaying', `${song.title}${song.artist ? ' / ' + song.artist : ''}`];
    if (performers) lines.push(`うた：${performers}`);
    const text = lines.join('\n');
    const sec = song.youtube?.timestampSec || 0;
    const ytUrl = song.youtube?.url
      || `https://www.youtube.com/watch?v=${song.youtube?.videoId}${sec ? '&t=' + sec : ''}`;
    const intent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`
      + `&url=${encodeURIComponent(ytUrl)}`;
    window.open(intent, '_blank', 'noopener,noreferrer');
  }

  function playSong(song: any) {
    queue = getFiltered();
    if (queue.length === 0 || !queue.find((s: any) => s.id === song.id)) queue = songs;
    qIndex = queue.findIndex((s: any) => s.id === song.id);
    current(song);
  }
  function playIndex(i: number) {
    if (queue.length === 0) return;
    qIndex = ((i % queue.length) + queue.length) % queue.length;
    current(queue[qIndex]);
  }
  function next() { if (queue.length) playIndex(qIndex + 1); }
  function prev() { if (queue.length) playIndex(qIndex - 1); }
  function shufflePlay() {
    // 連続再生キューをリセットしてシャッフル（絞り込み中の曲を対象）
    const base = getFiltered();
    const pool = (base.length ? base : songs).slice();
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }
    if (pool.length === 0) return;
    queue = pool;
    qIndex = 0;
    if (repeatMode === 'off') { repeatMode = 'all'; updateRepeatUI(); }
    current(queue[0]);
  }
  function togglePlay() {
    if (!ytPlayer) return;
    if (isPlaying) ytPlayer.pauseVideo(); else ytPlayer.playVideo();
  }

  // ----- 再生履歴 -----
  function openHistory() {
    const list = document.getElementById('historyList');
    if (list) {
      let arr: any[] = [];
      try { arr = JSON.parse(localStorage.getItem('umyamy:history') || '[]'); } catch (_) {}
      if (arr.length === 0) {
        list.innerHTML = '<p class="text-sm text-slate-400 py-10 text-center">まだ再生履歴はありません</p>';
      } else {
        list.innerHTML = arr.map((h: any) => {
          const thumb = `https://img.youtube.com/vi/${h.videoId}/default.jpg`;
          return `
            <button type="button" data-hist-id="${h.id}" class="history-item w-full flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 text-left">
              <img src="${thumb}" alt="" class="w-12 h-12 rounded object-cover bg-slate-100 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-ink truncate">${h.title}</p>
                <p class="text-xs text-slate-400 truncate">${h.artist}</p>
              </div>
            </button>`;
        }).join('');
      }
    }
    document.getElementById('historyModal')?.classList.remove('hidden');
  }
  function closeHistory() { document.getElementById('historyModal')?.classList.add('hidden'); }
  function playById(id: string) {
    const song = songs.find((s: any) => s.id === id);
    if (song) playSong(song);
  }

  function closePlayer() {
    stopWatch();
    currentVideoId = null;
    segEnd = Infinity;
    if (ytPlayer && ytPlayer.stopVideo) ytPlayer.stopVideo();
    document.getElementById('player')?.classList.add('hidden');
    document.getElementById('playerSheet')?.classList.add('hidden');
    document.body.style.paddingBottom = '';
    markPlayingCard(null);
  }

  // ----- 新着スライダー（配信＝動画単位でまとめて新しい順） -----
  function buildStreams() {
    const map = new Map<string, any>();
    for (const s of songs) {
      const vid = s.youtube.videoId;
      let g = map.get(vid);
      if (!g) {
        g = { videoId: vid, title: s.streamTitle || s.title, date: s.streamDate || '',
              category: s.category, streamType: s.streamType || '', performers: new Set<string>(), songs: [], views: 0 };
        map.set(vid, g);
      }
      (s.performers || []).forEach((p: string) => g.performers.add(p));
      g.views = Math.max(g.views, s.youtube?.viewCount || 0);
      g.songs.push(s);
    }
    return [...map.values()]
      .map(g => ({ ...g, performers: orderPerformers([...g.performers]) }))
      .sort((a, b) => b.date.localeCompare(a.date));
  }

  // 配信カードの中身（新着スライダー／配信ビューで共用）
  function streamCardInner(g: any) {
    const performerBadges = g.performers.map((p: string) =>
      `<span class="text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChipClass(p)}">${p}</span>`).join('');
    const thumbUrl = `https://img.youtube.com/vi/${g.videoId}/mqdefault.jpg`;
    const catLabel = CAT_LABEL[g.category] || g.category;
    // ソロ/コラボ歌枠バッジは歌枠のみ（歌ってみた/ショートでは出さない）
    const typeLabel = g.category !== 'uta_waku' ? '' : (g.streamType === 'solo' ? 'ソロ歌枠' : g.streamType === 'collab' ? 'コラボ歌枠' : '');
    const typeBadge = typeLabel
      ? `<span class="absolute top-2 left-2 text-[11px] font-semibold text-white bg-slate-900/70 px-1.5 py-0.5 rounded">${typeLabel}</span>`
      : '';
    return `
      <div class="relative aspect-video bg-slate-100 overflow-hidden">
        <img src="${thumbUrl}" alt="" onerror="this.style.opacity='0.3'" class="w-full h-full object-cover block">
        ${typeBadge}
        <span class="absolute bottom-2 left-2 text-[11px] font-semibold text-white bg-slate-900/80 px-1.5 py-0.5 rounded">${catLabel}</span>
        <span class="absolute bottom-2 right-2 text-[11px] font-semibold text-white bg-slate-900/80 px-1.5 py-0.5 rounded">${g.songs.length}曲</span>
      </div>
      <div class="p-3">
        <p class="text-sm font-semibold text-ink leading-snug clamp-2 min-h-[2.5em]">${g.title}</p>
        <div class="flex flex-wrap items-center gap-1.5 mt-2">
          ${performerBadges}
          <span class="text-[11px] text-slate-400 ml-auto">${g.date}</span>
        </div>
      </div>`;
  }

  // 新着は直近 NEW_LIMIT 件だけ（全件は「配信」ビューで見られる）
  const NEW_LIMIT = 12;
  function renderNewSlider() {
    const slider = document.getElementById('newSlider');
    if (!slider) return;
    slider.innerHTML = buildStreams().slice(0, NEW_LIMIT).map(g =>
      `<button type="button" data-video-id="${g.videoId}"
               class="new-card snap-start shrink-0 w-64 card overflow-hidden text-left hover:shadow-md transition">${streamCardInner(g)}</button>`
    ).join('');
    updateSliderArrows();
  }

  // 配信ビュー: 絞り込み済みの配信一覧
  function getFilteredStreams() {
    let list = buildStreams();
    if (filterMember === 'ayane') list = list.filter((g: any) => g.performers.includes('白砂あやね'));
    else if (filterMember === 'madoka') list = list.filter((g: any) => g.performers.includes('水面まどか'));
    else if (filterMember === 'duet') list = list.filter((g: any) => g.performers.length > 1);
    if (filterCategory !== 'all') list = list.filter((g: any) => g.category === filterCategory);
    if (filterFav) list = list.filter((g: any) => g.songs.some((s: any) => favSet.has(s.id)));
    if (searchText) {
      list = list.filter((g: any) => {
        const hay = [g.title, g.date, g.performers.join(' '),
          g.songs.map((s: any) => `${s.title} ${s.artist || ''}`).join(' ')].join(' ').toLowerCase();
        return hay.includes(searchText);
      });
    }
    const sortVal = (document.getElementById('streamSort') as HTMLSelectElement)?.value || 'date_desc';
    if (sortVal === 'date_asc') list.sort((a: any, b: any) => a.date.localeCompare(b.date));
    else if (sortVal === 'views') list.sort((a: any, b: any) => (b.views || 0) - (a.views || 0));
    else list.sort((a: any, b: any) => b.date.localeCompare(a.date));
    return list;
  }

  function renderStreams() {
    const grid = document.getElementById('streamGrid');
    if (!grid) return;
    const list = getFilteredStreams();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${list.length} 配信`;
    grid.innerHTML = list.map((g: any) =>
      `<button type="button" data-video-id="${g.videoId}"
               class="stream-card card overflow-hidden text-left hover:shadow-md transition">${streamCardInner(g)}</button>`
    ).join('');
    document.getElementById('streamEmpty')?.classList.toggle('hidden', list.length !== 0);
  }

  function playStream(videoId: string) {
    const list = songs.filter((s: any) => s.youtube.videoId === videoId);
    if (list.length === 0) return;
    queue = list;
    qIndex = 0;
    current(queue[0]);
  }

  // ----- アーティストビュー -----
  function escHtml(s: string) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // メンバー/カテゴリ絞り込みを反映しつつ、アーティスト名で集計（曲数が多い順）
  function buildArtists() {
    const base = memberCategoryFiltered();
    const map = new Map<string, number>();
    for (const s of base) {
      const a = (s.artist || '').trim();
      if (!a) continue; // アーティスト不明はリストから除外
      map.set(a, (map.get(a) || 0) + 1);
    }
    let list = [...map.entries()].map(([name, count]) => ({ name, count }));
    if (searchText) list = list.filter(g => g.name.toLowerCase().includes(searchText));
    list.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'ja'));
    return list;
  }

  function renderArtists() {
    const grid = document.getElementById('artistGrid');
    if (!grid) return;
    const list = buildArtists();
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${list.length} 組`;
    grid.innerHTML = list.map(g => `
      <button type="button" data-artist="${escHtml(g.name)}"
              class="artist-card card p-3 text-left hover:shadow-md transition">
        <p class="text-sm font-semibold text-ink truncate">${escHtml(g.name)}</p>
        <p class="text-[11px] text-slate-400 mt-0.5 tabular-nums">${g.count}曲</p>
      </button>`).join('');
    document.getElementById('artistEmpty')?.classList.toggle('hidden', list.length !== 0);
  }

  function updateSliderArrows() {
    // ループするので矢印は常に有効。スクロールできない（全件が画面内）ときだけ隠す。
    const slider = document.getElementById('newSlider');
    const prev = document.getElementById('newPrev') as HTMLButtonElement | null;
    const next = document.getElementById('newNext') as HTMLButtonElement | null;
    if (!slider || !prev || !next) return;
    const scrollable = slider.scrollWidth - slider.clientWidth > 1;
    prev.disabled = false;
    next.disabled = false;
    prev.classList.toggle('hidden', !scrollable);
    next.classList.toggle('hidden', !scrollable);
  }

  function setPressed(ids: string[], activeId: string) {
    ids.forEach(id => document.getElementById(id)?.setAttribute('aria-pressed', String(id === activeId)));
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (songs.length > 0) renderNewSlider();

    // 初期表示も段階表示にする（先頭 PAGE_SIZE 件のみ）
    applyDisplay();
    document.getElementById('loadMoreBtn')?.addEventListener('click', loadMore);

    // 新着スライダー操作
    const slider = document.getElementById('newSlider');
    // 端まで来たら反対側へループ（末尾で「次」→先頭、先頭で「前」→末尾）
    const scrollByCard = (dir: number) => {
      if (!slider) return;
      const max = slider.scrollWidth - slider.clientWidth;
      const step = slider.clientWidth * 0.8;
      let target = slider.scrollLeft + dir * step;
      if (dir > 0 && slider.scrollLeft >= max - 1) target = 0;
      else if (dir < 0 && slider.scrollLeft <= 1) target = max;
      slider.scrollTo({ left: target, behavior: 'smooth' });
    };
    document.getElementById('newPrev')?.addEventListener('click', () => scrollByCard(-1));
    document.getElementById('newNext')?.addEventListener('click', () => scrollByCard(1));
    slider?.addEventListener('scroll', updateSliderArrows, { passive: true });
    window.addEventListener('resize', updateSliderArrows);
    slider?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.new-card');
      const vid = btn?.getAttribute('data-video-id');
      if (vid) playStream(vid);
    });

    document.getElementById('searchInput')?.addEventListener('input', filterSongs);
    document.getElementById('clearSearch')?.addEventListener('click', clearSearch);
    document.getElementById('resetSearchBtn')?.addEventListener('click', clearSearch);
    document.getElementById('closePlayerBtn')?.addEventListener('click', closePlayer);

    // 共有コントロール（下部バー＋展開シート）
    const on = (sel: string, fn: () => void) =>
      document.querySelectorAll(sel).forEach(el => el.addEventListener('click', fn));
    on('.ctl-play', togglePlay);
    on('.ctl-prev', prev);
    on('.ctl-next', next);
    on('.ctl-shuffle', shufflePlay);
    on('.ctl-repeat', cycleRepeat);
    on('.ctl-mute', toggleMute);
    document.querySelectorAll('.volume-slider').forEach(el =>
      el.addEventListener('input', (e) => setVolume(Number((e.target as HTMLInputElement).value))));

    // 曲内シークバー（ミニバー＋展開シート共通）: ドラッグ中はバー位置を固定し、確定時にシーク
    document.querySelectorAll('.seek-range').forEach(el => {
      const bar = el as HTMLInputElement;
      bar.addEventListener('input', () => {
        isSeeking = true;
        const ratio = Number(bar.value) / 1000;
        const dur = Math.max(0, effectiveEnd() - segStart);
        // 全シークバー・経過表示を同期（プレビュー）
        document.querySelectorAll('.seek-range').forEach(o => ((o as HTMLInputElement).value = bar.value));
        document.querySelectorAll('.seek-cur').forEach(o => (o.textContent = fmtClock(ratio * dur)));
      });
      bar.addEventListener('change', () => { seekToRatio(Number(bar.value) / 1000); isSeeking = false; });
    });

    const openSheet = () => { document.getElementById('playerSheet')?.classList.remove('hidden'); renderUpNext(); };
    const closeSheet = () => document.getElementById('playerSheet')?.classList.add('hidden');
    document.getElementById('barExpand')?.addEventListener('click', openSheet);
    document.getElementById('barHandle')?.addEventListener('click', openSheet);
    document.getElementById('collapseBtn')?.addEventListener('click', closeSheet);
    document.getElementById('sheetBackdrop')?.addEventListener('click', closeSheet);

    updateRepeatUI();
    updateVolumeUI();

    // 次の曲リスト → クリックでジャンプ
    document.getElementById('upNext')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.upnext-item');
      const idx = btn?.getAttribute('data-qindex');
      if (idx !== null && idx !== undefined) playIndex(Number(idx));
    });

    // 再生履歴
    document.getElementById('historyBtn')?.addEventListener('click', openHistory);
    document.getElementById('historyClose')?.addEventListener('click', closeHistory);
    document.getElementById('historyBackdrop')?.addEventListener('click', closeHistory);
    document.getElementById('historyList')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.history-item');
      const id = btn?.getAttribute('data-hist-id');
      if (id) { closeHistory(); playById(id); }
    });

    const memberIds = ['btn-m-all', 'btn-m-madoka', 'btn-m-ayane', 'btn-m-duet'];
    const memberVal: Record<string, string> = { 'btn-m-all': 'all', 'btn-m-madoka': 'madoka', 'btn-m-ayane': 'ayane', 'btn-m-duet': 'duet' };
    memberIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterMember = memberVal[id]; setPressed(memberIds, id); filterSongs();
    }));

    const catIds = ['btn-c-all', 'btn-c-uta_waku', 'btn-c-cover', 'btn-c-short'];
    const catVal: Record<string, string> = { 'btn-c-all': 'all', 'btn-c-uta_waku': 'uta_waku', 'btn-c-cover': 'cover', 'btn-c-short': 'short' };
    catIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterCategory = catVal[id]; setPressed(catIds, id); filterSongs();
    }));

    // お気に入りで絞り込み（トグル）
    document.getElementById('btn-fav')?.addEventListener('click', () => {
      filterFav = !filterFav;
      document.getElementById('btn-fav')?.setAttribute('aria-pressed', String(filterFav));
      filterSongs();
    });
    // 展開シートの★（再生中の曲をお気に入り切替）
    document.getElementById('sheetFav')?.addEventListener('click', () => {
      if (nowPlaying) toggleFav(nowPlaying.id);
    });
    // 永続化された状態をカードに反映
    refreshFavUI();

    document.getElementById('songGrid')?.addEventListener('click', (e) => {
      // ★ボタンが押されたら再生せずお気に入り切替
      const fav = (e.target as HTMLElement).closest('.card-fav');
      if (fav) { const fid = fav.getAttribute('data-id'); if (fid) toggleFav(fid); return; }
      // 共有ボタンが押されたら再生せず共有
      const share = (e.target as HTMLElement).closest('.card-share');
      if (share) {
        const sid = share.getAttribute('data-id');
        const ss = sid ? songs.find((s: any) => s.id === sid) : null;
        if (ss) shareSong(ss);
        return;
      }
      const card = (e.target as HTMLElement).closest('.song-card-item');
      const id = card?.getAttribute('data-id');
      const song = id ? songs.find((s: any) => s.id === id) : null;
      if (song) playSong(song);
    });

    // プレーヤー（展開シート）の共有ボタン
    document.getElementById('sheetShare')?.addEventListener('click', () => shareSong(nowPlaying));

    // ビュー切替（曲 / 配信 / アーティスト）。タブを直接押したらアーティスト絞り込みは解除
    document.getElementById('view-songs')?.addEventListener('click', () => { filterArtist = null; setView('songs'); });
    document.getElementById('view-streams')?.addEventListener('click', () => { filterArtist = null; setView('streams'); });
    document.getElementById('view-artists')?.addEventListener('click', () => { filterArtist = null; setView('artists'); });
    document.getElementById('streamSort')?.addEventListener('change', renderStreams);

    // 配信カードをクリック → その配信まるごと再生キューへ
    document.getElementById('streamGrid')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.stream-card');
      const vid = btn?.getAttribute('data-video-id');
      if (vid) playStream(vid);
    });

    // アーティストをクリック → そのアーティストの曲に絞り込み（曲ビューへ）
    document.getElementById('artistGrid')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.artist-card');
      const a = btn?.getAttribute('data-artist');
      if (a) { filterArtist = a; setView('songs'); }
    });
    // アーティスト絞り込みの解除
    document.getElementById('artistClear')?.addEventListener('click', () => {
      filterArtist = null; updateArtistChip(); shownCount = PAGE_SIZE; applyDisplay();
    });
  });
</script>

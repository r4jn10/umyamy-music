  <!-- Playlist modal（一覧 ⇄ 詳細の2画面） -->
  <div id="plModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="plBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl border border-slate-200 max-h-[80vh] flex flex-col">
      <div class="flex items-center gap-2 p-4 border-b border-slate-100 shrink-0">
        <button id="plBack" type="button" aria-label="一覧へ戻る" class="hidden w-8 h-8 -ml-1 shrink-0 items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <h3 id="plModalTitle" class="font-bold text-ink flex-1 truncate">プレイリスト</h3>
        <button id="plClose" type="button" aria-label="閉じる" class="w-8 h-8 shrink-0 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

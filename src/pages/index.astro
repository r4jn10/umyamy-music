---
import BaseLayout from '../layouts/BaseLayout.astro';
import SongCard from '../components/SongCard.astro';
import SiteFooter from '../components/SiteFooter.astro';
import songsData from '../../public/data/songs.json';

const { songs } = songsData;
const totalSongs = songs.length;
const utaWakuCount = songs.filter(s => s.category === 'uta_waku').length;
const coverCount = songs.filter(s => s.category === 'cover').length;
const lastUpdated = songsData.updatedAt;
---

<BaseLayout title="うみゃみーMusic">
  <div class="max-w-6xl mx-auto px-4 w-full">

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-x-8 gap-y-2 py-6 text-sm">
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-2xl font-extrabold text-ink tabular-nums">{totalSongs}</span>
        <span class="text-slate-400 text-xs font-medium">曲</span>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-lg font-bold text-ayane tabular-nums">{utaWakuCount}</span>
        <span class="text-slate-400 text-xs font-medium">歌枠</span>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-lg font-bold text-madoka tabular-nums">{coverCount}</span>
        <span class="text-slate-400 text-xs font-medium">歌ってみた</span>
      </div>
      <span class="ml-auto text-[11px] text-slate-400">最終更新 <span class="font-semibold text-slate-500">{lastUpdated}</span></span>
    </div>

    <main id="songs" class="pb-16">

      <!-- Featured pick -->
      <section id="featuredSection" class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-display text-sm font-bold text-slate-500 tracking-wide">PICK UP</h2>
          <button id="shuffleBtn" type="button"
                  class="chip text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h5l2 3m9 13h-5l-2-3m7-13l-3 3m3-3v3m0 0h-3M4 20l3-3m-3 3v-3m0 0h3"/>
            </svg>
            シャッフル
          </button>
        </div>
        <div id="featuredCard" class="card overflow-hidden cursor-pointer"></div>
      </section>

      <!-- Search & Filter -->
      <div class="card p-5 mb-8" id="searchArea">
        <div class="relative mb-4">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3m1.8-4.7a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" id="searchInput" placeholder="曲名・アーティスト・タグで検索"
                 class="w-full pl-10 pr-10 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:outline-none focus:border-slate-400 focus:bg-white transition">
          <button id="clearSearch" type="button" aria-label="クリア"
                  class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="flex flex-col gap-3">
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-[11px] text-slate-400 font-semibold mr-1">メンバー</span>
            <button id="btn-m-all" class="chip" aria-pressed="true">ぜんぶ</button>
            <button id="btn-m-madoka" class="chip chip-madoka" aria-pressed="false"><span class="dot" style="background:#ff8184"></span>水面まどか</button>
            <button id="btn-m-ayane" class="chip chip-ayane" aria-pressed="false"><span class="dot" style="background:#54a2e5"></span>白砂あやね</button>
            <button id="btn-m-duet" class="chip chip-duet" aria-pressed="false">うみゃみー</button>
          </div>
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-[11px] text-slate-400 font-semibold mr-1">カテゴリ</span>
            <button id="btn-c-all" class="chip" aria-pressed="true">ぜんぶ</button>
            <button id="btn-c-uta_waku" class="chip" aria-pressed="false">歌枠</button>
            <button id="btn-c-cover" class="chip" aria-pressed="false">歌ってみた</button>
            <span id="resultCount" class="ml-auto text-[11px] font-medium text-slate-400">{totalSongs} 曲</span>
          </div>
        </div>
      </div>

      <!-- Song Grid -->
      <div id="songGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {songs.map(song => (<SongCard song={song} />))}
      </div>

      <!-- Empty state -->
      <div id="emptyState" class="hidden py-20 text-center">
        <p class="font-semibold text-slate-500">「<span id="emptyQuery" class="text-madoka"></span>」に一致する曲がありません</p>
        <button id="resetSearchBtn" type="button" class="mt-4 chip text-xs">検索をリセット</button>
      </div>

    </main>
  </div>

  <div id="songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>

  <!-- Bottom music player -->
  <div id="player" class="hidden">
    <!-- Expanded sheet -->
    <div id="playerSheet" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center">
      <div id="sheetBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
      <div class="relative w-full max-w-4xl bg-white rounded-t-2xl sm:rounded-2xl shadow-2xl border border-slate-200 max-h-[90vh] flex flex-col overflow-hidden">
        <div class="accent-bar h-1 w-full shrink-0"></div>
        <div class="flex items-center justify-between px-4 pt-3 pb-1">
          <span class="accent-text text-[11px] font-bold tracking-widest text-madoka">NOW PLAYING</span>
          <button id="collapseBtn" aria-label="閉じる" class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 p-4 pt-1 min-h-0 overflow-hidden">
          <div class="sm:w-3/5 shrink-0 flex flex-col">
            <div class="aspect-video bg-black rounded-xl overflow-hidden"><div id="ytFrame" class="w-full h-full"></div></div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <h3 id="sheetTitle" class="font-bold text-ink truncate">—</h3>
                <p id="sheetMeta" class="text-xs text-slate-400 truncate">—</p>
              </div>
              <a id="sheetYoutube" href="#" target="_blank" rel="noopener noreferrer"
                 class="shrink-0 inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-[#ff0000] px-3 py-2 rounded-lg">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
                YouTube
              </a>
            </div>
            <!-- Sheet controls -->
            <div class="mt-3 flex items-center justify-center gap-1 text-slate-600">
              <button class="ctl-prev p-2 rounded-full hover:bg-slate-100" aria-label="前へ">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
              </button>
              <button class="ctl-play play-btn-themed p-3 rounded-full bg-ink text-white hover:opacity-90" aria-label="再生/一時停止">
                <svg class="icon-play w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                <svg class="icon-pause w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
              </button>
              <button class="ctl-next p-2 rounded-full hover:bg-slate-100" aria-label="次へ">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 6h2v12h-2zM6 6l8.5 6L6 18z"/></svg>
              </button>
              <button class="ctl-repeat relative p-2 rounded-full hover:bg-slate-100" aria-label="リピート切替">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 2l4 4-4 4M3 11V9a4 4 0 014-4h14M7 22l-4-4 4-4m14 1v2a4 4 0 01-4 4H3"/></svg>
                <span class="repeat-one hidden absolute -top-0.5 -right-0.5 text-[9px] font-bold bg-madoka text-white rounded-full w-3.5 h-3.5 flex items-center justify-center">1</span>
              </button>
              <button class="ctl-shuffle p-2 rounded-full hover:bg-slate-100" aria-label="シャッフル再生">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.66 6.83l-1.41 1.41 3.13 3.13L14.5 16H20v-5.5l-2.04 2.04-2.8-2.71z"/></svg>
              </button>
              <div class="flex items-center gap-1 ml-2">
                <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
                  <svg class="icon-vol w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm13.5 2a4.5 4.5 0 00-2.5-4v8a4.5 4.5 0 002.5-4z"/></svg>
                  <svg class="icon-mute w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm16.6 2l2.1-2.1-1.4-1.4-2.1 2.1-2.1-2.1-1.4 1.4 2.1 2.1-2.1 2.1 1.4 1.4 2.1-2.1 2.1 2.1 1.4-1.4-2.1-2.1z"/></svg>
                </button>
                <input type="range" min="0" max="100" value="100" aria-label="音量" class="volume-slider w-20 accent-[#ff8184]">
              </div>
            </div>
          </div>
          <div class="sm:w-2/5 min-h-0 flex flex-col">
            <p class="text-xs font-bold text-slate-400 mb-2 shrink-0">次の曲</p>
            <div id="upNext" class="flex-1 overflow-y-auto -mr-1 pr-1 space-y-1 min-h-[120px]"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mini bar -->
    <div class="fixed inset-x-0 bottom-0 z-40 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_20px_rgba(15,23,42,0.06)]">
      <div class="accent-bar h-1 w-full"></div>
      <button id="barHandle" aria-label="プレーヤーを開く" class="group w-full flex flex-col items-center pt-1.5 gap-0.5">
        <span class="block w-9 h-1 rounded-full bg-slate-300 group-hover:bg-slate-400 transition"></span>
        <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-slate-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" d="M5 15l7-7 7 7"/></svg>
      </button>
      <div class="max-w-6xl mx-auto px-3 sm:px-4 pb-2 flex items-center gap-2 sm:gap-3">
        <button id="barExpand" class="flex items-center gap-3 min-w-0 flex-1 text-left" aria-label="プレーヤーを開く">
          <img id="barThumb" src="" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
          <div class="min-w-0">
            <p id="barTitle" class="text-sm font-semibold text-ink truncate">—</p>
            <p id="barMeta" class="text-xs text-slate-400 truncate">—</p>
          </div>
        </button>

        <!-- volume (md+) -->
        <div class="hidden md:flex items-center gap-1.5 shrink-0 text-slate-600">
          <button class="ctl-mute p-1.5 rounded-full hover:bg-slate-100" aria-label="ミュート">
            <svg class="icon-vol w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm13.5 2a4.5 4.5 0 00-2.5-4v8a4.5 4.5 0 002.5-4z"/></svg>
            <svg class="icon-mute w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm16.6 2l2.1-2.1-1.4-1.4-2.1 2.1-2.1-2.1-1.4 1.4 2.1 2.1-2.1 2.1 1.4 1.4 2.1-2.1 2.1 2.1 1.4-1.4-2.1-2.1z"/></svg>
          </button>
          <input type="range" min="0" max="100" value="100" aria-label="音量" class="volume-slider w-20 accent-[#ff8184]">
        </div>

        <div class="flex items-center gap-0 sm:gap-1 shrink-0 text-slate-600">
          <button class="ctl-prev p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="前へ">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
          </button>
          <button class="ctl-play play-btn-themed p-2 sm:p-2.5 rounded-full bg-ink text-white hover:opacity-90" aria-label="再生/一時停止">
            <svg class="icon-play w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            <svg class="icon-pause w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
          </button>
          <button class="ctl-next p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="次へ">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 6h2v12h-2zM6 6l8.5 6L6 18z"/></svg>
          </button>
          <button class="ctl-repeat relative p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="リピート切替">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 2l4 4-4 4M3 11V9a4 4 0 014-4h14M7 22l-4-4 4-4m14 1v2a4 4 0 01-4 4H3"/></svg>
            <span class="repeat-one hidden absolute -top-0.5 -right-0.5 text-[9px] font-bold bg-madoka text-white rounded-full w-3.5 h-3.5 flex items-center justify-center">1</span>
          </button>
          <button class="ctl-shuffle p-1.5 sm:p-2 rounded-full hover:bg-slate-100" aria-label="シャッフル再生">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.66 6.83l-1.41 1.41 3.13 3.13L14.5 16H20v-5.5l-2.04 2.04-2.8-2.71z"/></svg>
          </button>
          <a id="barYoutube" href="#" target="_blank" rel="noopener noreferrer" aria-label="YouTubeで開く" class="p-2 rounded-full hover:bg-slate-100 hidden lg:inline-flex text-[#ff0000]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <button id="closePlayerBtn" aria-label="閉じる" class="p-1.5 sm:p-2 rounded-full hover:bg-slate-100 text-slate-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- History modal（#player の外。再生前でも開けるように） -->
  <div id="historyModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="historyBackdrop" class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl border border-slate-200 max-h-[80vh] flex flex-col">
      <div class="flex items-center justify-between p-4 border-b border-slate-100">
        <h3 class="font-bold text-ink">再生履歴</h3>
        <button id="historyClose" aria-label="閉じる" class="w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="historyList" class="overflow-y-auto p-2"></div>
    </div>
  </div>

  <SiteFooter />
</BaseLayout>

<style>
  .player-wrap { aspect-ratio: 16/9; background: #0f172a; }
  .player-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
  @keyframes featured-pop { 0% { opacity: 0; transform: scale(.985); } 100% { opacity: 1; transform: scale(1); } }
  :global(.featured-anim) { animation: featured-pop .3s ease; }

  /* プレーヤーのテーマ色（歌唱者で変化） */
  #player { --accent: #ff8184; --accent-grad: linear-gradient(90deg,#ff8184,#54a2e5); }
  :global(.accent-bar) { background: var(--accent-grad); }
  :global(.accent-text) { color: var(--accent); }
  :global(.volume-slider) { accent-color: var(--accent); }
  :global(.repeat-one) { background: var(--accent) !important; }
  :global(.repeat-active) { color: var(--accent); }
</style>

<script>
  import Fuse from 'fuse.js';

  let filterMember = 'all';
  let filterCategory = 'all';
  let searchText = '';
  let featuredId: string | null = null;

  const songsDataEl = document.getElementById('songs-data');
  const songs = songsDataEl ? JSON.parse(songsDataEl.getAttribute('data-songs') || '[]') : [];

  const fuse = new Fuse(songs, { keys: ['title', 'artist', 'tags'], threshold: 0.3 });

  const CAT_LABEL: Record<string, string> = { uta_waku: '歌枠', cover: '歌ってみた' };
  const MEMBER_ORDER = ['水面まどか', '白砂あやね'];

  function orderPerformers(performers: string[]) {
    return [...performers].sort((a, b) => MEMBER_ORDER.indexOf(a) - MEMBER_ORDER.indexOf(b));
  }
  function memberChipClass(p: string) {
    return p === '水面まどか' ? 'text-[#ff8184] bg-[#ffeef0]' : 'text-[#54a2e5] bg-[#eaf4fc]';
  }

  function fmtTs(sec?: number) {
    if (!sec && sec !== 0) return null;
    if (sec === 0) return null;
    const h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60), s = sec % 60;
    return h > 0 ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}` : `${m}:${String(s).padStart(2,'0')}`;
  }

  function getFiltered() {
    let f = songs;
    if (filterMember === 'ayane') f = f.filter((s: any) => s.performers.includes('白砂あやね'));
    else if (filterMember === 'madoka') f = f.filter((s: any) => s.performers.includes('水面まどか'));
    else if (filterMember === 'duet') f = f.filter((s: any) => s.performers.length > 1);
    if (filterCategory !== 'all') f = f.filter((s: any) => s.category === filterCategory);
    if (searchText) {
      const m = new Set(fuse.search(searchText).map(r => (r.item as any).id));
      f = f.filter((s: any) => m.has(s.id));
    }
    return f;
  }

  function filterSongs() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    searchText = searchInput ? searchInput.value.trim().toLowerCase() : '';
    document.getElementById('clearSearch')?.classList.toggle('hidden', !searchText);
    const filtered = getFiltered();
    const matchedIds = new Set(filtered.map((s: any) => s.id));
    document.querySelectorAll('.song-card-item').forEach(card => {
      card.classList.toggle('hidden', !matchedIds.has(card.getAttribute('data-id')));
    });
    const countEl = document.getElementById('resultCount');
    if (countEl) countEl.textContent = `${filtered.length} 曲`;
    const emptyState = document.getElementById('emptyState');
    const emptyQuery = document.getElementById('emptyQuery');
    if (filtered.length === 0) {
      emptyState?.classList.remove('hidden');
      if (emptyQuery) emptyQuery.textContent = searchText;
    } else emptyState?.classList.add('hidden');
  }

  function clearSearch() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    filterSongs();
  }

  // ===== 下部音楽プレーヤー（YouTube IFrame API） =====
  type RepeatMode = 'all' | 'one' | 'off';
  let ytPlayer: any = null, pending: any = null;
  let queue: any[] = [], qIndex = -1, isPlaying = false;
  let repeatMode: RepeatMode = 'all';   // 連続再生 → 1曲リピート → オフ
  let lastVolume = 100, isMuted = false;

  const apiTag = document.createElement('script');
  apiTag.src = 'https://www.youtube.com/iframe_api';
  document.head.appendChild(apiTag);
  (window as any).onYouTubeIframeAPIReady = () => {
    ytPlayer = new (window as any).YT.Player('ytFrame', {
      playerVars: { rel: 0, playsinline: 1, autoplay: 1 },
      events: {
        onReady: () => {
          applyVolume();
          if (pending) { loadVideo(pending); pending = null; }
        },
        onStateChange: (e: any) => {
          isPlaying = (e.data === 1);
          updatePlayIcon();
          if (e.data === 0) handleEnded(); // ENDED
        },
      },
    });
  };

  function loadVideo(song: any) {
    const start = song.youtube.timestampSec || 0;
    if (ytPlayer && ytPlayer.loadVideoById) ytPlayer.loadVideoById({ videoId: song.youtube.videoId, startSeconds: start });
    else pending = song;
  }

  function saveHistory(song: any) {
    try {
      const k = 'umyamy:history';
      const arr = JSON.parse(localStorage.getItem(k) || '[]');
      if (arr[0] && arr[0].id === song.id) return;
      arr.unshift({ id: song.id, title: song.title, artist: song.artist, videoId: song.youtube.videoId, at: Date.now() });
      localStorage.setItem(k, JSON.stringify(arr.slice(0, 50)));
    } catch (_) {}
  }

  function markPlayingCard(id: string | null) {
    document.querySelectorAll('.song-card-item').forEach(card => {
      const on = card.getAttribute('data-id') === id;
      card.classList.toggle('is-playing', on);
      const pb = card.querySelector('.playing-badge');
      const ts = card.querySelector('.ts-badge:not(.playing-badge)');
      if (pb) pb.classList.toggle('hidden', !on);
      if (ts) ts.classList.toggle('hidden', on);
    });
  }

  function updateBar(song: any) {
    const yurl = song.youtube.url || `https://www.youtube.com/watch?v=${song.youtube.videoId}`;
    const set = (id: string, fn: (el: any) => void) => { const el = document.getElementById(id); if (el) fn(el); };
    set('barThumb', el => el.src = `https://img.youtube.com/vi/${song.youtube.videoId}/default.jpg`);
    set('barTitle', el => el.textContent = song.title);
    set('barMeta', el => el.textContent = song.artist);
    set('sheetTitle', el => el.textContent = song.title);
    set('sheetMeta', el => el.textContent = `${song.artist}${song.streamTitle ? ' — ' + song.streamTitle : ''}`);
    set('barYoutube', el => el.href = yurl);
    set('sheetYoutube', el => el.href = yurl);
  }

  function updatePlayIcon() {
    document.querySelectorAll('.icon-play').forEach(el => el.classList.toggle('hidden', isPlaying));
    document.querySelectorAll('.icon-pause').forEach(el => el.classList.toggle('hidden', !isPlaying));
  }

  // ----- テーマ色（歌唱者で変化） -----
  function applyTheme(song: any) {
    const p: string[] = song.performers || [];
    const hasM = p.includes('水面まどか'), hasA = p.includes('白砂あやね');
    let accent: string, grad: string;
    if (hasM && hasA) { accent = '#b86fb0'; grad = 'linear-gradient(90deg,#ff8184,#54a2e5)'; }
    else if (hasA) { accent = '#54a2e5'; grad = 'linear-gradient(90deg,#54a2e5,#88c4f1)'; }
    else { accent = '#ff8184'; grad = 'linear-gradient(90deg,#ff8184,#ffb0b2)'; }
    const root = document.getElementById('player');
    if (root) {
      root.style.setProperty('--accent', accent);
      root.style.setProperty('--accent-grad', grad);
    }
    document.querySelectorAll('.play-btn-themed').forEach(b => (b as HTMLElement).style.background = grad);
  }

  // ----- 次の曲リスト（YouTube Music風・キューを巡回して表示） -----
  function renderUpNext() {
    const el = document.getElementById('upNext');
    if (!el) return;
    if (queue.length <= 1 || qIndex < 0) {
      el.innerHTML = '<p class="text-xs text-slate-400 py-4 text-center">次の曲はありません</p>';
      return;
    }
    // 現在の曲の次から、キューを一周ぶん並べる（末尾付近で再生開始しても十分な数が出る）
    const items: { song: any; idx: number }[] = [];
    for (let k = 1; k < queue.length; k++) {
      const idx = (qIndex + k) % queue.length;
      items.push({ song: queue[idx], idx });
    }
    el.innerHTML = items.map(({ song: s, idx }) => {
      const thumb = `https://img.youtube.com/vi/${s.youtube.videoId}/default.jpg`;
      return `
        <button type="button" data-qindex="${idx}" class="upnext-item w-full flex items-center gap-2.5 p-1.5 rounded-lg hover:bg-slate-100 text-left">
          <img src="${thumb}" alt="" class="w-10 h-10 rounded object-cover bg-slate-100 shrink-0">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-ink truncate">${s.title}</p>
            <p class="text-[11px] text-slate-400 truncate">${s.artist}</p>
          </div>
        </button>`;
    }).join('');
  }

  // ----- 音量 -----
  function applyVolume() {
    if (!ytPlayer || !ytPlayer.setVolume) return;
    if (isMuted || lastVolume === 0) ytPlayer.mute?.();
    else { ytPlayer.unMute?.(); ytPlayer.setVolume(lastVolume); }
  }
  function updateVolumeUI() {
    const off = isMuted || lastVolume === 0;
    document.querySelectorAll('.volume-slider').forEach(s => (s as HTMLInputElement).value = String(isMuted ? 0 : lastVolume));
    document.querySelectorAll('.icon-vol').forEach(el => el.classList.toggle('hidden', off));
    document.querySelectorAll('.icon-mute').forEach(el => el.classList.toggle('hidden', !off));
  }
  function setVolume(v: number) {
    lastVolume = Math.max(0, Math.min(100, v));
    isMuted = lastVolume === 0;
    applyVolume();
    updateVolumeUI();
  }
  function toggleMute() {
    isMuted = !isMuted;
    if (!isMuted && lastVolume === 0) lastVolume = 50;
    applyVolume();
    updateVolumeUI();
  }

  // ----- リピート -----
  const REPEAT_CYCLE: RepeatMode[] = ['all', 'one', 'off'];
  function cycleRepeat() {
    repeatMode = REPEAT_CYCLE[(REPEAT_CYCLE.indexOf(repeatMode) + 1) % REPEAT_CYCLE.length];
    updateRepeatUI();
    renderUpNext();
  }
  function updateRepeatUI() {
    document.querySelectorAll('.ctl-repeat').forEach(btn => {
      btn.classList.toggle('repeat-active', repeatMode !== 'off');
      btn.setAttribute('aria-label',
        repeatMode === 'all' ? 'リピート: 連続再生' : repeatMode === 'one' ? 'リピート: 1曲' : 'リピート: オフ');
    });
    document.querySelectorAll('.repeat-one').forEach(el => el.classList.toggle('hidden', repeatMode !== 'one'));
  }

  function handleEnded() {
    if (repeatMode === 'one') { playIndex(qIndex); return; }
    if (qIndex >= queue.length - 1) {
      if (repeatMode === 'all') playIndex(0);
      return; // off → 末尾で停止
    }
    playIndex(qIndex + 1);
  }

  function current(song: any) {
    if (!song) return;
    loadVideo(song);
    updateBar(song);
    applyTheme(song);
    saveHistory(song);
    markPlayingCard(song.id);
    renderUpNext();
    document.getElementById('player')?.classList.remove('hidden');
    document.body.style.paddingBottom = '5.75rem';
  }

  function playSong(song: any) {
    queue = getFiltered();
    if (queue.length === 0 || !queue.find((s: any) => s.id === song.id)) queue = songs;
    qIndex = queue.findIndex((s: any) => s.id === song.id);
    current(song);
  }
  function playIndex(i: number) {
    if (queue.length === 0) return;
    qIndex = ((i % queue.length) + queue.length) % queue.length;
    current(queue[qIndex]);
  }
  function next() { if (queue.length) playIndex(qIndex + 1); }
  function prev() { if (queue.length) playIndex(qIndex - 1); }
  function shufflePlay() {
    // 連続再生キューをリセットしてシャッフル（絞り込み中の曲を対象）
    const base = getFiltered();
    const pool = (base.length ? base : songs).slice();
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }
    if (pool.length === 0) return;
    queue = pool;
    qIndex = 0;
    if (repeatMode === 'off') { repeatMode = 'all'; updateRepeatUI(); }
    current(queue[0]);
  }
  function togglePlay() {
    if (!ytPlayer) return;
    if (isPlaying) ytPlayer.pauseVideo(); else ytPlayer.playVideo();
  }

  // ----- 再生履歴 -----
  function openHistory() {
    const list = document.getElementById('historyList');
    if (list) {
      let arr: any[] = [];
      try { arr = JSON.parse(localStorage.getItem('umyamy:history') || '[]'); } catch (_) {}
      if (arr.length === 0) {
        list.innerHTML = '<p class="text-sm text-slate-400 py-10 text-center">まだ再生履歴はありません</p>';
      } else {
        list.innerHTML = arr.map((h: any) => {
          const thumb = `https://img.youtube.com/vi/${h.videoId}/default.jpg`;
          return `
            <button type="button" data-hist-id="${h.id}" class="history-item w-full flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 text-left">
              <img src="${thumb}" alt="" class="w-12 h-12 rounded object-cover bg-slate-100 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-ink truncate">${h.title}</p>
                <p class="text-xs text-slate-400 truncate">${h.artist}</p>
              </div>
            </button>`;
        }).join('');
      }
    }
    document.getElementById('historyModal')?.classList.remove('hidden');
  }
  function closeHistory() { document.getElementById('historyModal')?.classList.add('hidden'); }
  function playById(id: string) {
    const song = songs.find((s: any) => s.id === id);
    if (song) playSong(song);
  }

  function closePlayer() {
    if (ytPlayer && ytPlayer.stopVideo) ytPlayer.stopVideo();
    document.getElementById('player')?.classList.add('hidden');
    document.getElementById('playerSheet')?.classList.add('hidden');
    document.body.style.paddingBottom = '';
    markPlayingCard(null);
  }

  function pickRandomSong(excludeId: string | null) {
    const pool = songs.length > 1 ? songs.filter((s: any) => s.id !== excludeId) : songs;
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function renderFeatured(song: any, animate: boolean) {
    featuredId = song.id;
    const ts = fmtTs(song.youtube.timestampSec);
    const performerBadges = orderPerformers(song.performers).map((p: string) =>
      `<span class="text-[11px] px-2 py-0.5 rounded-full font-semibold ${memberChipClass(p)}">${p}</span>`).join('');

    const card = document.getElementById('featuredCard');
    if (!card) return;
    card.onclick = () => playSong(song);
    const catLabel = CAT_LABEL[song.category] || song.category;
    const thumbUrl = `https://img.youtube.com/vi/${song.youtube.videoId}/mqdefault.jpg`;

    card.innerHTML = `
      <div class="flex flex-col sm:flex-row">
        <div class="relative sm:w-2/5 shrink-0 aspect-video bg-slate-100 overflow-hidden">
          <img src="${thumbUrl}" alt="${song.title}" onerror="this.style.opacity='0.3'" class="w-full h-full object-cover block">
          ${ts ? `<span class="absolute bottom-2 right-2 bg-slate-900/80 text-white text-[11px] font-semibold px-2 py-0.5 rounded">${ts}</span>` : ''}
        </div>
        <div class="p-5 flex flex-col justify-center min-w-0">
          <span class="self-start text-[11px] font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full mb-2">${catLabel}</span>
          <h3 class="font-display text-lg font-extrabold text-ink leading-snug">${song.title}</h3>
          <p class="text-sm text-slate-400 mt-0.5">${song.artist}</p>
          <div class="flex flex-wrap items-center gap-1.5 mt-3">
            ${performerBadges}
            <span class="text-[11px] text-slate-400 ml-1">${song.streamDate}</span>
          </div>
        </div>
      </div>`;

    if (animate) { card.classList.remove('featured-anim'); void card.offsetWidth; card.classList.add('featured-anim'); }
  }

  function setPressed(ids: string[], activeId: string) {
    ids.forEach(id => document.getElementById(id)?.setAttribute('aria-pressed', String(id === activeId)));
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (songs.length > 0) renderFeatured(pickRandomSong(null), false);

    document.getElementById('searchInput')?.addEventListener('input', filterSongs);
    document.getElementById('clearSearch')?.addEventListener('click', clearSearch);
    document.getElementById('resetSearchBtn')?.addEventListener('click', clearSearch);
    document.getElementById('shuffleBtn')?.addEventListener('click', () => renderFeatured(pickRandomSong(featuredId), true));
    document.getElementById('closePlayerBtn')?.addEventListener('click', closePlayer);

    // 共有コントロール（下部バー＋展開シート）
    const on = (sel: string, fn: () => void) =>
      document.querySelectorAll(sel).forEach(el => el.addEventListener('click', fn));
    on('.ctl-play', togglePlay);
    on('.ctl-prev', prev);
    on('.ctl-next', next);
    on('.ctl-shuffle', shufflePlay);
    on('.ctl-repeat', cycleRepeat);
    on('.ctl-mute', toggleMute);
    document.querySelectorAll('.volume-slider').forEach(el =>
      el.addEventListener('input', (e) => setVolume(Number((e.target as HTMLInputElement).value))));

    const openSheet = () => { document.getElementById('playerSheet')?.classList.remove('hidden'); renderUpNext(); };
    const closeSheet = () => document.getElementById('playerSheet')?.classList.add('hidden');
    document.getElementById('barExpand')?.addEventListener('click', openSheet);
    document.getElementById('barHandle')?.addEventListener('click', openSheet);
    document.getElementById('collapseBtn')?.addEventListener('click', closeSheet);
    document.getElementById('sheetBackdrop')?.addEventListener('click', closeSheet);

    updateRepeatUI();
    updateVolumeUI();

    // 次の曲リスト → クリックでジャンプ
    document.getElementById('upNext')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.upnext-item');
      const idx = btn?.getAttribute('data-qindex');
      if (idx !== null && idx !== undefined) playIndex(Number(idx));
    });

    // 再生履歴
    document.getElementById('historyBtn')?.addEventListener('click', openHistory);
    document.getElementById('historyClose')?.addEventListener('click', closeHistory);
    document.getElementById('historyBackdrop')?.addEventListener('click', closeHistory);
    document.getElementById('historyList')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.history-item');
      const id = btn?.getAttribute('data-hist-id');
      if (id) { closeHistory(); playById(id); }
    });

    const memberIds = ['btn-m-all', 'btn-m-madoka', 'btn-m-ayane', 'btn-m-duet'];
    const memberVal: Record<string, string> = { 'btn-m-all': 'all', 'btn-m-madoka': 'madoka', 'btn-m-ayane': 'ayane', 'btn-m-duet': 'duet' };
    memberIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterMember = memberVal[id]; setPressed(memberIds, id); filterSongs();
    }));

    const catIds = ['btn-c-all', 'btn-c-uta_waku', 'btn-c-cover'];
    const catVal: Record<string, string> = { 'btn-c-all': 'all', 'btn-c-uta_waku': 'uta_waku', 'btn-c-cover': 'cover' };
    catIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => {
      filterCategory = catVal[id]; setPressed(catIds, id); filterSongs();
    }));

    document.getElementById('songGrid')?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.song-card-item');
      const songJson = card?.getAttribute('data-song');
      if (songJson) playSong(JSON.parse(songJson));
    });
  });
</script>
